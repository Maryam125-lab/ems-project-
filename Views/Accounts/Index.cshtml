@{ ViewData["Title"] = "HR Accounts"; ViewData["Active"] = "HRAccounts"; }
<div class="page-header anim-fade-in-up">
    <div>
        <h1 class="page-title"><i class="fa-solid fa-user-lock" aria-hidden="true"></i> HR Accounts</h1>
        <div class="page-date">Manage HR admin user accounts and permissions</div>
    </div>
    <button class="btn btn-primary" onclick="openModal('accountModal')">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Create Account
    </button>
</div>
<div class="table-container anim-fade-in-up">
    <div class="filter-bar"><input class="filter-search" type="text" placeholder="Search accounts…" id="accSearch" oninput="filterTable('accTable','accSearch')" /></div>
    <div class="table-scroll-wrapper">
        <table class="data-table" id="accTable">
            <thead><tr><th>User</th><th>Username</th><th>Role</th><th>Branch</th><th>Last Login</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                <tr><td><div class="cell-employee"><div class="cell-avatar blue">SU</div><div><div class="cell-name">Super Admin</div><div class="cell-sub">superadmin@esspl.com</div></div></div></td><td><span class="cell-mono">superadmin</span></td><td><span class="tag tag-blue">Super Admin</span></td><td>All</td><td><span class="cell-mono" style="font-size:11px;">Apr 18, 12:00</span></td><td><span class="status-badge approved">Active</span></td><td><div class="table-actions"><button class="table-action-btn" onclick="openModal('accountModal')"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/></svg></button></div></td></tr>
                <tr><td><div class="cell-employee"><div class="cell-avatar purple">SA</div><div><div class="cell-name">Sara Ali</div><div class="cell-sub">sara.a@esspl.com</div></div></div></td><td><span class="cell-mono">hr1</span></td><td><span class="tag tag-purple">HR Admin</span></td><td>Head Office</td><td><span class="cell-mono" style="font-size:11px;">Apr 18, 09:30</span></td><td><span class="status-badge approved">Active</span></td><td><div class="table-actions"><button class="table-action-btn" onclick="openModal('accountModal')"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/></svg></button></div></td></tr>
                <tr><td><div class="cell-employee"><div class="cell-avatar purple">KY</div><div><div class="cell-name">Kamran Yusuf</div><div class="cell-sub">kamran.y@esspl.com</div></div></div></td><td><span class="cell-mono">hr2</span></td><td><span class="tag tag-purple">HR Admin</span></td><td>Lahore</td><td><span class="cell-mono" style="font-size:11px;">Apr 17, 18:00</span></td><td><span class="status-badge approved">Active</span></td><td><div class="table-actions"><button class="table-action-btn" onclick="openModal('accountModal')"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/></svg></button></div></td></tr>
            </tbody>
        </table>
    </div>
    <div class="table-pagination"><div class="pagination-info">Showing all <strong>3</strong> accounts</div><div class="pagination-controls"><button class="page-btn active">1</button></div></div>
</div>
<div class="modal-backdrop" id="accountModal">
    <div class="modal-dialog"><div class="modal-header"><div class="modal-title"><i class="fa-solid fa-user-lock" aria-hidden="true"></i> Create Account</div><button class="modal-close" onclick="closeModal('accountModal')"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
    <div class="modal-body"><div class="form-grid form-grid-2"><div class="field-group"><label class="field-label">Full Name <span class="field-required">*</span></label><input type="text" class="field-input" /></div><div class="field-group"><label class="field-label">Email <span class="field-required">*</span></label><input type="email" class="field-input" /></div><div class="field-group"><label class="field-label">Username <span class="field-required">*</span></label><input type="text" class="field-input" /></div><div class="field-group"><label class="field-label">Role</label><select class="field-select"><option>HR Admin</option><option>Super Admin</option></select></div><div class="field-group"><label class="field-label">Branch</label><select class="field-select"><option>All</option><option>Head Office</option><option>Lahore</option><option>Islamabad</option></select></div><div class="field-group"><label class="field-label">Temp Password</label><input type="text" class="field-input" value="temp@123" readonly /></div></div></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('accountModal')">Cancel</button><button class="btn btn-primary" onclick="closeModal('accountModal'); showToast('Account created','success')">Create Account</button></div></div>
</div>
@section Scripts { <script src="~/js/tables.js"></script><script src="~/js/modals.js"></script> }
