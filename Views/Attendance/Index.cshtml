@{
    ViewData["Title"] = "Attendance";
    ViewData["Active"] = "Attendance";
}

<!-- PAGE HEADER -->
<div class="page-header anim-fade-in-up">
    <div>
        <h1 class="page-title">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Digital Attendance Ledger
            <span class="live-dot">LIVE</span>
        </h1>
        <div class="page-date"><i class="fa-regular fa-calendar" aria-hidden="true"></i> @DateTime.Now.ToString("dddd, dd MMMM yyyy")</div>
    </div>
    <div style="display:flex;gap:8px;">
        <button class="btn btn-ghost" onclick="showToast('Exported to Excel','success')">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export
        </button>
        <button class="btn btn-success" id="btnSubmitHO" onclick="submitToHO()">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            Submit to HO
        </button>
    </div>
</div>

<!-- KPI STRIP -->
<div class="kpi-grid stagger" style="grid-template-columns: repeat(5, 1fr); margin-bottom: 20px;">
    <div class="stat-card green"><div class="kpi-label"><span class="status-dot online"></span> Present</div><div class="kpi-num" style="color:var(--accent2)" id="kpiPresent">--</div><div class="kpi-sub" id="kpiPresentPct">Loading...</div></div>
    <div class="stat-card amber"><div class="kpi-label"><span class="status-dot away"></span> Late</div><div class="kpi-num" style="color:var(--accent3)" id="kpiLate">--</div><div class="kpi-sub" id="kpiLatePct">Loading...</div></div>
    <div class="stat-card red"><div class="kpi-label"><span class="status-dot offline"></span> Absent</div><div class="kpi-num" style="color:var(--accent4)" id="kpiAbsent">--</div><div class="kpi-sub" id="kpiAbsentPct">Loading...</div></div>
    <div class="stat-card blue"><div class="kpi-label"><svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/></svg> On Leave</div><div class="kpi-num" id="kpiOnLeave">--</div><div class="kpi-sub" id="kpiOnLeavePct">Loading...</div></div>
    <div class="stat-card purple"><div class="kpi-label"><svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Verified</div><div class="kpi-num" style="color:#8b5cf6" id="kpiVerified">--</div><div class="kpi-sub" id="kpiVerifiedPct">Loading...</div></div>
</div>

<!-- FILTERS & TABLE -->
<div class="table-container anim-fade-in-up">
    <div class="filter-bar">
        <div class="filter-group">
            <label class="filter-label">Date</label>
            <input type="date" class="field-input" style="height:34px;font-size:12px;" id="attDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" onchange="loadAttendance()" />
        </div>
        <div class="filter-group">
            <label class="filter-label">Location</label>
            <select class="filter-select" id="attLocation" onchange="loadAttendance()"><option value="">All Locations</option></select>
        </div>
        <div class="filter-group">
            <label class="filter-label">Department</label>
            <select class="filter-select" id="attDept" onchange="filterAttTable()"><option value="all">All Departments</option></select>
        </div>
        <input class="filter-search" type="text" placeholder="Search by name…" id="attSearch" oninput="filterAttTable()" />
        <button class="btn btn-sm btn-outline" onclick="markAllPresent()" style="margin-left:auto;">Mark All Present</button>
    </div>

    <div class="table-scroll-wrapper">
        <table class="data-table" id="attendanceTable">
            <thead>
                <tr>
                    <th style="width:30px;">#</th>
                    <th>Employee</th>
                    <th>Department</th>
                    <th>Shift</th>
                    <th style="width:120px;">Status</th>
                    <th style="width:110px;">Check-In</th>
                    <th style="width:110px;">Check-Out</th>
                    <th style="width:80px;">Verified</th>
                </tr>
            </thead>
            <tbody id="attTableBody">
                <tr><td colspan="8" style="text-align:center;padding:40px;color:var(--muted);">Loading attendance...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="table-pagination"><div class="pagination-info" id="attPagInfo">Loading...</div></div>
</div>

@section Scripts {
<script src="~/js/tables.js" asp-append-version="true"></script>
<script src="~/js/modals.js" asp-append-version="true"></script>
<script>
    let attData = [];

    async function loadAttendance() {
        const date = document.getElementById('attDate').value;
        const location = document.getElementById('attLocation').value;
        const params = { date };
        if (location) params.location_id = location;

        const res = await EmsApi.attendance.getSheet(params);
        const tbody = document.getElementById('attTableBody');

        if (res.success && res.data) {
            // Handle both flat array and object with rows
            attData = Array.isArray(res.data) ? res.data : (res.data.rows || []);
            renderAttendance(attData);
            updateAttKPIs(attData);
        } else {
            tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;color:var(--accent4);">' + (res.error || 'Could not load attendance') + '</td></tr>';
        }
    }

    function renderAttendance(data) {
        const tbody = document.getElementById('attTableBody');
        const pagInfo = document.getElementById('attPagInfo');
        if (!data.length) {
            tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;color:var(--muted);">No attendance records for this date</td></tr>';
            if (pagInfo) pagInfo.textContent = 'No records';
            return;
        }
        tbody.innerHTML = data.map((a, i) => {
            const name = a.name || a.employee_name || a.employee_id || 'Employee';
            const initials = name.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase();
            const status = a.status || 'present';
            const statusColor = status === 'present' ? 'green' : status === 'late' ? 'amber' : status === 'absent' ? 'red' : 'blue';
            const isLate = status === 'late';
            const lateStyle = isLate ? 'border-color:var(--accent4);color:var(--accent4);' : '';
            const acked = a.employee_ack || a.ack || false;
            return `<tr ${isLate ? 'style="background:rgba(239,68,68,0.04);"' : ''}>
                <td><span class="cell-mono">${i+1}</span></td>
                <td><div class="cell-employee"><div class="cell-avatar ${statusColor}">${initials}</div><div class="cell-name">${name}</div></div></td>
                <td>${a.designation || a.department_name || '—'}</td>
                <td><span class="cell-mono">${(a.shift && a.shift.name) || a.shift_name || a.shift_start || '—'}</span></td>
                <td>
                    <select class="filter-select" style="height:30px;font-size:11px;padding:0 24px 0 8px;min-width:90px;${lateStyle}" data-emp="${a.employee_id}" data-field="status">
                        ${['present','late','absent','half_day','on_leave'].map(s => `<option value="${s}" ${s===status?'selected':''}>${s.replace('_',' ').replace(/\b\w/g,l=>l.toUpperCase())}</option>`).join('')}
                    </select>
                </td>
                <td><input type="time" class="field-input" style="height:30px;font-size:11px;padding:0 6px;width:100px;${lateStyle}" value="${a.check_in || ''}" data-emp="${a.employee_id}" data-field="check_in" /></td>
                <td><input type="time" class="field-input" style="height:30px;font-size:11px;padding:0 6px;width:100px;" value="${a.check_out || ''}" data-emp="${a.employee_id}" data-field="check_out" /></td>
                <td style="text-align:center;">
                    ${acked ? '<span class="tag tag-green" style="font-size:10px;"><svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Yes</span>' : '<span class="tag tag-gray" style="font-size:10px;">Pending</span>'}
                </td>
            </tr>`;
        }).join('');
        if (pagInfo) pagInfo.innerHTML = `Showing <strong>${data.length}</strong> records`;
    }

    function updateAttKPIs(data) {
        const total = data.length || 1;
        const present = data.filter(a => a.status === 'present').length;
        const late = data.filter(a => a.status === 'late').length;
        const absent = data.filter(a => a.status === 'absent').length;
        const onLeave = data.filter(a => a.status === 'on_leave').length;
        const verified = data.filter(a => a.employee_ack || a.ack).length;

        document.getElementById('kpiPresent').textContent = present;
        document.getElementById('kpiPresentPct').textContent = Math.round(present/total*100) + '% of total';
        document.getElementById('kpiLate').textContent = late;
        document.getElementById('kpiLatePct').textContent = Math.round(late/total*100) + '% of total';
        document.getElementById('kpiAbsent').textContent = absent;
        document.getElementById('kpiAbsentPct').textContent = Math.round(absent/total*100) + '% of total';
        document.getElementById('kpiOnLeave').textContent = onLeave;
        document.getElementById('kpiOnLeavePct').textContent = Math.round(onLeave/total*100) + '% of total';
        document.getElementById('kpiVerified').textContent = verified;
        document.getElementById('kpiVerifiedPct').textContent = Math.round(verified/total*100) + '% verified';
    }

    function markAllPresent() {
        document.querySelectorAll('#attendanceTable tbody select[data-field="status"]').forEach(s => { s.value = 'present'; s.style.borderColor = ''; s.style.color = ''; });
        showToast('All employees marked as Present', 'success');
    }

    async function submitToHO() {
        const date = document.getElementById('attDate').value;
        const locationId = document.getElementById('attLocation').value;
        if (!locationId) { showToast('Please select a location first', 'error'); return; }
        const rows = [];
        document.querySelectorAll('#attendanceTable tbody tr').forEach(row => {
            const empId = row.querySelector('select[data-field="status"]')?.dataset.emp;
            if (!empId) return;
            rows.push({
                employee_id: empId,
                status: row.querySelector('select[data-field="status"]').value,
                check_in: row.querySelector('input[data-field="check_in"]').value || null,
                check_out: row.querySelector('input[data-field="check_out"]').value || null
            });
        });
        
        const saveRes = await EmsApi.attendance.save({ date, location_id: locationId, rows });
        if (!saveRes.success) {
            showToast(saveRes.error || 'Failed to save attendance', 'error');
            return;
        }

        const submitRes = await EmsApi.attendance.submit({ date, location_id: locationId });
        if (submitRes.success) {
            showToast('Attendance saved & submitted to HO', 'success');
            loadAttendance();
        } else {
            showToast('Saved, but failed to submit: ' + (submitRes.error || ''), 'warning');
        }
    }

    function filterAttTable() {
        const dept = document.getElementById('attDept').value;
        const search = document.getElementById('attSearch').value.toLowerCase();
        let filtered = attData;
        if (dept !== 'all') filtered = filtered.filter(a => (a.department_name || '').toLowerCase() === dept.toLowerCase());
        if (search) filtered = filtered.filter(a => (a.employee_name || '').toLowerCase().includes(search));
        renderAttendance(filtered);
    }

    // Load locations & departments for filters
    (async function loadFilters() {
        const [locRes, deptRes] = await Promise.allSettled([EmsApi.config.get('work-locations'), EmsApi.config.get('departments')]);
        if (locRes.status === 'fulfilled' && locRes.value.success && Array.isArray(locRes.value.data)) {
            const sel = document.getElementById('attLocation');
            locRes.value.data.forEach(l => { const o = document.createElement('option'); o.value = l.id; o.textContent = l.location_name || l.name; sel.appendChild(o); });
            // Select first location by default to load data
            if (sel.options.length > 1) {
                sel.selectedIndex = 1;
            }
        }
        if (deptRes.status === 'fulfilled' && deptRes.value.success && Array.isArray(deptRes.value.data)) {
            const sel = document.getElementById('attDept');
            deptRes.value.data.forEach(d => { const o = document.createElement('option'); o.value = d.department_name || d.name; o.textContent = d.department_name || d.name; sel.appendChild(o); });
        }
        
        loadAttendance();
    })();
</script>
}
