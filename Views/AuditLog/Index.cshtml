@{ ViewData["Title"] = "Audit Log"; ViewData["Active"] = "AuditLog"; }
<div class="page-header anim-fade-in-up">
    <div>
        <h1 class="page-title"><i class="fa-solid fa-clipboard-list" aria-hidden="true"></i> Audit Log</h1>
        <div class="page-date">System-wide activity trail for compliance and tracking</div>
    </div>
    <button class="btn btn-ghost" onclick="exportAuditCSV()">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Export CSV
    </button>
</div>
<div class="table-container anim-fade-in-up">
    <div class="filter-bar">
        <div class="filter-group"><label class="filter-label">Action</label><select class="filter-select" onchange="filterTableByColumn('auditTable', 1, this.value)"><option value="all">All Actions</option><option>CREATE</option><option>UPDATE</option><option>DELETE</option><option>LOGIN</option></select></div>
        <div class="filter-group"><label class="filter-label">Module</label><select class="filter-select" id="moduleFilter" onchange="filterTableByColumn('auditTable', 2, this.value)"><option value="all">All Modules</option></select></div>
        <input class="filter-search" type="text" placeholder="Search logs…" id="auditSearch" oninput="filterTable('auditTable','auditSearch')" />
    </div>
    <div class="table-scroll-wrapper">
        <table class="data-table" id="auditTable">
            <thead><tr><th>Timestamp</th><th>Action</th><th>Module</th><th>Description</th><th>User</th><th>IP Address</th></tr></thead>
            <tbody id="auditTableBody">
                <tr><td colspan="6" style="text-align:center;padding:40px;color:var(--muted);">Loading audit logs...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="table-pagination" id="auditTable-pagination">
        <div class="pagination-info">Showing <strong>0</strong> to <strong>0</strong> of <strong>0</strong></div>
        <div class="pagination-controls"></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/tables.js" asp-append-version="true"></script>
    <script src="~/js/modals.js" asp-append-version="true"></script>
    <script>
        let allLogs = [];

        async function loadAuditLogs() {
            const tbody = document.getElementById('auditTableBody');
            tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--muted);">Loading audit logs...</td></tr>';

            const res = await EmsApi.audit.list();
            if (res.success && res.data) {
                allLogs = Array.isArray(res.data) ? res.data : (res.data.data || []);
                renderAuditLogs(allLogs);
                populateModuleFilter(allLogs);
                initPagination('auditTable', 10);
            } else {
                tbody.innerHTML = `<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--accent4);">${res.error || 'Failed to load audit logs.'}</td></tr>`;
            }
        }

        function renderAuditLogs(data) {
            const tbody = document.getElementById('auditTableBody');
            if (!data.length) {
                tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:40px;color:var(--muted);">No audit logs found.</td></tr>';
                return;
            }

            tbody.innerHTML = data.map(log => {
                const date = log.created_at ? new Date(log.created_at).toLocaleString('en-US', {
                    month: 'short',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit',
                    hour12: false
                }) : '—';
                
                const rawAction = (log.action || 'UPDATE').toUpperCase();
                let action = rawAction;
                if (rawAction === 'INSERT') action = 'CREATE';

                let tagClass = 'tag-blue';
                if (action === 'CREATE') tagClass = 'tag-green';
                else if (action === 'DELETE') tagClass = 'tag-red';
                else if (action === 'LOGIN' || action === 'USER_LOGIN') tagClass = 'tag-purple';

                const moduleRaw = log.module || 'System';
                // Capitalize first letter of module
                const module = moduleRaw.charAt(0).toUpperCase() + moduleRaw.slice(1).replace('_', ' ');
                const description = log.description || 'Activity recorded';
                const user = log.user_name || 'System';
                const ip = log.ip_address || '—';

                return `<tr>
                    <td><span class="cell-mono" style="font-size:11px;">${date}</span></td>
                    <td><span class="tag ${tagClass}">${action}</span></td>
                    <td><strong>${module}</strong></td>
                    <td>${description}</td>
                    <td><span style="color:var(--muted);">${user}</span></td>
                    <td><span class="cell-mono" style="font-size:11px;">${ip}</span></td>
                </tr>`;
            }).join('');
        }

        function populateModuleFilter(logs) {
            const select = document.getElementById('moduleFilter');
            select.innerHTML = '<option value="all">All Modules</option>';
            
            const modules = [...new Set(logs.map(log => {
                const m = log.module || 'System';
                return m.charAt(0).toUpperCase() + m.slice(1).replace('_', ' ');
            }).filter(Boolean))];

            modules.sort().forEach(m => {
                const opt = document.createElement('option');
                opt.value = m;
                opt.textContent = m;
                select.appendChild(opt);
            });
        }

        function exportAuditCSV() {
            if (!allLogs.length) {
                showToast('No log data available to export', 'warning');
                return;
            }
            
            let csvContent = "data:text/csv;charset=utf-8,";
            csvContent += "Timestamp,Action,Module,Description,User,IP Address\r\n";
            
            allLogs.forEach(log => {
                const date = log.created_at ? new Date(log.created_at).toISOString() : '—';
                const action = (log.action || 'UPDATE').toUpperCase().replace('INSERT', 'CREATE');
                const module = (log.module || 'System').replace('_', ' ');
                const desc = `"${(log.description || '').replace(/"/g, '""')}"`;
                const user = (log.user_name || 'System');
                const ip = log.ip_address || '—';
                csvContent += `${date},${action},${module},${desc},${user},${ip}\r\n`;
            });
            
            const encodedUri = encodeURI(csvContent);
            const link = document.createElement("a");
            link.setAttribute("href", encodedUri);
            link.setAttribute("download", `EMS_AuditLog_${new Date().toISOString().split('T')[0]}.csv`);
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            showToast('Audit log exported successfully!', 'success');
        }

        loadAuditLogs();
    </script>
}

