@{
    ViewData["Title"] = "Add Employee";
    ViewData["Active"] = "Employees";
}

<!-- PAGE HEADER -->
<div class="page-header anim-fade-in-up">
    <div>
        <h1 class="page-title">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/>
                <line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/>
            </svg>
            Employee Onboarding
        </h1>
        <div class="page-date">Register a new employee into the system</div>
    </div>
    <a class="btn btn-ghost" asp-action="Index">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to Directory
    </a>
</div>

<!-- STEP INDICATOR -->
<div class="step-indicator anim-fade-in-up onboarding-steps">
    <div class="step-line" style="position:absolute; top:18px; left:0; right:0; height:2px; background:var(--surface2); z-index:0;">
        <div id="stepProgress" style="width:0%; height:100%; background:var(--accent); transition: width 0.3s ease;"></div>
    </div>
    <div class="step-item active" data-step="1" style="z-index:1; background:var(--surface1); padding:0 10px; text-align:center;">
        <div class="step-dot" style="width:36px; height:36px; border-radius:50%; border:2px solid var(--accent); display:flex; align-items:center; justify-content:center; margin:0 auto 8px; background:var(--surface1); font-weight:600; color:var(--accent);">1</div>
        <div style="font-size:11px; font-weight:600; color:var(--accent);">Personal</div>
    </div>
    <div class="step-item" data-step="2" style="z-index:1; background:var(--surface1); padding:0 10px; text-align:center;">
        <div class="step-dot" style="width:36px; height:36px; border-radius:50%; border:2px solid var(--surface3); display:flex; align-items:center; justify-content:center; margin:0 auto 8px; background:var(--surface1); font-weight:600; color:var(--muted);">2</div>
        <div style="font-size:11px; font-weight:600; color:var(--muted);">Job</div>
    </div>
    <div class="step-item" data-step="3" style="z-index:1; background:var(--surface1); padding:0 10px; text-align:center;">
        <div class="step-dot" style="width:36px; height:36px; border-radius:50%; border:2px solid var(--surface3); display:flex; align-items:center; justify-content:center; margin:0 auto 8px; background:var(--surface1); font-weight:600; color:var(--muted);">3</div>
        <div style="font-size:11px; font-weight:600; color:var(--muted);">Schedule</div>
    </div>
    <div class="step-item" data-step="4" style="z-index:1; background:var(--surface1); padding:0 10px; text-align:center;">
        <div class="step-dot" style="width:36px; height:36px; border-radius:50%; border:2px solid var(--surface3); display:flex; align-items:center; justify-content:center; margin:0 auto 8px; background:var(--surface1); font-weight:600; color:var(--muted);">4</div>
        <div style="font-size:11px; font-weight:600; color:var(--muted);">Payroll</div>
    </div>
    <div class="step-item" data-step="5" style="z-index:1; background:var(--surface1); padding:0 10px; text-align:center;">
        <div class="step-dot" style="width:36px; height:36px; border-radius:50%; border:2px solid var(--surface3); display:flex; align-items:center; justify-content:center; margin:0 auto 8px; background:var(--surface1); font-weight:600; color:var(--muted);">5</div>
        <div style="font-size:11px; font-weight:600; color:var(--muted);">Bank</div>
    </div>
    <div class="step-item" data-step="6" style="z-index:1; background:var(--surface1); padding:0 10px; text-align:center;">
        <div class="step-dot" style="width:36px; height:36px; border-radius:50%; border:2px solid var(--surface3); display:flex; align-items:center; justify-content:center; margin:0 auto 8px; background:var(--surface1); font-weight:600; color:var(--muted);">6</div>
        <div style="font-size:11px; font-weight:600; color:var(--muted);">Access</div>
    </div>
    <div class="step-item" data-step="7" style="z-index:1; background:var(--surface1); padding:0 10px; text-align:center;">
        <div class="step-dot" style="width:36px; height:36px; border-radius:50%; border:2px solid var(--surface3); display:flex; align-items:center; justify-content:center; margin:0 auto 8px; background:var(--surface1); font-weight:600; color:var(--muted);">7</div>
        <div style="font-size:11px; font-weight:600; color:var(--muted);">Review</div>
    </div>
</div>

<form id="onboardingForm" class="anim-fade-in-up" onsubmit="return handleOnboarding(event)" novalidate>
    <div class="card" style="margin-bottom:16px; min-height: 400px;">
        <!-- STEP 1: Personal Information -->
        <div class="form-step active" id="step-1">
            <div class="form-section-title">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Personal Information
            </div>
            <div class="form-grid form-grid-3">
                <div class="field-group">
                    <label class="field-label">First Name <span class="field-required">*</span></label>
                    <input type="text" name="first_name" class="field-input" placeholder="e.g. Ahmed" required oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '')" />
                </div>
                <div class="field-group">
                    <label class="field-label">Last Name <span class="field-required">*</span></label>
                    <input type="text" name="last_name" class="field-input" placeholder="e.g. Khan" required oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '')" />
                </div>
                <div class="field-group">
                    <label class="field-label">Father's Name <span class="field-required">*</span></label>
                    <input type="text" name="father_name" class="field-input" placeholder="e.g. Mohammad Khan" required oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '')" />
                </div>
                <div class="field-group">
                    <label class="field-label">CNIC / ID Number <span class="field-required">*</span></label>
                    <input type="text" name="cnic" class="field-input" placeholder="e.g. 4220112345678" required minlength="13" maxlength="13" data-message="CNIC must be exactly 13 digits." oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                </div>
                <div class="field-group">
                    <label class="field-label">Date of Birth <span class="field-required">*</span></label>
                    <input type="date" name="dob" class="field-input" required />
                </div>
                <div class="field-group">
                    <label class="field-label">Gender</label>
                    <select name="gender" class="field-select" required>
                        <option value="">Select Gender</option>
                        <option value="male">Male</option>
                        <option value="female">Female</option>
                        <option value="other">Other</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Blood Group</label>
                    <select name="blood_group" class="field-select" required>
                        <option value="">Select</option>
                        <option>A+</option><option>A-</option><option>B+</option><option>B-</option>
                        <option>O+</option><option>O-</option><option>AB+</option><option>AB-</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Phone Number <span class="field-required">*</span></label>
                    <input type="tel" name="phone" class="field-input" placeholder="e.g. 03001234567" required minlength="11" maxlength="11" data-message="Phone number must be exactly 11 digits." oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                </div>
                <div class="field-group">
                    <label class="field-label">Marital Status</label>
                    <select name="marital_status" class="field-select" required>
                        <option value="">Select</option>
                        <option value="single">Single</option><option value="married">Married</option><option value="divorced">Divorced</option><option value="widowed">Widowed</option>
                    </select>
                </div>
                <div class="field-group form-full">
                    <label class="field-label">Address</label>
                    <textarea name="address" class="field-textarea" rows="2" placeholder="Full residential address" required minlength="8"></textarea>
                </div>
            </div>
        </div>

        <!-- STEP 2: Job Information -->
        <div class="form-step" id="step-2" style="display:none;">
            <div class="form-section-title">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                Job Information
            </div>
            <div class="form-grid form-grid-3">
                <div class="field-group">
                    <label class="field-label">Department <span class="field-required">*</span></label>
                    <select name="department_id" id="department_id" class="field-select" required>
                        <option value="">Loading...</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Designation <span class="field-required">*</span></label>
                    <select name="designation_id" id="designation_id" class="field-select" required>
                        <option value="">Loading...</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Branch <span class="field-required">*</span></label>
                    <select name="location_id" id="location_id" class="field-select" required>
                        <option value="">Loading...</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Employment Type</label>
                    <select name="employee_type_id" id="employee_type_id" class="field-select">
                        <option value="">Loading...</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Work Mode</label>
                    <select name="work_mode_id" id="work_mode_id" class="field-select">
                        <option value="">Loading...</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- STEP 3: Schedule & Reporting -->
        <div class="form-step" id="step-3" style="display:none;">
            <div class="form-section-title">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
                Schedule & Reporting
            </div>
            <div class="form-grid form-grid-3">
                <div class="field-group">
                    <label class="field-label">Shift</label>
                    <select name="shift_id" id="shift_id" class="field-select">
                        <option value="">Loading...</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Joining Date <span class="field-required">*</span></label>
                    <input type="date" name="joining_date" class="field-input" required />
                </div>
                <div class="field-group">
                    <label class="field-label">Reporting Manager</label>
                    <select name="manager_id" id="manager_id" class="field-select">
                        <option value="">Select Manager</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Job Status <span class="field-required">*</span></label>
                    <select name="job_status_id" id="job_status_id" class="field-select" required>
                        <option value="">Loading...</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- STEP 4: Payroll Setup -->
        <div class="form-step" id="step-4" style="display:none;">
            <div class="form-section-title">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 1v22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7H14a3.5 3.5 0 0 1 0 7H6"/></svg>
                Payroll Setup
            </div>
            <div class="form-grid form-grid-3">
                <div class="field-group">
                    <label class="field-label">Basic Salary (PKR)</label>
                    <input type="number" name="basic_salary" class="field-input" placeholder="e.g. 80000" oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                </div>
                <div class="field-group">
                    <label class="field-label">Payroll Cycle</label>
                    <select name="payroll_cycle" class="field-select">
                        <option value="monthly">Monthly</option>
                        <option value="biweekly">Bi-weekly</option>
                        <option value="weekly">Weekly</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Tax Status</label>
                    <select name="tax_status" class="field-select">
                        <option value="">Select</option>
                        <option value="taxable">Taxable</option>
                        <option value="non_taxable">Non-taxable</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Allowance Notes</label>
                    <input type="text" name="allowance_notes" class="field-input" placeholder="e.g. Fuel / medical allowance" />
                </div>
                <div class="field-group">
                    <label class="field-label">Probation Salary</label>
                    <input type="number" name="probation_salary" class="field-input" placeholder="Optional" oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                </div>
                <div class="field-group">
                    <label class="field-label">Salary Effective From</label>
                    <input type="date" name="salary_effective_from" class="field-input" />
                </div>
            </div>
        </div>

        <!-- STEP 5: Bank & Documents -->
        <div class="form-step" id="step-5" style="display:none;">
            <div class="form-section-title">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 21h18"/><path d="M4 10h16"/><path d="M6 10v8M10 10v8M14 10v8M18 10v8"/><path d="M12 3 3 8h18z"/></svg>
                Bank & Documents
            </div>
            <div class="form-grid form-grid-3">
                <div class="field-group">
                    <label class="field-label">Bank Name <span class="field-required">*</span></label>
                    <input type="text" name="bank_name" class="field-input" placeholder="e.g. HBL" required oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '')" />
                </div>
                <div class="field-group">
                    <label class="field-label">Account Title <span class="field-required">*</span></label>
                    <input type="text" name="bank_account_title" class="field-input" placeholder="e.g. Ahmed Khan" required oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '')" />
                </div>
                <div class="field-group">
                    <label class="field-label">IBAN <span class="field-required">*</span></label>
                    <input type="text" name="bank_account_no" class="field-input" placeholder="e.g. PK36HABB0012345678901" required minlength="16" maxlength="34" data-message="IBAN must be 16 to 34 letters/numbers." oninput="this.value = this.value.replace(/[^a-zA-Z0-9]/g, '').toUpperCase()" />
                </div>
                <div class="field-group">
                    <label class="field-label">CNIC Copy</label>
                    <input type="file" name="cnic_document" class="field-input" accept=".pdf,.jpg,.jpeg,.png" />
                </div>
                <div class="field-group">
                    <label class="field-label">Resume / CV</label>
                    <input type="file" name="resume_document" class="field-input" accept=".pdf,.doc,.docx" />
                </div>
                <div class="field-group">
                    <label class="field-label">Offer Letter</label>
                    <input type="file" name="offer_letter_document" class="field-input" accept=".pdf,.doc,.docx" />
                </div>
            </div>
        </div>

        <!-- STEP 6: Login & Access -->
        <div class="form-step" id="step-6" style="display:none;">
            <div class="form-section-title">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Login & Access
            </div>
            <div class="form-grid form-grid-3">
                <div class="field-group">
                    <label class="field-label">Official Email <span class="field-required">*</span></label>
                    <input type="email" name="email" class="field-input" placeholder="e.g. ahmed.k@esspl.com" required />
                </div>
                <div class="field-group">
                    <label class="field-label">Initial Password <span class="field-required">*</span></label>
                    <input type="text" name="password" class="field-input" placeholder="e.g. Emp@12345" required />
                </div>
                <div class="field-group">
                    <label class="field-label">Portal Access</label>
                    <select name="portal_access" class="field-select">
                        <option value="enabled">Enabled</option>
                        <option value="disabled">Disabled</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Access Role</label>
                    <select name="access_role" class="field-select">
                        <option value="employee">Employee</option>
                        <option value="hr_admin">HR Admin</option>
                        <option value="manager">Manager</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Welcome Email</label>
                    <select name="send_welcome_email" class="field-select">
                        <option value="no">No email now</option>
                        <option value="yes">Record request only</option>
                    </select>
                    <small style="display:block;margin-top:6px;color:var(--muted);font-size:11px;">SMTP/email service is not connected yet, so this only stores the request in the database.</small>
                </div>
            </div>
        </div>

        <!-- STEP 7: Review & Complete -->
        <div class="form-step" id="step-7" style="display:none;">
            <div class="form-section-title">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                Review & Complete
            </div>
            <div class="review-panel">
                <div class="review-card">
                    <span>Employee</span>
                    <strong id="reviewName">Not entered</strong>
                </div>
                <div class="review-card">
                    <span>Job</span>
                    <strong id="reviewJob">Not selected</strong>
                </div>
                <div class="review-card">
                    <span>Email</span>
                    <strong id="reviewEmail">Not entered</strong>
                </div>
                <div class="review-card">
                    <span>Payroll</span>
                    <strong id="reviewSalary">Optional</strong>
                </div>
            </div>
            <div class="onboarding-note">
                Please review the information before completing onboarding. The employee account, HR profile, job setup and payroll details will be created together.
            </div>
        </div>
    </div>

    <!-- ACTION BAR -->
    <div style="display:flex;justify-content:space-between;gap:10px;margin-top:20px;" class="anim-fade-in-up">
        <div>
            <button type="button" class="btn btn-ghost" id="btnPrev" style="display:none;" onclick="prevStep()">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
                Previous
            </button>
        </div>
        <div style="display:flex; gap:10px;">
            <a class="btn btn-ghost" asp-action="Index">Cancel</a>
            <button type="button" class="btn btn-primary" id="btnNext" onclick="nextStep()">
                Next Step
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <button type="submit" class="btn btn-success" id="btnRegister" style="display:none;">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                Complete Onboarding
            </button>
        </div>
    </div>
</form>

@section Styles {
<style>
    :root { --surface1: var(--white); }

    .onboarding-steps {
        display: flex;
        justify-content: space-between;
        gap: 8px;
        margin-bottom: 30px;
        position: relative;
        overflow-x: auto;
        padding: 0 8px 6px;
    }

    .onboarding-steps .step-item {
        min-width: 92px;
    }

    .review-panel {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }

    .review-card {
        border: 1px solid var(--border);
        border-radius: 12px;
        background: #f8fafc;
        padding: 16px;
    }

    .review-card span {
        display: block;
        color: var(--muted);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .05em;
        text-transform: uppercase;
        margin-bottom: 7px;
    }

    .review-card strong {
        color: var(--text);
        font-size: 14px;
        word-break: break-word;
    }

    .onboarding-note {
        margin-top: 16px;
        border: 1px solid var(--accent-light);
        border-radius: 12px;
        background: #eff6ff;
        color: var(--text2);
        padding: 14px 16px;
        font-size: 13px;
        line-height: 1.5;
    }

    @@media (max-width: 900px) {
        .review-panel { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    }

    @@media (max-width: 640px) {
        .review-panel { grid-template-columns: 1fr; }
    }
</style>
}

@section Scripts {
<script src="~/js/modals.js" asp-append-version="true"></script>
<script>
    let currentStep = 1;
    const totalSteps = 7;

    function updateSteps() {
        // Update display
        document.querySelectorAll('.form-step').forEach(s => s.style.display = 'none');
        document.getElementById(`step-${currentStep}`).style.display = 'block';
        if (currentStep === totalSteps) {
            renderReview();
        }

        // Update progress bar
        const progress = ((currentStep - 1) / (totalSteps - 1)) * 100;
        document.getElementById('stepProgress').style.width = progress + '%';

        // Update indicators
        document.querySelectorAll('.step-item').forEach((item, idx) => {
            const stepNum = idx + 1;
            const dot = item.querySelector('.step-dot');
            const label = item.querySelector('div:last-child');
            
            if (stepNum < currentStep) {
                item.classList.add('completed');
                dot.style.borderColor = 'var(--accent2)';
                dot.style.color = 'var(--accent2)';
                dot.innerHTML = '<svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>';
            } else if (stepNum === currentStep) {
                item.classList.add('active');
                dot.style.borderColor = 'var(--accent)';
                dot.style.color = 'var(--accent)';
                dot.textContent = stepNum;
                label.style.color = 'var(--accent)';
            } else {
                item.classList.remove('active', 'completed');
                dot.style.borderColor = 'var(--surface3)';
                dot.style.color = 'var(--muted)';
                dot.textContent = stepNum;
                label.style.color = 'var(--muted)';
            }
        });

        // Update buttons
        document.getElementById('btnPrev').style.display = currentStep === 1 ? 'none' : 'flex';
        document.getElementById('btnNext').style.display = currentStep === totalSteps ? 'none' : 'flex';
        document.getElementById('btnRegister').style.display = currentStep === totalSteps ? 'flex' : 'none';
    }

    function markInvalid(field, message) {
        field.style.borderColor = 'var(--accent4)';
        field.setAttribute('title', message || 'This field is required.');
    }

    function clearInvalid(field) {
        field.style.borderColor = '';
        field.removeAttribute('title');
    }

    function validateCurrentStep() {
        const currentStepDiv = document.getElementById(`step-${currentStep}`);
        const fields = currentStepDiv.querySelectorAll('input, select, textarea');
        let allValid = true;

        fields.forEach(field => {
            const value = (field.value || '').trim();
            clearInvalid(field);

            if (field.hasAttribute('required') && !value) {
                markInvalid(field, 'This field is required.');
                allValid = false;
                return;
            }
            if (!value) return;

            if (field.name === 'cnic' && !/^[0-9]{13}$/.test(value)) {
                markInvalid(field, field.dataset.message);
                allValid = false;
            }
            if (field.name === 'phone' && !/^[0-9]{11}$/.test(value)) {
                markInvalid(field, field.dataset.message);
                allValid = false;
            }
            if (field.name === 'bank_account_no' && !/^[A-Z0-9]{16,34}$/.test(value)) {
                markInvalid(field, field.dataset.message);
                allValid = false;
            }
            if (field.type === 'email' && !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(value)) {
                markInvalid(field, 'Please enter a valid email address.');
                allValid = false;
            }
        });

        if (!allValid) {
            const firstInvalid = currentStepDiv.querySelector('[style*="border-color"]');
            firstInvalid?.focus();
            showToast('Please complete the highlighted fields before moving ahead.', 'error');
        }

        return allValid;
    }

    function nextStep() {
        if (!validateCurrentStep()) {
            return;
        }

        if (currentStep < totalSteps) {
            currentStep++;
            updateSteps();
        }
    }

    function prevStep() {
        if (currentStep > 1) {
            currentStep--;
            updateSteps();
        }
    }

    function getSelectText(name) {
        const el = document.querySelector(`[name="${name}"]`);
        return el?.selectedOptions?.[0]?.textContent?.trim() || '';
    }

    function renderReview() {
        const form = document.getElementById('onboardingForm');
        const formData = new FormData(form);
        const firstName = formData.get('first_name') || '';
        const lastName = formData.get('last_name') || '';
        const email = formData.get('email') || '';
        const salary = formData.get('basic_salary') || '';
        const designation = getSelectText('designation_id');
        const department = getSelectText('department_id');

        document.getElementById('reviewName').textContent = `${firstName} ${lastName}`.trim() || 'Not entered';
        document.getElementById('reviewJob').textContent = [designation, department].filter(Boolean).join(' - ') || 'Not selected';
        document.getElementById('reviewEmail').textContent = email || 'Not entered';
        document.getElementById('reviewSalary').textContent = salary ? `PKR ${Number(salary).toLocaleString()}` : 'Optional';
    }

    (async function initOnboarding() {
        updateSteps();
        // Load all config dropdowns
        const load = async (entity, elId, valueKey, labelKey) => {
            const el = document.getElementById(elId);
            const res = await EmsApi.config.get(entity);
            if (res.success && Array.isArray(res.data)) {
                el.innerHTML = '<option value="">Select ' + entity.charAt(0).toUpperCase() + entity.slice(1).replace("-"," ") + '</option>';
                res.data.forEach(item => {
                    const opt = document.createElement('option');
                    opt.value = item[valueKey] || item.id;
                    opt.textContent = item[labelKey] || item.name;
                    el.appendChild(opt);
                });
            } else {
                el.innerHTML = '<option value="">Error loading</option>';
            }
        };

        await Promise.allSettled([
            load('departments', 'department_id', 'id', 'department_name'),
            load('designations', 'designation_id', 'id', 'title'),
            load('work-locations', 'location_id', 'id', 'location_name'),
            load('employment-types', 'employee_type_id', 'id', 'type_name'),
            load('work-modes', 'work_mode_id', 'id', 'mode_name'),
            load('shifts', 'shift_id', 'id', 'shift_name'),
            load('job-statuses', 'job_status_id', 'id', 'status_name')
        ]);

        // Load Managers (Employees with special roles or just list of employees)
        const mgrRes = await EmsApi.employees.list();
        const mgrEl = document.getElementById('manager_id');
        const managerRows = mgrRes.success
            ? (Array.isArray(mgrRes.data) ? mgrRes.data : (mgrRes.data?.data || []))
            : [];
        if (managerRows.length) {
            managerRows.forEach(emp => {
                const opt = document.createElement('option');
                opt.value = emp.employee_id;
                opt.textContent = emp.name + ' (' + (emp.designation_title || emp.designation_name || '') + ')';
                mgrEl.appendChild(opt);
            });
        }
    })();

    async function handleOnboarding(e) {
        e.preventDefault();
        const btn = document.getElementById('btnRegister');
        const form = document.getElementById('onboardingForm');
        const formData = new FormData(form);
        const data = {};
        formData.forEach((value, key) => {
            if (value) data[key] = value;
        });

        const fileName = (fieldName) => {
            const input = form.querySelector(`[name="${fieldName}"]`);
            return input?.files?.[0]?.name || null;
        };

        const payload = {
            personalInfo: {
                name: `${data.first_name} ${data.last_name}`,
                father_name: data.father_name,
                cnic: data.cnic,
                date_of_birth: data.dob,
                marital_status: data.marital_status
            },
            jobInfo: {
                department_id: data.department_id,
                designation_id: data.designation_id,
                employment_type_id: data.employee_type_id,
                job_status_id: data.job_status_id,
                work_mode_id: data.work_mode_id,
                work_location_id: data.location_id,
                shift_id: data.shift_id,
                manager_emp_id: data.manager_id || null,
                date_of_joining: data.joining_date
            },
            salaryInfo: {
                base_salary: data.basic_salary ? Number(data.basic_salary) : 0,
                payroll_cycle: data.payroll_cycle || null,
                tax_status: data.tax_status || null,
                allowance_notes: data.allowance_notes || null,
                probation_salary: data.probation_salary ? Number(data.probation_salary) : null,
                salary_effective_from: data.salary_effective_from || null
            },
            accountInfo: {
                email: data.email,
                password: data.password,
                phone: data.phone,
                role_id: null // Assigned by backend
            },
            emergencyContacts: {
                contact_1: data.phone,
                contact_2: null,
                perment_address: data.address || '',
                postal_address: data.address || '',
                e_contact_1_relation: 'other',
                e_contact_1_full_name: 'Emergency Contact',
                e_contact_1_phone: data.phone,
                e_contact_1_phone_country_code: '+92',
                e_contact_1_email: data.email || null,
                e_contact_2_relation: null,
                e_contact_2_full_name: null,
                e_contact_2_phone: null,
                e_contact_2_phone_country_code: null,
                e_contact_2_email: null,
                primary_contact: 1
            },
            documentInfo: {
                cnic_document: fileName('cnic_document'),
                resume_document: fileName('resume_document'),
                offer_letter_document: fileName('offer_letter_document')
            },
            accessInfo: {
                portal_access: data.portal_access || 'enabled',
                access_role: data.access_role || 'employee',
                send_welcome_email: data.send_welcome_email || 'no'
            }
        };

        if (data.bank_name && data.bank_account_title && data.bank_account_no) {
            payload.bankInfo = {
                bank_name: data.bank_name,
                account_title: data.bank_account_title,
                account_number: data.bank_account_no,
                iban: data.bank_account_no
            };
        }

        if (data.blood_group || data.gender) {
            payload.medicalInfo = {
                blood_group: data.blood_group || null,
                gender: data.gender || null,
                date_of_birth: data.dob || null
            };
        }

        btn.disabled = true;
        btn.textContent = 'Registering...';

        const res = await EmsApi.employees.create(payload);
        if (res.success) {
            const createdId = res.data?.employee?.employee_id || res.data?.employee_id || '';
            showToast('Employee registered successfully!', 'success');
            setTimeout(() => window.location.href = createdId ? `/Employees?created=${encodeURIComponent(createdId)}` : '/Employees', 1200);
        } else {
            btn.disabled = false;
            btn.innerHTML = '<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Register Employee';
            showToast(res.error || 'Failed to register employee', 'error');
            if (res.issues) {
                console.error('Validation issues:', res.issues);
            }
        }
        return false;
    }
</script>
}
