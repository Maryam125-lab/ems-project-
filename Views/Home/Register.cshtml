@{
    ViewData["Title"] = "Register Account";
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
}

<div class="login-page" id="registerPage">
    <!-- Animated Background -->
    <div class="login-bg">
        <div class="login-orb login-orb-1"></div>
        <div class="login-orb login-orb-2"></div>
        <div class="login-orb login-orb-3"></div>
    </div>
    <div class="login-grid-overlay"></div>

    <!-- Register Card -->
    <div class="login-card" style="max-width:480px;">
        <!-- Brand -->
        <div class="login-brand">
            <div class="login-logo">
                <svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                </svg>
            </div>
            <h1 class="login-title">TRACK360 ERP</h1>
            <p class="login-subtitle">Create your employee account</p>
        </div>

        <!-- Error / Success -->
        <div class="login-error" id="regError">
            <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" />
            </svg>
            <span id="regErrorText">Error</span>
        </div>
        <div id="regSuccess" style="display:none;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);border-radius:10px;padding:12px 16px;margin-bottom:12px;color:#10b981;font-size:13px;text-align:center;">
            ✅ Account created! <a href="/" style="color:#10b981;text-decoration:underline;">Sign in now →</a>
        </div>

        <!-- Form -->
        <form class="login-form" id="regForm" onsubmit="return handleRegister(event)">
            <div class="form-group">
                <label class="form-label" for="empId">Employee ID <span style="color:#ef4444">*</span></label>
                <div class="form-input-wrapper">
                    <input type="text" class="form-input" id="empId" name="employee_id"
                           placeholder="e.g. EMP004" autocomplete="off" required
                           style="text-transform:uppercase;" />
                </div>
                <div style="font-size:11px;color:var(--muted,#64748b);margin-top:4px;">Your Employee ID provided by HR (e.g. EMP004, EMP100)</div>
            </div>

            <div class="form-group">
                <label class="form-label" for="regEmail">Email Address <span style="color:#ef4444">*</span></label>
                <div class="form-input-wrapper">
                    <input type="email" class="form-input" id="regEmail" name="email"
                           placeholder="Enter your email" autocomplete="email" required />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="regPassword">Password <span style="color:#ef4444">*</span></label>
                <div class="form-input-wrapper">
                    <input type="password" class="form-input" id="regPassword" name="password"
                           placeholder="Min. 8 characters" autocomplete="new-password" required
                           style="padding-right: 44px;" />
                    <button type="button" class="password-toggle" onclick="toggleRegPassword()">
                        <svg id="regEyeIcon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="regConfirm">Confirm Password <span style="color:#ef4444">*</span></label>
                <div class="form-input-wrapper">
                    <input type="password" class="form-input" id="regConfirm"
                           placeholder="Re-enter password" autocomplete="new-password" required
                           style="padding-right: 44px;" />
                </div>
            </div>

            <button type="submit" class="login-btn" id="regBtn">
                <span class="btn-text">Create Account</span>
                <svg class="btn-spinner" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
                </svg>
            </button>
        </form>

        <div style="text-align:center;margin-top:16px;font-size:13px;color:var(--muted,#64748b);">
            Already have an account? <a href="/" style="color:#3b82f6;text-decoration:none;font-weight:500;">Sign in →</a>
        </div>
    </div>

    <!-- Footer -->
    <div class="login-footer">
        TRACK360 ERP &copy; @DateTime.Now.Year &middot; ESSPL Solutions
    </div>
</div>

@section Scripts {
<script>
    function toggleRegPassword() {
        const input = document.getElementById('regPassword');
        const icon = document.getElementById('regEyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.innerHTML = '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>';
        } else {
            input.type = 'password';
            icon.innerHTML = '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
        }
    }

    async function handleRegister(e) {
        e.preventDefault();
        const errorEl = document.getElementById('regError');
        const successEl = document.getElementById('regSuccess');
        const btn = document.getElementById('regBtn');

        errorEl.classList.remove('show');
        successEl.style.display = 'none';

        const empId = document.getElementById('empId').value.trim().toUpperCase();
        const email = document.getElementById('regEmail').value.trim();
        const password = document.getElementById('regPassword').value;
        const confirm = document.getElementById('regConfirm').value;

        // Validations
        if (!empId || !email || !password) {
            errorEl.classList.add('show');
            document.getElementById('regErrorText').textContent = 'Please fill in all fields.';
            return false;
        }
        if (password.length < 8) {
            errorEl.classList.add('show');
            document.getElementById('regErrorText').textContent = 'Password must be at least 8 characters.';
            return false;
        }
        if (password !== confirm) {
            errorEl.classList.add('show');
            document.getElementById('regErrorText').textContent = 'Passwords do not match.';
            return false;
        }

        btn.classList.add('loading');

        try {
            const res = await fetch(EmsApi.API_BASE + '/api/auth/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ employee_id: empId, email, password })
            });
            const data = await res.json();

            if (res.ok && data.success) {
                btn.classList.remove('loading');
                document.getElementById('regForm').style.display = 'none';
                successEl.style.display = 'block';
            } else {
                btn.classList.remove('loading');
                errorEl.classList.add('show');
                let msg = data.error?.message || data.error || 'Registration failed. Please try again.';
                if (typeof msg === 'object') msg = JSON.stringify(msg);
                document.getElementById('regErrorText').textContent = msg;
            }
        } catch (err) {
            btn.classList.remove('loading');
            errorEl.classList.add('show');
            document.getElementById('regErrorText').textContent = 'Connection error. Please check the server.';
        }
        return false;
    }
</script>
}
