        document.getElementById('workflowFields').innerHTML = renderWorkflowFields(type, id);
        document.getElementById('workflowSaveBtn').textContent = type === 'grn' ? 'Receive Stock' : 'Save Workflow';
        document.getElementById('invWorkflowModal').classList.add('open');
        document.getElementById('invWorkflowModal').setAttribute('aria-hidden', 'false');
    }

    function closeWorkflowModal() {
        document.getElementById('invWorkflowModal').classList.remove('open');
        document.getElementById('invWorkflowModal').setAttribute('aria-hidden', 'true');
        document.getElementById('workflowForm').reset();
        document.getElementById('workflowFields').innerHTML = '';
    }

    async function saveWorkflowRecord(event) {
        event.preventDefault();
        const form = event.currentTarget;
        const type = document.getElementById('workflowType').value;
        const id = document.getElementById('workflowRecordId').value;
        const data = Object.fromEntries(new FormData(form).entries());
        const btn = document.getElementById('workflowSaveBtn');
        btn.disabled = true;
        btn.textContent = 'Working...';

        let res;
        if (type === 'purchaseRequest') {
            res = await EmsApi.inventory.createPurchaseRequest({
                department_id: data.department_id,
                remarks: data.remarks,
                items: collectWorkflowItems(false)
            });
        } else if (type === 'purchaseOrder') {
            const purchaseRequestId = id || data.purchase_request_id;
            const row = findWorkflowRow(invState.purchaseRows, purchaseRequestId);
            const unitPrices = {};
            parseWorkflowItems(row?.items).forEach(item => { unitPrices[item.product_id] = Number(data.default_unit_price || 0); });
            res = await EmsApi.inventory.createPurchaseOrder({
                purchase_request_id: purchaseRequestId,
                vendor_id: data.vendor_id,
                unit_prices: unitPrices,
                remarks: data.remarks
            });
        } else if (type === 'grn') {
            res = await EmsApi.inventory.createGrn({
                purchase_order_id: id || data.purchase_order_id,
                serial_prefix: data.serial_prefix,
                remarks: data.remarks
            });
        } else if (type === 'quotation') {
            res = await EmsApi.inventory.createQuotation({
                customer_id: data.customer_id,
                remarks: data.remarks,
                items: collectWorkflowItems(true)
            });
        } else if (type === 'installation') {
            res = await EmsApi.inventory.createInstallation({
                customer_id: data.customer_id,
                vehicle_no: data.vehicle_no,
                vehicle_model: data.vehicle_model,
                contact_person: data.contact_person,
                contact_phone: data.contact_phone,
                installation_type: data.installation_type,
                po_reference: data.po_reference,
                remarks: data.remarks
            });
        } else if (type === 'assignTracker') {
            res = await EmsApi.inventory.assignInstallationTracker(id, {
                tracker_item_id: data.tracker_item_id,
                mapping_notes: data.mapping_notes,
                remarks: data.remarks
            });
        } else if (type === 'completeInstallation') {
            res = await EmsApi.inventory.completeInstallation(id, {
                welcome_call_notes: data.welcome_call_notes,
                billing_notes: data.billing_notes,
                remarks: data.remarks
            });
        } else if (type === 'complaint') {
            res = await EmsApi.inventory.createComplaint({
                customer_id: data.customer_id,
                vehicle_no: data.vehicle_no,
                issue_type: data.issue_type,
                priority: data.priority,
                remarks: data.remarks
            });
        } else if (type === 'replacement') {
            res = await EmsApi.inventory.createReplacement({
                complaint_id: data.complaint_id,
                customer_id: data.customer_id,
                vehicle_no: data.vehicle_no,
                old_inventory_item_id: data.old_inventory_item_id,
                new_inventory_item_id: data.new_inventory_item_id,
                status: 'REPLACED',
                remarks: data.remarks
            });
        }

        btn.disabled = false;
        btn.textContent = type === 'grn' ? 'Receive Stock' : 'Save Workflow';
        if (!res?.success) {
            alert(res?.error || 'Workflow action failed.');
            return false;
        }

        closeWorkflowModal();
        await loadInventoryControl();
        return false;
    }

    async function quickWorkflow(type, id) {
        const labels = {
            approvePurchaseRequest: 'approve this purchase request',
            rejectPurchaseRequest: 'reject this purchase request',
            approveQuotation: 'approve this quotation',
            rejectQuotation: 'reject this quotation',
            createDeliveryOrder: 'create delivery order',
            approveDeliveryOrder: 'approve delivery order and allocate stock',
            rejectDeliveryOrder: 'reject delivery order',
            createInvoice: 'create invoice',
            approveInvoice: 'approve invoice',
            rejectInvoice: 'reject invoice',
            markInvoicePaid: 'mark invoice as paid',
            cancelInstallation: 'cancel this installation',
            resolveComplaint: 'resolve this complaint'
        };
        if (!confirm(`Do you want to ${labels[type] || 'run this action'}?`)) return;
        const remarks = ['rejectPurchaseRequest','rejectQuotation','rejectDeliveryOrder','rejectInvoice'].includes(type)
            ? prompt('Reason / remarks?', 'Rejected after review') || 'Rejected'
            : 'Action completed from inventory workspace.';
        const map = {
            approvePurchaseRequest: () => EmsApi.inventory.approvePurchaseRequest(id, { remarks }),
            rejectPurchaseRequest: () => EmsApi.inventory.rejectPurchaseRequest(id, { remarks }),
            approveQuotation: () => EmsApi.inventory.approveQuotation(id, { remarks }),
            rejectQuotation: () => EmsApi.inventory.rejectQuotation(id, { remarks }),
            createDeliveryOrder: () => EmsApi.inventory.createDeliveryOrder({ quotation_id: id, remarks }),
            approveDeliveryOrder: () => EmsApi.inventory.approveDeliveryOrder(id, { remarks }),
            rejectDeliveryOrder: () => EmsApi.inventory.rejectDeliveryOrder(id, { remarks }),
            createInvoice: () => EmsApi.inventory.createInvoice({ quotation_id: id, remarks }),
            approveInvoice: () => EmsApi.inventory.approveInvoice(id, { remarks }),
            rejectInvoice: () => EmsApi.inventory.rejectInvoice(id, { remarks }),
            markInvoicePaid: () => EmsApi.inventory.markInvoicePaid(id, { remarks: 'Payment received.' }),
            cancelInstallation: () => EmsApi.inventory.cancelInstallation(id, { remarks }),
            resolveComplaint: () => EmsApi.inventory.resolveComplaint(id, { resolution_notes: remarks })
        };
        const res = await map[type]();
        if (!res.success) {
            alert(res.error || 'Workflow action failed.');
            return;
        }
        await loadInventoryControl();
    }

    function formToObject(form) {
        const data = {};
        new FormData(form).forEach((value, key) => {
            if (!['master_type', 'record_id'].includes(key)) data[key] = value;
        });
        return data;
    }

    async function saveMasterRecord(event) {
        event.preventDefault();
        const form = event.currentTarget;
        const type = document.getElementById('masterType').value;
        const id = document.getElementById('masterRecordId').value;
        const data = formToObject(form);
        const btn = document.getElementById('masterSaveBtn');
        btn.disabled = true;
        btn.textContent = 'Saving...';

        const createMap = {
            category: EmsApi.inventory.createCategory,
            product: EmsApi.inventory.createProduct,
            serial: EmsApi.inventory.createSerial,
            customer: EmsApi.inventory.createCustomer,
            vendor: EmsApi.inventory.createVendor
        };
        const updateMap = {
            category: EmsApi.inventory.updateCategory,
            product: EmsApi.inventory.updateProduct,
            serial: EmsApi.inventory.updateSerial,
            customer: EmsApi.inventory.updateCustomer,
            vendor: EmsApi.inventory.updateVendor
        };

        const res = id ? await updateMap[type](id, data) : await createMap[type](data);
        btn.disabled = false;
        btn.textContent = 'Save';

        if (!res.success) {
            alert(res.error || 'Could not save record.');
            return false;
        }

        closeMasterModal();
        await loadInventoryControl();
        return false;
    }

    async function deleteMasterRecord(type, id) {
        const labels = { category: 'category', product: 'product', serial: 'serial item', customer: 'customer', vendor: 'vendor' };
        if (!confirm(`Delete this ${labels[type]}? Linked records are protected automatically.`)) return;

        const deleteMap = {
            category: EmsApi.inventory.deleteCategory,
            product: EmsApi.inventory.deleteProduct,
            serial: EmsApi.inventory.deleteSerial,
            customer: EmsApi.inventory.deleteCustomer,
            vendor: EmsApi.inventory.deleteVendor
        };

        const res = await deleteMap[type](id);
        if (!res.success) {
            alert(res.error || 'Could not delete record. It may be linked with purchase/sales history.');
            return;
        }
        await loadInventoryControl();
    }

    async function loadInventoryControl() {
        const [
            statusRes,
            categoriesRes,
            productsRes,
            serialsRes,
            purchaseRes,
            purchaseOrdersRes,
            salesRes,
            invoiceLedgerRes,
            installationsRes,
            supportRes,
            customersRes,
            vendorsRes,
            departmentsRes
        ] = await Promise.allSettled([
            EmsApi.inventory.status(),
            EmsApi.inventory.categories(),
            EmsApi.inventory.products({ limit: 100 }),
            EmsApi.inventory.serials({ limit: 100 }),
            EmsApi.inventory.purchaseFlow(),
            EmsApi.inventory.purchaseOrders(),
            EmsApi.inventory.salesFlow(),
            EmsApi.inventory.invoiceLedger(),
            EmsApi.inventory.installationFlow(),
            EmsApi.inventory.supportFlow(),
            EmsApi.inventory.customers({ limit: 100 }),
            EmsApi.inventory.vendors({ limit: 100 }),
            EmsApi.config.get('departments')
        ]);

        const status = statusRes.value;
        if (status?.success) {
            renderSummary(status.data.summary || {});
        } else {
            document.getElementById('inventoryAuthStatus').textContent = 'Backend unavailable';
            document.getElementById('demoReadiness').textContent = 'Needs attention';
        }

        if (categoriesRes.value?.success) {
            renderCategories(categoriesRes.value.data || []);
        }
        invState.purchaseOrders = purchaseOrdersRes.value?.data || [];
        invState.departments = departmentsRes.value?.data || [];
        renderProducts(productsRes.value?.data || []);
        renderSerials(serialsRes.value?.data || []);
        renderPurchase(purchaseRes.value?.data || []);
        renderSales(salesRes.value?.data || []);
        renderInvoiceLedger(invoiceLedgerRes.value?.data || []);
        renderInstallations(installationsRes.value?.data || []);
        renderSupport(supportRes.value?.data || { complaints: [], replacements: [] });
        renderParties(customersRes.value?.data || [], vendorsRes.value?.data || []);
    }

    loadInventoryControl();
</script>
}
