@section Scripts {
<script>
    const money = new Intl.NumberFormat('en-PK', { style: 'currency', currency: 'PKR', maximumFractionDigits: 0 });
    const invState = {
        categories: [],
        products: [],
        serials: [],
        customers: [],
        vendors: [],
        departments: [],
        purchaseRows: [],
        purchaseOrders: [],
        salesRows: [],
        invoiceLedgerRows: [],
        installationRows: [],
        complaints: [],
        replacements: []
    };

    function showInvTab(tab) {
        document.querySelectorAll('.inv-tabs button').forEach(btn => btn.classList.toggle('active', btn.dataset.tab === tab));
        document.querySelectorAll('.inv-tab-panel').forEach(panel => panel.classList.toggle('active', panel.id === `inv-tab-${tab}`));
    }

    function safe(value, fallback = '-') {
        return value === null || value === undefined || value === '' ? fallback : value;
    }

    function statusClass(status) {
        const value = String(status || '').toUpperCase();
        if (['AVAILABLE', 'APPROVED', 'PAID', 'COMPLETED', 'RESOLVED', 'REPLACED', 'INSTALLED', 'HIGH'].includes(value)) return 'green';
        if (['PENDING', 'UNPAID', 'ALLOCATED', 'REQUESTED', 'TAKEN', 'MEDIUM', 'BILLING_READY', 'WELCOME_CALL'].includes(value)) return 'amber';
        if (['REJECTED', 'DAMAGED', 'CANCELLED', 'LOW'].includes(value)) return 'red';
        return 'gray';
    }

    function statusBadge(status) {
        return `<span class="inv-status ${statusClass(status)}">${safe(status)}</span>`;
    }

    function escapeAttr(value) {
        return String(value ?? '').replaceAll('&', '&amp;').replaceAll('"', '&quot;').replaceAll('<', '&lt;').replaceAll('>', '&gt;');
    }

    function jsArg(value) {
        return String(value ?? '').replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/\r?\n/g, ' ');
    }

    function formatDate(value) {
        if (!value) return '-';
        const parsed = new Date(value);
        return Number.isNaN(parsed.getTime()) ? safe(value) : parsed.toLocaleDateString();
    }

    function actions(type, id) {
        return `<div class="inv-table-actions">
            <button type="button" class="inv-mini-btn" onclick="openMasterModal('${type}', '${id}')">Edit</button>
            <button type="button" class="inv-mini-btn danger" onclick="deleteMasterRecord('${type}', '${id}')">Delete</button>
        </div>`;
    }

    function renderSummary(summary) {
        const products = summary.products || {};
        const stock = summary.stock || {};
        const purchase = summary.purchase || {};
        const sales = summary.sales || {};
        const installations = summary.installations || {};
        const support = summary.support || {};
        const parties = summary.parties || {};
        const trackedSerials = Number(stock.total_serials || 0);
        const availableSerials = Number(stock.available || 0);
        const damagedSerials = Number(stock.damaged || 0);
        const returnedSerials = Number(stock.returned || 0);
        const pendingQueue = Number(purchase.pending_pr || 0) + Number(sales.pending_invoices || 0) + Number(installations.requested || 0) + Number(support.open_complaints || 0);
        const exceptionQueue = damagedSerials + returnedSerials + Number(support.open_complaints || 0);
        const stockHealth = trackedSerials > 0 ? Math.round((availableSerials / trackedSerials) * 100) : 100;
        const riskPenalty = Math.min(45, pendingQueue * 3 + exceptionQueue * 4);
        const readinessScore = Math.max(55, Math.min(100, stockHealth - riskPenalty + 28));

        document.getElementById('inventoryAuthStatus').textContent = 'Backend connected';
        document.getElementById('demoReadiness').textContent = 'Final ERP ready';
        document.getElementById('demoReadinessSub').textContent = `${readinessScore}% operational health across stock, purchasing, invoicing and support.`;
        document.getElementById('demoReadinessMeter').style.width = `${readinessScore}%`;
        document.getElementById('kpiProducts').textContent = products.total_products || 0;
        document.getElementById('kpiProductsSub').textContent = `${products.assets || 0} assets, ${products.consumables || 0} consumables, ${products.services || 0} services`;
        document.getElementById('kpiCategoryFoot').textContent = `${(summary.categories || []).length} active categories`;
        document.getElementById('kpiAvailable').textContent = stock.available || 0;
        document.getElementById('kpiAvailableSub').textContent = `${stock.total_serials || 0} tracked serials`;
        document.getElementById('stockHealthMeter').style.width = `${stockHealth}%`;
        document.getElementById('kpiPending').textContent = pendingQueue;
        document.getElementById('kpiPendingFoot').textContent = pendingQueue > 0 ? 'Action required' : 'No pending queue';
        document.getElementById('kpiExceptions').textContent = exceptionQueue;
        document.getElementById('kpiExceptionFoot').textContent = exceptionQueue > 0 ? 'Review stock/support' : 'No active risk';

        document.getElementById('execHealthScore').textContent = `${readinessScore}%`;
        document.getElementById('execHealthSub').textContent = `${pendingQueue} pending actions and ${exceptionQueue} exceptions across workflows.`;
        document.getElementById('execInvoiceValue').textContent = money.format(Number(sales.invoice_value || 0));
        document.getElementById('execInvoiceSub').textContent = `${sales.invoices || 0} invoices, ${sales.pending_invoices || 0} pending approvals`;
        document.getElementById('execStockUtilization').textContent = `${stockHealth}%`;
        document.getElementById('execStockSub').textContent = `${availableSerials} available of ${trackedSerials} tracked serials`;
        document.getElementById('execAttention').textContent = pendingQueue + exceptionQueue;
        document.getElementById('execAttentionSub').textContent = `${pendingQueue} approvals/support, ${exceptionQueue} stock exceptions`;

        document.getElementById('dashPurchase').textContent = purchase.purchase_requests || 0;
        document.getElementById('dashPurchaseSub').textContent = `${purchase.pending_pr || 0} pending, ${purchase.purchase_orders || 0} POs, ${purchase.grns || 0} GRNs`;
        document.getElementById('dashSales').textContent = sales.quotations || 0;
        document.getElementById('dashSalesSub').textContent = `${sales.delivery_orders || 0} deliveries, ${sales.invoices || 0} invoices, ${money.format(Number(sales.invoice_value || 0))}`;
        document.getElementById('dashInstallations').textContent = installations.installation_requests || 0;
        document.getElementById('dashInstallationsSub').textContent = `${installations.requested || 0} requested, ${installations.installed || 0} installed, ${installations.completed || 0} completed`;
        document.getElementById('dashSupport').textContent = support.complaints || 0;
        document.getElementById('dashSupportSub').textContent = `${support.open_complaints || 0} open, ${support.resolved_complaints || 0} resolved, ${support.replacements || 0} replacements`;

        const coverage = [
            ['Masters', Number(products.total_products || 0) > 0 && Number(parties.customers || 0) > 0 && Number(parties.vendors || 0) > 0],
            ['Stock', Number(stock.total_serials || 0) >= 0],
            ['Purchasing', true],
            ['Sales', true],
            ['Installations', true],
            ['Support', true]
        ];
        const readyCount = coverage.filter(item => item[1]).length;
        document.getElementById('workflowReadinessScore').textContent = `${Math.round((readyCount / coverage.length) * 100)}%`;
        document.getElementById('workflowReadinessGrid').innerHTML = coverage.map(item => `<div class="inv-readiness-item">
            <strong>${item[0]}</strong>
            <span>${item[1] ? 'Connected' : 'Needs data'}</span>
        </div>`).join('');

        renderCategories(summary.categories || []);
        renderMovements(summary.recent_movements || []);
    }

    function renderCategories(categories) {
        invState.categories = categories;
        const el = document.getElementById('categoryBars');
        const table = document.getElementById('categoriesBody');
        if (!categories.length) {
            el.innerHTML = '<div class="inv-empty">No categories found.</div>';
            if (table) table.innerHTML = '<tr><td colspan="4">No categories found.</td></tr>';
            return;
        }
        const max = Math.max(...categories.map(c => Number(c.products || 0)), 1);
        el.innerHTML = categories.map(c => {
            const pct = Math.round((Number(c.products || 0) / max) * 100);
            return `<div class="inv-bar-row">
                <div>${safe(c.category_name)}</div>
                <div class="inv-bar-track"><div class="inv-bar-fill" style="width:${pct}%"></div></div>
                <div class="inv-bar-count">${c.products || 0}</div>
            </div>`;
        }).join('');
        if (table) {
            table.innerHTML = categories.map(c => `<tr>
                <td><strong>${safe(c.category_name)}</strong></td>
                <td>${safe(c.description)}</td>
                <td>${c.products ?? c.product_count ?? 0}</td>
                <td>${actions('category', c.id)}</td>
            </tr>`).join('');
        }
    }

    function renderMovements(rows) {
        const el = document.getElementById('recentMovements');
        if (!rows.length) {
            el.innerHTML = '<div class="inv-empty">No recent inventory movements.</div>';
            return;
        }
        el.innerHTML = rows.map(row => `<div class="inv-activity-item">
            <span class="inv-dot"></span>
            <div>
                <strong>${safe(row.movement_type)} - ${safe(row.product_name, 'Item')}</strong>
                <span>${safe(row.serial_number)} / ${safe(row.reference_type)} / ${new Date(row.created_at).toLocaleDateString()}</span>
            </div>
        </div>`).join('');
    }

    function renderProducts(rows) {
        invState.products = rows;
        const el = document.getElementById('productsBody');
        if (!rows.length) {
            el.innerHTML = '<tr><td colspan="6">No products found.</td></tr>';
            return;
        }
        el.innerHTML = rows.map(row => `<tr>
            <td><strong>${safe(row.product_name)}</strong></td>
            <td>${safe(row.category_name)}</td>
            <td>${statusBadge(row.product_type)}</td>
            <td>${safe(row.tracking_type)}</td>
            <td>${row.available_count || row.quantity || 0}</td>
            <td>${actions('product', row.id)}</td>
        </tr>`).join('');
    }

    function renderSerials(rows) {
        invState.serials = rows;
        const el = document.getElementById('serialsBody');
        if (!rows.length) {
            el.innerHTML = '<tr><td colspan="5">No tracked serials found.</td></tr>';
            return;
        }
        el.innerHTML = rows.map(row => `<tr>
            <td><strong>${safe(row.serial_number)}</strong></td>
            <td>${safe(row.product_name)}</td>
            <td>${safe(row.category_name)}</td>
            <td>${statusBadge(row.current_status)}</td>
            <td>${actions('serial', row.id)}</td>
        </tr>`).join('');
    }

    function renderPurchase(rows) {
        invState.purchaseRows = rows;
        const el = document.getElementById('purchaseBody');
        if (!rows.length) {
            el.innerHTML = '<tr><td colspan="7">No purchase requests found.</td></tr>';
            return;
        }
        el.innerHTML = rows.map(row => `<tr>
            <td><strong>${safe(row.pr_id)}</strong></td>
            <td>${safe(row.department_name)}</td>
            <td>${safe(row.requested_by_name)}</td>
            <td>${row.item_count || 0}<br><small>${row.requested_qty || 0} qty</small></td>
            <td>${safe(row.po_id)}<br><small>${safe(row.grn_id, row.purchase_order_db_id ? 'GRN pending' : 'PO pending')}</small></td>
            <td>${statusBadge(row.status)}</td>
            <td>${purchaseActions(row)}</td>
        </tr>`).join('');
    }

    function renderSales(rows) {
        invState.salesRows = rows;
        const el = document.getElementById('salesBody');
        if (!rows.length) {
            el.innerHTML = '<tr><td colspan="7">No sales records found.</td></tr>';
            return;
        }
        el.innerHTML = rows.map(row => `<tr>
            <td><strong>${safe(row.quotation_id)}</strong><br>${statusBadge(row.quotation_status)}</td>
            <td>${safe(row.customer_name)}<br><small>${safe(row.company_name, '')}</small></td>
            <td>${safe(row.do_id)}<br>${statusBadge(row.delivery_status)}</td>
            <td>${row.invoice_id
                ? `<button type="button" class="inv-link-btn" onclick="openInvoiceModal('${jsArg(row.invoice_db_id || row.invoice_id)}','OUTBOUND')">${safe(row.invoice_id)}</button>`
                : safe(row.invoice_id)}<br>${statusBadge(row.approval_status)}</td>
            <td>${statusBadge(row.payment_status)}</td>
            <td class="inv-money">${money.format(Number(row.invoice_amount || row.quotation_amount || 0))}</td>
            <td>${salesActions(row)}</td>
        </tr>`).join('');
    }

    function purchaseActions(row) {
        const status = String(row.status || '').toUpperCase();
        const buttons = [];
        if (status === 'PENDING') {
            buttons.push(`<button type="button" class="inv-mini-btn success" onclick="quickWorkflow('approvePurchaseRequest','${row.id}')">Approve</button>`);
            buttons.push(`<button type="button" class="inv-mini-btn danger" onclick="quickWorkflow('rejectPurchaseRequest','${row.id}')">Reject</button>`);
        }
        if (status === 'APPROVED' && !row.purchase_order_db_id) {
            buttons.push(`<button type="button" class="inv-mini-btn" onclick="openWorkflowModal('purchaseOrder','${row.id}')">Create PO</button>`);
        }
        if (row.purchase_order_db_id && !row.grn_db_id) {
            buttons.push(`<button type="button" class="inv-mini-btn success" onclick="openWorkflowModal('grn','${row.purchase_order_db_id}')">Receive GRN</button>`);
        }
        return buttons.length ? `<div class="inv-table-actions">${buttons.join('')}</div>` : '<span class="inv-status gray">Complete</span>';
    }

    function salesActions(row) {
        const quote = String(row.quotation_status || '').toUpperCase();
        const delivery = String(row.delivery_status || '').toUpperCase();
        const invoice = String(row.approval_status || '').toUpperCase();
        const payment = String(row.payment_status || '').toUpperCase();
        const buttons = [];
        if (quote === 'DRAFT' || quote === 'PENDING') {
            buttons.push(`<button type="button" class="inv-mini-btn success" onclick="quickWorkflow('approveQuotation','${row.id}')">Approve</button>`);
            buttons.push(`<button type="button" class="inv-mini-btn danger" onclick="quickWorkflow('rejectQuotation','${row.id}')">Reject</button>`);
        }
        if (quote === 'APPROVED' && !row.delivery_db_id) {
            buttons.push(`<button type="button" class="inv-mini-btn" onclick="quickWorkflow('createDeliveryOrder','${row.id}')">Create DO</button>`);
        }
        if (row.delivery_db_id && delivery === 'PENDING') {
            buttons.push(`<button type="button" class="inv-mini-btn success" onclick="quickWorkflow('approveDeliveryOrder','${row.delivery_db_id}')">Approve DO</button>`);
            buttons.push(`<button type="button" class="inv-mini-btn danger" onclick="quickWorkflow('rejectDeliveryOrder','${row.delivery_db_id}')">Reject DO</button>`);
        }
        if (quote === 'APPROVED' && !row.invoice_db_id) {
            buttons.push(`<button type="button" class="inv-mini-btn" onclick="quickWorkflow('createInvoice','${row.id}')">Create Inv</button>`);
        }
        if (row.invoice_db_id && invoice === 'PENDING') {
            buttons.push(`<button type="button" class="inv-mini-btn success" onclick="quickWorkflow('approveInvoice','${row.invoice_db_id}')">Approve Inv</button>`);
            buttons.push(`<button type="button" class="inv-mini-btn danger" onclick="quickWorkflow('rejectInvoice','${row.invoice_db_id}')">Reject Inv</button>`);
        }
        if (row.invoice_db_id && invoice === 'APPROVED' && payment === 'UNPAID') {
            buttons.push(`<button type="button" class="inv-mini-btn success" onclick="quickWorkflow('markInvoicePaid','${row.invoice_db_id}')">Mark Paid</button>`);
        }
        return buttons.length ? `<div class="inv-table-actions">${buttons.join('')}</div>` : '<span class="inv-status gray">No action</span>';
    }

    function renderInvoiceLedger(rows) {
        invState.invoiceLedgerRows = rows;
        const el = document.getElementById('invoiceLedgerBody');
        if (!el) return;
        if (!rows.length) {
            el.innerHTML = '<tr><td colspan="7"><div class="inv-empty">No invoices found yet.</div></td></tr>';
            return;
        }
        el.innerHTML = rows.map(row => {
            const direction = String(row.invoice_direction || '').toUpperCase();
            const directionClass = direction === 'INBOUND' ? 'green' : 'blue';
            return `<tr>
                <td><span class="inv-status ${directionClass}">${safe(direction)}</span></td>
                <td><button type="button" class="inv-link-btn" onclick="openInvoiceModal('${jsArg(row.id)}','${jsArg(direction)}')">${safe(row.invoice_no)}</button><br><small>${safe(row.reference_no, '')}</small></td>
                <td>${safe(row.party_name)}</td>
                <td>${safe(row.invoice_type)}</td>
                <td>${statusBadge(row.workflow_status || row.approval_status)}</td>
                <td>${statusBadge(row.payment_status)}</td>
                <td class="inv-money">${money.format(Number(row.total_amount || 0))}</td>
            </tr>`;
        }).join('');
    }

    function findInvoiceRecord(id, direction) {
        const normalizedDirection = String(direction || '').toUpperCase();
        const ledgerRecord = invState.invoiceLedgerRows.find(row =>
            String(row.id) === String(id) &&
            String(row.invoice_direction || '').toUpperCase() === normalizedDirection);
        if (ledgerRecord) return ledgerRecord;

        const salesRecord = invState.salesRows.find(row =>
            String(row.invoice_db_id || '') === String(id) || String(row.invoice_id || '') === String(id));
        if (!salesRecord) return null;

        return {
            id: salesRecord.invoice_db_id,
            invoice_direction: 'OUTBOUND',
            invoice_no: salesRecord.invoice_id,
            reference_no: salesRecord.quotation_id,
            party_name: salesRecord.customer_name,
            invoice_type: 'Sales / Stock-Out',
            workflow_status: salesRecord.delivery_status,
            approval_status: salesRecord.approval_status,
            payment_status: salesRecord.payment_status,
            total_amount: salesRecord.invoice_amount || salesRecord.quotation_amount || 0,
            created_at: salesRecord.created_at,
            delivery_no: salesRecord.do_id,
            company_name: salesRecord.company_name
        };
    }

    function openInvoiceModal(id, direction) {
        const record = findInvoiceRecord(id, direction);
        if (!record) {
            alert('Invoice detail is not available yet. Create or approve the invoice first.');
            return;
        }

        const invoiceNo = safe(record.invoice_no, 'Draft invoice');
        document.getElementById('invoiceModalTitle').textContent = invoiceNo;
        document.getElementById('invoiceModalKicker').textContent = `${safe(record.invoice_direction, 'Invoice')} detail`;
        document.getElementById('invoiceDetailBody').innerHTML = `
            <div class="inv-invoice-sheet" id="printableInvoice">
                <div class="inv-invoice-top">
                    <div class="inv-invoice-brand">
                        <span>TRACK360 ERP</span>
                        <strong>${invoiceNo}</strong>
                        <small>${safe(record.invoice_type)}</small>
                    </div>
                    <div class="inv-invoice-total">
                        <span>Total Amount</span>
                        <strong>${money.format(Number(record.total_amount || 0))}</strong>
                        <small>${safe(record.payment_status)}</small>
                    </div>
                </div>
                <div class="inv-invoice-grid">
                    <div class="inv-invoice-field"><span>Party</span><strong>${safe(record.party_name)}</strong></div>
                    <div class="inv-invoice-field"><span>Reference</span><strong>${safe(record.reference_no)}</strong></div>
                    <div class="inv-invoice-field"><span>Direction</span><strong>${safe(record.invoice_direction)}</strong></div>
                    <div class="inv-invoice-field"><span>Date</span><strong>${formatDate(record.created_at)}</strong></div>
                    <div class="inv-invoice-field"><span>Workflow Status</span><strong>${safe(record.workflow_status || record.approval_status)}</strong></div>
                    <div class="inv-invoice-field"><span>Approval Status</span><strong>${safe(record.approval_status)}</strong></div>
                </div>
                <div class="inv-invoice-note">
                    This invoice is opened from the live inventory workflow. Use row actions in Purchasing or Sales & Invoices to approve, create DO, approve invoice, or mark paid.
                </div>
            </div>`;

        const modal = document.getElementById('invInvoiceModal');
        modal.classList.add('open');
        modal.setAttribute('aria-hidden', 'false');
    }

    function closeInvoiceModal() {
        const modal = document.getElementById('invInvoiceModal');
        modal.classList.remove('open');
        modal.setAttribute('aria-hidden', 'true');
    }

    function printInvoiceDetail() {
        const sheet = document.getElementById('printableInvoice');
        if (!sheet) return;
        const win = window.open('', '_blank', 'width=900,height=700');
        if (!win) {
            alert('Popup blocked. Please allow popups to print this invoice.');
            return;
        }
        win.document.write(`<!doctype html><html><head><title>Invoice</title><style>
            body{font-family:Arial,sans-serif;margin:24px;color:#0f172a}
            .inv-invoice-sheet{border:1px solid #dbe4f0;border-radius:14px;overflow:hidden}
            .inv-invoice-top{display:flex;justify-content:space-between;gap:18px;padding:18px;background:#f8fbff;border-bottom:1px solid #dbe4f0}
            .inv-invoice-brand span,.inv-invoice-total span{display:block;color:#64748b;font-size:12px;font-weight:700;text-transform:uppercase}
            .inv-invoice-brand strong,.inv-invoice-total strong{display:block;margin-top:5px;font-size:22px}
            .inv-invoice-total{text-align:right}
            .inv-invoice-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;padding:18px}
            .inv-invoice-field{border:1px solid #e7edf5;border-radius:12px;padding:12px;background:#f8fafc}
            .inv-invoice-field span{display:block;color:#64748b;font-size:11px;font-weight:700;text-transform:uppercase}
            .inv-invoice-field strong{display:block;margin-top:5px;font-size:13px}
            .inv-invoice-note{margin:0 18px 18px;padding:12px;border-radius:12px;background:#eff6ff;color:#2563eb;font-size:12px;font-weight:700}
        </style></head><body>${sheet.outerHTML}</body></html>`);
        win.document.close();
        win.focus();
        win.print();
    }

    function buildInvoiceHtml() {
        const sheet = document.getElementById('printableInvoice');
        if (!sheet) return '';
        return `<!doctype html><html><head><meta charset="utf-8"><title>Invoice</title><style>
            body{font-family:Arial,sans-serif;margin:24px;color:#0f172a}
            .inv-invoice-sheet{border:1px solid #dbe4f0;border-radius:14px;overflow:hidden}
            .inv-invoice-top{display:flex;justify-content:space-between;gap:18px;padding:18px;background:#f8fbff;border-bottom:1px solid #dbe4f0}
            .inv-invoice-brand span,.inv-invoice-total span{display:block;color:#64748b;font-size:12px;font-weight:700;text-transform:uppercase}
            .inv-invoice-brand strong,.inv-invoice-total strong{display:block;margin-top:5px;font-size:22px}
            .inv-invoice-total{text-align:right}
            .inv-invoice-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;padding:18px}
            .inv-invoice-field{border:1px solid #e7edf5;border-radius:12px;padding:12px;background:#f8fafc}
            .inv-invoice-field span{display:block;color:#64748b;font-size:11px;font-weight:700;text-transform:uppercase}
            .inv-invoice-field strong{display:block;margin-top:5px;font-size:13px}
            .inv-invoice-note{margin:0 18px 18px;padding:12px;border-radius:12px;background:#eff6ff;color:#2563eb;font-size:12px;font-weight:700}
        </style></head><body>${sheet.outerHTML}</body></html>`;
    }

    function downloadInvoiceDetail() {
        const html = buildInvoiceHtml();
        if (!html) return;
        const title = document.getElementById('invoiceModalTitle').textContent || 'invoice';
        const fileName = `${title.replace(/[^a-z0-9-]+/gi, '_')}.html`;
        const blob = new Blob([html], { type: 'text/html;charset=utf-8' });
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = fileName;
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(link.href);
    }

    function csvValue(value) {
        const text = String(value ?? '').replace(/"/g, '""');
        return `"${text}"`;
    }

    function downloadInvoiceLedgerCsv() {
        const rows = invState.invoiceLedgerRows || [];
        if (!rows.length) {
            alert('No invoice ledger data available to export.');
            return;
        }

        const header = ['Direction', 'Invoice No', 'Reference No', 'Party', 'Type', 'Workflow Status', 'Approval Status', 'Payment Status', 'Amount', 'Created At'];
        const csvRows = rows.map(row => [
            row.invoice_direction,
            row.invoice_no,
            row.reference_no,
            row.party_name,
            row.invoice_type,
            row.workflow_status,
            row.approval_status,
            row.payment_status,
            row.total_amount,
            formatDate(row.created_at)
        ].map(csvValue).join(','));

        const csv = [header.map(csvValue).join(','), ...csvRows].join('\r\n');
        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = `TRACK360_Invoice_Ledger_${new Date().toISOString().slice(0, 10)}.csv`;
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(link.href);
    }

    function renderInstallations(rows) {
        invState.installationRows = rows;
        const el = document.getElementById('installationsBody');
        if (!rows.length) {
            el.innerHTML = '<tr><td colspan="7">No installation requests found.</td></tr>';
            return;
        }
        el.innerHTML = rows.map(row => `<tr>
            <td><strong>${safe(row.request_no, 'New request')}</strong><br><small>${new Date(row.created_at).toLocaleDateString()}</small></td>
            <td>${safe(row.customer_name)}<br><small>${safe(row.company_name, '')}</small></td>
            <td><strong>${safe(row.vehicle_no)}</strong><br><small>${safe(row.installation_type)}</small></td>
            <td>${safe(row.tracker_serial, 'Not assigned')}<br><small>${safe(row.tracker_product, '')}</small></td>
            <td>${statusBadge(row.status)}</td>
            <td><small>${safe(row.mapping_notes, safe(row.welcome_call_notes, safe(row.remarks, 'Pending workflow')))}</small></td>
            <td>${installationActions(row)}</td>
        </tr>`).join('');
    }

    function installationActions(row) {
        const status = String(row.status || '').toUpperCase();
        const buttons = [];
        if (!row.tracker_item_id && !['COMPLETED', 'CANCELLED'].includes(status)) {
            buttons.push(`<button type="button" class="inv-mini-btn" onclick="openWorkflowModal('assignTracker','${row.id}')">Assign Tracker</button>`);
        }
        if (row.tracker_item_id && status !== 'COMPLETED' && status !== 'CANCELLED') {
            buttons.push(`<button type="button" class="inv-mini-btn success" onclick="openWorkflowModal('completeInstallation','${row.id}')">Complete</button>`);
        }
        if (!['COMPLETED', 'CANCELLED'].includes(status)) {
            buttons.push(`<button type="button" class="inv-mini-btn danger" onclick="quickWorkflow('cancelInstallation','${row.id}')">Cancel</button>`);
        }
        return buttons.length ? `<div class="inv-table-actions">${buttons.join('')}</div>` : '<span class="inv-status gray">Closed</span>';
    }

    function renderSupport(data) {
        invState.complaints = data.complaints || [];
        invState.replacements = data.replacements || [];
        const complaintsEl = document.getElementById('complaintsBody');
        const replacementsEl = document.getElementById('replacementsBody');

        complaintsEl.innerHTML = invState.complaints.length ? invState.complaints.map(row => `<tr>
            <td><strong>${safe(row.ticket_no, 'New ticket')}</strong><br><small>${new Date(row.created_at).toLocaleDateString()}</small></td>
            <td>${safe(row.customer_name)}<br><small>${safe(row.vehicle_no, '')}</small></td>
            <td>${safe(row.issue_type)}<br><small>${safe(row.remarks, '')}</small></td>
            <td>${statusBadge(row.priority)}</td>
            <td>${statusBadge(row.status)}</td>
            <td>${complaintActions(row)}</td>
        </tr>`).join('') : '<tr><td colspan="6">No complaints found.</td></tr>';

        replacementsEl.innerHTML = invState.replacements.length ? invState.replacements.map(row => `<tr>
            <td><strong>${safe(row.replacement_no, 'New replacement')}</strong><br><small>${new Date(row.created_at).toLocaleDateString()}</small></td>
            <td>${safe(row.customer_name)}</td>
            <td>${safe(row.vehicle_no)}</td>
            <td>${safe(row.old_serial, 'Old not linked')}<br><small>${safe(row.new_serial, 'New not linked')}</small></td>
            <td>${statusBadge(row.status)}</td>
        </tr>`).join('') : '<tr><td colspan="5">No replacements found.</td></tr>';
    }

    function complaintActions(row) {
        const status = String(row.status || '').toUpperCase();
        const buttons = [];
        if (status !== 'RESOLVED') {
            buttons.push(`<button type="button" class="inv-mini-btn success" onclick="quickWorkflow('resolveComplaint','${row.id}')">Resolve</button>`);
            buttons.push(`<button type="button" class="inv-mini-btn" onclick="openWorkflowModal('replacement','${row.id}')">Replacement</button>`);
        }
        return buttons.length ? `<div class="inv-table-actions">${buttons.join('')}</div>` : '<span class="inv-status gray">Closed</span>';
    }

    function renderParties(customers, vendors) {
        invState.customers = customers;
        invState.vendors = vendors;
        const customersEl = document.getElementById('customersList');
        const vendorsEl = document.getElementById('vendorsList');
        const visibleCustomers = customers.slice(0, 12);
        const visibleVendors = vendors.slice(0, 12);
        customersEl.innerHTML = visibleCustomers.length ? visibleCustomers.map(c => `<div class="inv-party">
            <span class="inv-dot"></span>
            <div style="flex:1;"><strong>${safe(c.customer_name)}</strong><span>${safe(c.company_name)} / ${safe(c.phone)}</span></div>
            ${actions('customer', c.id)}
        </div>`).join('') + (customers.length > visibleCustomers.length ? `<div class="inv-empty">Showing ${visibleCustomers.length} of ${customers.length} customers. Use workflow dropdowns for all records.</div>` : '') : '<div class="inv-empty">No customers found.</div>';
        vendorsEl.innerHTML = visibleVendors.length ? visibleVendors.map(v => `<div class="inv-party">
            <span class="inv-dot"></span>
            <div style="flex:1;"><strong>${safe(v.vendor_name)}</strong><span>${safe(v.contact_person)} / ${safe(v.phone)}</span></div>
            ${actions('vendor', v.id)}
        </div>`).join('') + (vendors.length > visibleVendors.length ? `<div class="inv-empty">Showing ${visibleVendors.length} of ${vendors.length} vendors. Use workflow dropdowns for all records.</div>` : '') : '<div class="inv-empty">No vendors found.</div>';
    }

    function optionList(items, valueKey, labelKey, selected) {
        return items.map(item => {
            const value = item[valueKey];
            const selectedAttr = String(value) === String(selected || '') ? 'selected' : '';
            return `<option value="${escapeAttr(value)}" ${selectedAttr}>${escapeAttr(item[labelKey] || item.product_name || item.category_name)}</option>`;
        }).join('');
    }

    function findRecord(type, id) {
        const key = type === 'category' ? 'categories' : type === 'product' ? 'products' : type === 'serial' ? 'serials' : type === 'customer' ? 'customers' : 'vendors';
        return invState[key].find(item => String(item.id) === String(id)) || null;
    }

    function field(name, label, value = '', attrs = '') {
        return `<div class="inv-field"><label>${label}</label><input name="${name}" value="${escapeAttr(value)}" ${attrs} /></div>`;
    }

    function selectField(name, label, options, value = '') {
        return `<div class="inv-field"><label>${label}</label><select name="${name}">${options(value)}</select></div>`;
    }

    function renderMasterFields(type, record = {}) {
        if (type === 'category') {
            return `
                ${field('category_name', 'Category Name', record.category_name, 'required')}
                <div class="inv-field full"><label>Description</label><textarea name="description">${escapeAttr(record.description || '')}</textarea></div>
            `;
        }

        if (type === 'product') {
            return `
                ${field('product_name', 'Product / Service Name', record.product_name, 'required')}
                ${selectField('category_id', 'Category', (selected) => `<option value="">No category</option>${optionList(invState.categories, 'id', 'category_name', selected)}`, record.category_id)}
                ${selectField('product_type', 'Product Type', (selected) => ['ASSET','CONSUMABLE','SERVICE'].map(v => `<option value="${v}" ${v === (selected || 'ASSET') ? 'selected' : ''}>${v}</option>`).join(''), record.product_type || 'ASSET')}
                ${selectField('tracking_type', 'Tracking Type', (selected) => ['SERIAL','IMEI','NONE'].map(v => `<option value="${v}" ${v === (selected || 'NONE') ? 'selected' : ''}>${v}</option>`).join(''), record.tracking_type || 'NONE')}
                ${field('quantity', 'Opening / Current Quantity', record.quantity ?? 0, 'type="number" min="0"')}
            `;
        }

        if (type === 'serial') {
            return `
                ${selectField('product_id', 'Product', (selected) => `${optionList(invState.products, 'id', 'product_name', selected)}`, record.product_id)}
                ${field('serial_number', 'Serial / IMEI Number', record.serial_number, 'required')}
                ${selectField('current_status', 'Current Status', (selected) => ['AVAILABLE','ALLOCATED','INSTALLED','RETURNED','DAMAGED'].map(v => `<option value="${v}" ${v === (selected || 'AVAILABLE') ? 'selected' : ''}>${v}</option>`).join(''), record.current_status || 'AVAILABLE')}
            `;
        }

        if (type === 'customer') {
            return `
                ${field('customer_name', 'Customer Name', record.customer_name, 'required')}
                ${field('company_name', 'Company Name', record.company_name, 'required')}
                ${field('customer_type', 'Customer Type', record.customer_type || 'Corporate', 'required')}
                ${field('phone', 'Phone', record.phone, 'required')}
                ${field('email', 'Email', record.email, 'type="email" required')}
            `;
        }

        return `
            ${field('vendor_name', 'Vendor Name', record.vendor_name, 'required')}
            ${field('contact_person', 'Contact Person', record.contact_person)}
            ${field('phone', 'Phone', record.phone)}
            ${field('email', 'Email', record.email, 'type="email"')}
        `;
    }

    function openMasterModal(type, id = '') {
        const record = id ? findRecord(type, id) : {};
        const labels = {
            category: 'Category',
            product: 'Product / Service',
            serial: 'Serial Item',
            customer: 'Customer',
            vendor: 'Vendor'
        };

        document.getElementById('masterType').value = type;
        document.getElementById('masterRecordId').value = id || '';
        document.getElementById('masterModalKicker').textContent = id ? 'Edit master record' : 'Create master record';
        document.getElementById('masterModalTitle').textContent = `${id ? 'Edit' : 'Add'} ${labels[type]}`;
        document.getElementById('masterFields').innerHTML = renderMasterFields(type, record || {});
        document.getElementById('invMasterModal').classList.add('open');
        document.getElementById('invMasterModal').setAttribute('aria-hidden', 'false');
    }

    function closeMasterModal() {
        document.getElementById('invMasterModal').classList.remove('open');
        document.getElementById('invMasterModal').setAttribute('aria-hidden', 'true');
        document.getElementById('masterForm').reset();
    }

    function workflowSelect(name, label, optionsHtml, value = '') {
        return `<div class="inv-field"><label>${label}</label><select name="${name}" required>${optionsHtml(value)}</select></div>`;
    }

    function workflowRemarks(value = '') {
        return `<div class="inv-field full"><label>Remarks</label><textarea name="remarks" placeholder="Approval note, receiving note, client reference...">${escapeAttr(value)}</textarea></div>`;
    }

    function workflowItemBox(kind) {
        const purchase = kind === 'purchase';
        return `<div class="inv-items-box">
            <div class="inv-panel-head" style="padding:0;border:0;">
                <div><span>${purchase ? 'Requested items' : 'Quotation items'}</span><h2 style="font-size:15px;">Line Items</h2></div>
                <button type="button" class="inv-mini-btn" onclick="addWorkflowItemRow('${kind}')">Add Item</button>
            </div>
            <div id="workflowItems"></div>
        </div>`;
    }

    function addWorkflowItemRow(kind) {
        const wrap = document.getElementById('workflowItems');
        if (!wrap) return;
        const purchase = kind === 'purchase';
        const options = optionList(invState.products, 'id', 'product_name', '');
        const row = document.createElement('div');
        row.className = `inv-item-row ${purchase ? 'purchase-item' : ''}`;
        row.innerHTML = `
            <select name="product_id" required><option value="">Select product</option>${options}</select>
            <input name="quantity" type="number" min="1" value="1" required />
            ${purchase ? '' : '<input name="unit_price" type="number" min="0" step="0.01" value="0" required />'}
            <button type="button" class="inv-row-remove" onclick="this.closest('.inv-item-row').remove()">x</button>
        `;
        wrap.appendChild(row);
    }

    function parseWorkflowItems(items) {
        if (Array.isArray(items)) return items;
        try { return JSON.parse(items || '[]'); } catch { return []; }
    }

    function collectWorkflowItems(includePrice) {
        return Array.from(document.querySelectorAll('#workflowItems .inv-item-row')).map(row => {
            const productId = row.querySelector('[name="product_id"]').value;
            const product = invState.products.find(item => String(item.id) === String(productId));
            return {
                product_id: productId,
                product_name: product?.product_name || '',
                quantity: Number(row.querySelector('[name="quantity"]').value || 1),
                unit_price: includePrice ? Number(row.querySelector('[name="unit_price"]').value || 0) : 0
            };
        }).filter(item => item.product_id);
    }

    function findWorkflowRow(collection, id) {
        return collection.find(item => String(item.id) === String(id)) || null;
    }

    function trackerOptions(statuses = ['AVAILABLE', 'ALLOCATED']) {
        const allowed = statuses.map(status => status.toUpperCase());
        return invState.serials
            .filter(item => allowed.includes(String(item.current_status || '').toUpperCase()))
            .map(item => `<option value="${escapeAttr(item.id)}">${escapeAttr(item.serial_number)} - ${escapeAttr(item.product_name || 'Tracker')}</option>`)
            .join('');
    }

    function renderWorkflowFields(type, id = '') {
        if (type === 'purchaseRequest') {
            setTimeout(() => addWorkflowItemRow('purchase'), 0);
            return `
                ${workflowSelect('department_id', 'Department', selected => optionList(invState.departments, 'id', 'department_name', selected))}
                ${workflowItemBox('purchase')}
                ${workflowRemarks()}
            `;
        }

        if (type === 'purchaseOrder') {
            const approvedPrs = invState.purchaseRows.filter(row => String(row.status).toUpperCase() === 'APPROVED' && !row.purchase_order_db_id);
            return `
                ${id ? '' : workflowSelect('purchase_request_id', 'Approved Purchase Request', selected => optionList(approvedPrs, 'id', 'pr_id', selected))}
                ${workflowSelect('vendor_id', 'Vendor', selected => optionList(invState.vendors, 'id', 'vendor_name', selected))}
                ${field('default_unit_price', 'Default Unit Price', 0, 'type="number" min="0" step="0.01" required')}
                ${workflowRemarks('PO generated from approved PR.')}
            `;
        }

        if (type === 'grn') {
            const pendingOrders = invState.purchaseOrders.filter(row => !row.grn_id);
            return `
                ${id ? '' : workflowSelect('purchase_order_id', 'Purchase Order', selected => optionList(pendingOrders, 'id', 'po_id', selected))}
                ${field('serial_prefix', 'Serial Prefix', `GRN-${new Date().toISOString().slice(0,10).replaceAll('-', '')}`, 'required')}
                ${workflowRemarks('Goods received and added to inventory.')}
            `;
        }

        if (type === 'quotation') {
            setTimeout(() => addWorkflowItemRow('sales'), 0);
            return `
                ${workflowSelect('customer_id', 'Customer', selected => optionList(invState.customers, 'id', 'customer_name', selected))}
                ${workflowItemBox('sales')}
                ${workflowRemarks('Quotation prepared for client approval.')}
            `;
        }

        if (type === 'installation') {
            return `
                ${workflowSelect('customer_id', 'Customer', selected => optionList(invState.customers, 'id', 'customer_name', selected))}
                ${field('vehicle_no', 'Vehicle Number', '', 'required placeholder="ABC-123"')}
                ${field('vehicle_model', 'Vehicle Model', '', 'placeholder="Toyota Corolla / Truck / Bike"')}
                ${field('contact_person', 'Contact Person', '', 'placeholder="Fleet coordinator"')}
                ${field('contact_phone', 'Contact Phone', '', 'placeholder="03001234567"')}
                ${selectField('installation_type', 'Installation Type', selected => ['NEW','REPLACEMENT','SERVICE'].map(v => `<option value="${v}" ${v === (selected || 'NEW') ? 'selected' : ''}>${v}</option>`).join(''), 'NEW')}
                ${field('po_reference', 'PO / Client Reference', '', 'placeholder="Optional"')}
                ${workflowRemarks('Installation request created from inventory workspace.')}
            `;
        }

        if (type === 'assignTracker') {
            const installation = findWorkflowRow(invState.installationRows, id);
            return `
                <div class="inv-field full"><label>Installation</label><input value="${escapeAttr(`${installation?.customer_name || ''} / ${installation?.vehicle_no || ''}`)}" disabled /></div>
                <div class="inv-field full"><label>Tracker Serial</label><select name="tracker_item_id" required><option value="">Select available tracker</option>${trackerOptions()}</select></div>
                ${field('mapping_notes', 'Vehicle Mapping Notes', `Mapped to ${installation?.vehicle_no || 'vehicle'}`, 'required')}
                ${workflowRemarks('Tracker assigned and marked installed.')}
            `;
        }

        if (type === 'completeInstallation') {
            return `
                ${field('welcome_call_notes', 'Welcome Call Notes', 'Customer welcome call completed.', 'required')}
                ${field('billing_notes', 'Billing / Finance Notes', 'Billing setup ready.', 'required')}
                ${workflowRemarks('Installation completed.')}
            `;
        }

        if (type === 'complaint') {
            return `
                ${workflowSelect('customer_id', 'Customer', selected => optionList(invState.customers, 'id', 'customer_name', selected))}
                ${field('vehicle_no', 'Vehicle Number', '', 'placeholder="Optional"')}
                ${field('issue_type', 'Issue Type', '', 'required placeholder="No signal / device fault / billing issue"')}
                ${selectField('priority', 'Priority', selected => ['LOW','MEDIUM','HIGH'].map(v => `<option value="${v}" ${v === (selected || 'MEDIUM') ? 'selected' : ''}>${v}</option>`).join(''), 'MEDIUM')}
                ${workflowRemarks('Complaint taken by support team.')}
            `;
        }

        if (type === 'replacement') {
            const complaint = findWorkflowRow(invState.complaints, id);
            const customerId = complaint?.customer_id || '';
            const vehicleNo = complaint?.vehicle_no || '';
            return `
                ${id ? `<input type="hidden" name="complaint_id" value="${escapeAttr(id)}" />` : ''}
                ${id ? `<input type="hidden" name="customer_id" value="${escapeAttr(customerId)}" />` : workflowSelect('customer_id', 'Customer', selected => optionList(invState.customers, 'id', 'customer_name', selected))}
                ${field('vehicle_no', 'Vehicle Number', vehicleNo, 'placeholder="Vehicle number"')}
                <div class="inv-field"><label>Old Serial</label><select name="old_inventory_item_id"><option value="">Old serial unknown</option>${trackerOptions(['INSTALLED','ALLOCATED','DAMAGED','RETURNED'])}</select></div>
                <div class="inv-field"><label>New Serial</label><select name="new_inventory_item_id" required><option value="">Select replacement tracker</option>${trackerOptions(['AVAILABLE','ALLOCATED'])}</select></div>
                ${workflowRemarks('Old serial returned, new serial installed, complaint resolved.')}
            `;
        }

        return workflowRemarks();
    }

    function openWorkflowModal(type, id = '') {
        const titles = {
            purchaseRequest: 'Create Purchase Request',
            purchaseOrder: 'Generate Purchase Order',
            grn: 'Receive Goods Note',
            quotation: 'Create Customer Quotation',
            installation: 'Create Installation Request',
            assignTracker: 'Assign Tracker Serial',
            completeInstallation: 'Complete Installation',
            complaint: 'Create Complaint Ticket',
            replacement: 'Record Item Replacement'
        };
        document.getElementById('workflowType').value = type;
        document.getElementById('workflowRecordId').value = id || '';
