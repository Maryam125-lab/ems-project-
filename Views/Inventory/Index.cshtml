@{
    ViewData["Title"] = "Inventory Control";
    ViewData["Active"] = "Inventory";
}

<section class="inv-shell">
    <div class="inv-hero">
        <div>
            <div class="inv-eyebrow">
                <span class="inv-live-dot"></span>
                ERP Module 02
            </div>
            <h1>Inventory & Invoicing Control</h1>
            <p>Stock-in, stock-out, purchase approvals, quotations, delivery orders, invoices, tracker serials, vendors and customers in one operational workspace.</p>
            <div class="inv-status-row">
                <span class="inv-pill live" id="inventoryAuthStatus">Checking backend...</span>
                <span class="inv-pill">HR auth connected</span>
                <span class="inv-pill">Database live</span>
            </div>
        </div>
        <div class="inv-hero-card">
            <span>Office demo readiness</span>
            <strong id="demoReadiness">Loading...</strong>
            <small id="demoReadinessSub">Live actions, ledger views, stock movement, invoices and customer support are being checked.</small>
            <div class="inv-health-meter" aria-label="Inventory readiness">
                <span id="demoReadinessMeter"></span>
            </div>
        </div>
    </div>

    <div class="inv-kpi-grid">
        <div class="inv-kpi blue">
            <div class="inv-kpi-head"><span>Total Products</span><i class="fa-solid fa-boxes-stacked" aria-hidden="true"></i></div>
            <strong id="kpiProducts">--</strong>
            <small id="kpiProductsSub">Loading...</small>
            <div class="inv-kpi-foot"><span id="kpiCategoryFoot">Categories loading</span></div>
        </div>
        <div class="inv-kpi green">
            <div class="inv-kpi-head"><span>Available Serials</span><i class="fa-solid fa-barcode" aria-hidden="true"></i></div>
            <strong id="kpiAvailable">--</strong>
            <small id="kpiAvailableSub">Ready stock</small>
            <div class="inv-mini-meter"><span id="stockHealthMeter"></span></div>
        </div>
        <div class="inv-kpi amber">
            <div class="inv-kpi-head"><span>Pending Approvals</span><i class="fa-solid fa-route" aria-hidden="true"></i></div>
            <strong id="kpiPending">--</strong>
            <small>Purchase and invoice queue</small>
            <div class="inv-kpi-foot"><span id="kpiPendingFoot">Queue loading</span></div>
        </div>
        <div class="inv-kpi red">
            <div class="inv-kpi-head"><span>Exceptions</span><i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i></div>
            <strong id="kpiExceptions">--</strong>
            <small>Damaged / returned stock</small>
            <div class="inv-kpi-foot"><span id="kpiExceptionFoot">Risk loading</span></div>
        </div>
    </div>

    <div class="inv-tabs" role="tablist" aria-label="Inventory views">
        <button type="button" class="active" data-tab="overview" onclick="showInvTab('overview')">Overview</button>
        <button type="button" data-tab="stock" onclick="showInvTab('stock')">Stock</button>
        <button type="button" data-tab="purchase" onclick="showInvTab('purchase')">Purchasing</button>
        <button type="button" data-tab="sales" onclick="showInvTab('sales')">Sales & Invoices</button>
        <button type="button" data-tab="installations" onclick="showInvTab('installations')">Installations</button>
        <button type="button" data-tab="support" onclick="showInvTab('support')">Support</button>
        <button type="button" data-tab="parties" onclick="showInvTab('parties')">Customers & Vendors</button>
        <button type="button" data-tab="masters" onclick="showInvTab('masters')">Master Setup</button>
    </div>

    <div class="inv-tab-panel active" id="inv-tab-overview">
        <div class="inv-command-strip">
            <button type="button" onclick="openWorkflowModal('purchaseRequest')"><span>Purchase</span><strong>New PR</strong></button>
            <button type="button" onclick="openWorkflowModal('quotation')"><span>Sales</span><strong>New Quotation</strong></button>
            <button type="button" onclick="openWorkflowModal('installation')"><span>Installations</span><strong>New Request</strong></button>
            <button type="button" onclick="openWorkflowModal('complaint')"><span>Support</span><strong>New Complaint</strong></button>
            <button type="button" onclick="openMasterModal('product')"><span>Master</span><strong>Add Product</strong></button>
        </div>

        <div class="inv-exec-grid">
            <div class="inv-exec-card primary">
                <span>Operational health</span>
                <strong id="execHealthScore">--</strong>
                <small id="execHealthSub">Calculating ERP readiness...</small>
            </div>
            <div class="inv-exec-card">
                <span>Invoice value</span>
                <strong id="execInvoiceValue">--</strong>
                <small id="execInvoiceSub">Sales ledger value</small>
            </div>
            <div class="inv-exec-card">
                <span>Stock utilization</span>
                <strong id="execStockUtilization">--</strong>
                <small id="execStockSub">Available vs tracked serials</small>
            </div>
            <div class="inv-exec-card danger">
                <span>Attention queue</span>
                <strong id="execAttention">--</strong>
                <small id="execAttentionSub">Approvals, complaints, exceptions</small>
            </div>
        </div>

        <div class="inv-dashboard-grid">
            <div class="inv-phase-card blue">
                <span>Purchase Pipeline</span>
                <strong id="dashPurchase">--</strong>
                <small id="dashPurchaseSub">Loading...</small>
                <button type="button" onclick="showInvTab('purchase')">Open Purchasing</button>
            </div>
            <div class="inv-phase-card green">
                <span>Sales Pipeline</span>
                <strong id="dashSales">--</strong>
                <small id="dashSalesSub">Loading...</small>
                <button type="button" onclick="showInvTab('sales')">Open Sales</button>
            </div>
            <div class="inv-phase-card amber">
                <span>Tracker Installations</span>
                <strong id="dashInstallations">--</strong>
                <small id="dashInstallationsSub">Loading...</small>
                <button type="button" onclick="showInvTab('installations')">Open Installations</button>
            </div>
            <div class="inv-phase-card red">
                <span>Support Desk</span>
                <strong id="dashSupport">--</strong>
                <small id="dashSupportSub">Loading...</small>
                <button type="button" onclick="showInvTab('support')">Open Support</button>
            </div>
        </div>

        <div class="inv-panel inv-process-panel">
            <div class="inv-panel-head">
                <div>
                    <span>Process map</span>
                    <h2>ERP Flow Coverage</h2>
                    <small>Click a step to start a new record or continue from the matching workflow table.</small>
                </div>
            </div>
            <div class="inv-flow-board compact">
                <div class="inv-flow-lane">
                    <div class="inv-lane-title">Stock-In Purchase Flow</div>
                    <button type="button" class="inv-flow-step done" onclick="openWorkflowModal('purchaseRequest')">1. Purchase Request</button>
                    <button type="button" class="inv-flow-step active" onclick="showInvTab('purchase')">2. Manager Approval</button>
                    <button type="button" class="inv-flow-step active" onclick="showInvTab('purchase')">3. Finance Approval</button>
                    <button type="button" class="inv-flow-step" onclick="showInvTab('purchase')">4. Purchase Order</button>
                    <button type="button" class="inv-flow-step" onclick="showInvTab('purchase')">5. GRN Receiving</button>
                    <button type="button" class="inv-flow-step success" onclick="showInvTab('stock')">6. Add to Inventory</button>
                </div>
                <div class="inv-flow-lane">
                    <div class="inv-lane-title">Stock-Out Supply & Services</div>
                    <button type="button" class="inv-flow-step done" onclick="openWorkflowModal('quotation')">1. Generate Quotation</button>
                    <button type="button" class="inv-flow-step active" onclick="showInvTab('sales')">2. Send to Client</button>
                    <button type="button" class="inv-flow-step" onclick="showInvTab('sales')">3. Create Delivery Order</button>
                    <button type="button" class="inv-flow-step" onclick="showInvTab('sales')">4. Generate Invoice</button>
                    <button type="button" class="inv-flow-step success" onclick="showInvTab('sales')">5. Paid / Allocated</button>
                </div>
                <div class="inv-flow-lane">
                    <div class="inv-lane-title">Tracker Installation Flow</div>
                    <button type="button" class="inv-flow-step done" onclick="openWorkflowModal('installation')">1. Installation Request</button>
                    <button type="button" class="inv-flow-step active" onclick="showInvTab('installations')">2. Assign Tracker</button>
                    <button type="button" class="inv-flow-step" onclick="showInvTab('installations')">3. Vehicle Mapping</button>
                    <button type="button" class="inv-flow-step success" onclick="showInvTab('installations')">4. Welcome Call & Billing</button>
                </div>
                <div class="inv-flow-lane">
                    <div class="inv-lane-title">Customer Support</div>
                    <button type="button" class="inv-flow-step done" onclick="openWorkflowModal('complaint')">Complaints</button>
                    <button type="button" class="inv-flow-step active" onclick="showInvTab('support')">Replacement Tracking</button>
                    <button type="button" class="inv-flow-step" onclick="showInvTab('support')">Serial Transfer</button>
                    <button type="button" class="inv-flow-step success" onclick="showInvTab('support')">Resolved / Pending</button>
                </div>
            </div>
        </div>

        <div class="inv-grid-two">
            <div class="inv-panel">
                <div class="inv-panel-head">
                    <div>
                        <span>Category intelligence</span>
                        <h2>Products by Category</h2>
                    </div>
                </div>
                <div class="inv-bars" id="categoryBars">
                    <div class="inv-empty">Loading category distribution...</div>
                </div>
            </div>
            <div class="inv-panel">
                <div class="inv-panel-head">
                    <div>
                        <span>Recent stock activity</span>
                        <h2>Inventory Movements</h2>
                    </div>
                </div>
                <div class="inv-activity" id="recentMovements">
                    <div class="inv-empty">Loading movements...</div>
                </div>
            </div>
        </div>

        <div class="inv-panel inv-readiness-panel">
            <div class="inv-panel-head">
                <div>
                    <span>ERP readiness</span>
                    <h2>Final Workflow Coverage</h2>
                </div>
                <strong id="workflowReadinessScore">--</strong>
            </div>
            <div class="inv-readiness-grid" id="workflowReadinessGrid">
                <div>Loading coverage...</div>
            </div>
        </div>
    </div>

    <div class="inv-tab-panel" id="inv-tab-stock">
        <div class="inv-grid-two">
            <div class="inv-panel">
                <div class="inv-panel-head">
                    <div>
                        <span>Item master</span>
                        <h2>Products & Services</h2>
                    </div>
                    <button type="button" class="inv-action-btn" onclick="openMasterModal('product')">Add Product</button>
                </div>
                <div class="inv-table-wrap">
                    <table class="inv-table">
                        <thead><tr><th>Product</th><th>Category</th><th>Type</th><th>Tracking</th><th>Available</th><th>Actions</th></tr></thead>
                        <tbody id="productsBody"><tr><td colspan="5">Loading...</td></tr></tbody>
                    </table>
                </div>
            </div>
            <div class="inv-panel">
                <div class="inv-panel-head">
                    <div>
                        <span>Serial control</span>
                        <h2>Tracked Items</h2>
                    </div>
                    <button type="button" class="inv-action-btn" onclick="openMasterModal('serial')">Add Serial</button>
                </div>
                <div class="inv-table-wrap">
                    <table class="inv-table">
                        <thead><tr><th>Serial</th><th>Product</th><th>Category</th><th>Status</th><th>Actions</th></tr></thead>
                        <tbody id="serialsBody"><tr><td colspan="4">Loading...</td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="inv-tab-panel" id="inv-tab-purchase">
        <div class="inv-panel">
            <div class="inv-panel-head">
                <div>
                    <span>Stock-in workflow</span>
                    <h2>Purchase Requests</h2>
                </div>
                <div class="inv-head-actions">
                    <button type="button" class="inv-action-btn" onclick="openWorkflowModal('purchaseRequest')">New PR</button>
                    <button type="button" class="inv-action-btn ghost-action" onclick="openWorkflowModal('grn')">Receive GRN</button>
                </div>
            </div>
            <div class="inv-table-wrap">
                <table class="inv-table">
                    <thead><tr><th>PR No.</th><th>Department</th><th>Requested By</th><th>Items</th><th>PO / GRN</th><th>Status</th><th>Actions</th></tr></thead>
                    <tbody id="purchaseBody"><tr><td colspan="7">Loading...</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="inv-tab-panel" id="inv-tab-sales">
        <div class="inv-panel">
            <div class="inv-panel-head">
                <div>
                    <span>Stock-out workflow</span>
                    <h2>Quotations, Delivery & Invoices</h2>
                </div>
                <button type="button" class="inv-action-btn" onclick="openWorkflowModal('quotation')">New Quotation</button>
            </div>
            <div class="inv-table-wrap">
                <table class="inv-table">
                    <thead><tr><th>Quotation</th><th>Customer</th><th>Delivery</th><th>Invoice</th><th>Payment</th><th>Amount</th><th>Actions</th></tr></thead>
                    <tbody id="salesBody"><tr><td colspan="7">Loading...</td></tr></tbody>
                </table>
            </div>
        </div>
        <div class="inv-panel" style="margin-top:16px;">
            <div class="inv-panel-head">
                <div>
                    <span>Incoming and outgoing invoices</span>
                    <h2>All Invoices Ledger</h2>
                </div>
                <div class="inv-head-actions">
                    <span class="inv-pill live">Purchase + Sales</span>
                    <button type="button" class="inv-action-btn ghost-action" onclick="downloadInvoiceLedgerCsv()">Export Ledger</button>
                </div>
            </div>
            <div class="inv-table-wrap">
                <table class="inv-table">
                    <thead><tr><th>Direction</th><th>Invoice / Ref</th><th>Party</th><th>Type</th><th>Workflow</th><th>Payment</th><th>Amount</th></tr></thead>
                    <tbody id="invoiceLedgerBody"><tr><td colspan="7">Loading...</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="inv-tab-panel" id="inv-tab-installations">
        <div class="inv-panel">
            <div class="inv-panel-head">
                <div>
                    <span>Tracker installation workflow</span>
                    <h2>Installation Requests, Vehicle Mapping & Billing</h2>
                </div>
                <button type="button" class="inv-action-btn" onclick="openWorkflowModal('installation')">New Installation</button>
            </div>
            <div class="inv-table-wrap">
                <table class="inv-table">
                    <thead><tr><th>Request</th><th>Customer</th><th>Vehicle</th><th>Tracker</th><th>Status</th><th>Notes</th><th>Actions</th></tr></thead>
                    <tbody id="installationsBody"><tr><td colspan="7">Loading...</td></tr></tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="inv-tab-panel" id="inv-tab-support">
        <div class="inv-grid-two">
            <div class="inv-panel">
                <div class="inv-panel-head">
                    <div>
                        <span>Customer & complaint management</span>
                        <h2>Complaints</h2>
                    </div>
                    <button type="button" class="inv-action-btn" onclick="openWorkflowModal('complaint')">New Complaint</button>
                </div>
                <div class="inv-table-wrap">
                    <table class="inv-table">
                        <thead><tr><th>Ticket</th><th>Customer</th><th>Issue</th><th>Priority</th><th>Status</th><th>Actions</th></tr></thead>
                        <tbody id="complaintsBody"><tr><td colspan="6">Loading...</td></tr></tbody>
                    </table>
                </div>
            </div>
            <div class="inv-panel">
                <div class="inv-panel-head">
                    <div>
                        <span>Item replacement tracking</span>
                        <h2>Serial Transfers</h2>
                    </div>
                    <button type="button" class="inv-action-btn" onclick="openWorkflowModal('replacement')">New Replacement</button>
                </div>
                <div class="inv-table-wrap">
                    <table class="inv-table">
                        <thead><tr><th>Replacement</th><th>Customer</th><th>Vehicle</th><th>Old / New Serial</th><th>Status</th></tr></thead>
                        <tbody id="replacementsBody"><tr><td colspan="5">Loading...</td></tr></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="inv-tab-panel" id="inv-tab-parties">
        <div class="inv-grid-two">
            <div class="inv-panel">
                <div class="inv-panel-head">
                    <div>
                        <span>Client master</span>
                        <h2>Customers</h2>
                    </div>
                    <button type="button" class="inv-action-btn" onclick="openMasterModal('customer')">Add Customer</button>
                </div>
                <div class="inv-list" id="customersList"><div class="inv-empty">Loading customers...</div></div>
            </div>
            <div class="inv-panel">
                <div class="inv-panel-head">
                    <div>
                        <span>Supply master</span>
                        <h2>Vendors</h2>
                    </div>
                    <button type="button" class="inv-action-btn" onclick="openMasterModal('vendor')">Add Vendor</button>
                </div>
                <div class="inv-list" id="vendorsList"><div class="inv-empty">Loading vendors...</div></div>
            </div>
        </div>
    </div>

    <div class="inv-tab-panel" id="inv-tab-masters">
        <div class="inv-master-toolbar">
            <button type="button" onclick="openMasterModal('category')">New Category</button>
            <button type="button" onclick="openMasterModal('product')">New Product / Service</button>
            <button type="button" onclick="openMasterModal('serial')">New Serial Item</button>
            <button type="button" onclick="openMasterModal('customer')">New Customer</button>
            <button type="button" onclick="openMasterModal('vendor')">New Vendor</button>
        </div>
        <div class="inv-grid-two">
            <div class="inv-panel">
                <div class="inv-panel-head">
                    <div>
                        <span>Config master</span>
                        <h2>Categories</h2>
                    </div>
                </div>
                <div class="inv-table-wrap">
                    <table class="inv-table">
                        <thead><tr><th>Category</th><th>Description</th><th>Products</th><th>Actions</th></tr></thead>
                        <tbody id="categoriesBody"><tr><td colspan="4">Loading...</td></tr></tbody>
                    </table>
                </div>
            </div>
            <div class="inv-panel">
                <div class="inv-panel-head">
                    <div>
                        <span>Action guide</span>
                        <h2>Master Data Rules</h2>
                    </div>
                </div>
                <div class="inv-rule-list">
                    <div><strong>Products</strong><span>Create products before serial items.</span></div>
                    <div><strong>Serials</strong><span>Use unique tracker/camera/device serial numbers.</span></div>
                    <div><strong>Customers</strong><span>Customer IDs are generated automatically.</span></div>
                    <div><strong>Vendors</strong><span>Vendor IDs are generated automatically.</span></div>
                    <div><strong>Delete safety</strong><span>Records linked with purchase/sales history are protected.</span></div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="inv-modal-backdrop" id="invMasterModal" aria-hidden="true">
    <div class="inv-modal">
        <div class="inv-modal-head">
            <div>
                <span id="masterModalKicker">Master setup</span>
                <h2 id="masterModalTitle">Add Record</h2>
            </div>
            <button type="button" onclick="closeMasterModal()" aria-label="Close">x</button>
        </div>
        <form id="masterForm" onsubmit="return saveMasterRecord(event)">
            <input type="hidden" name="master_type" id="masterType" />
            <input type="hidden" name="record_id" id="masterRecordId" />
            <div class="inv-form-grid" id="masterFields"></div>
            <div class="inv-modal-actions">
                <button type="button" class="inv-btn ghost" onclick="closeMasterModal()">Cancel</button>
                <button type="submit" class="inv-btn primary" id="masterSaveBtn">Save</button>
            </div>
        </form>
    </div>
</div>

<div class="inv-modal-backdrop" id="invWorkflowModal" aria-hidden="true">
    <div class="inv-modal">
        <div class="inv-modal-head">
            <div>
                <span id="workflowModalKicker">ERP workflow</span>
                <h2 id="workflowModalTitle">Run Action</h2>
            </div>
            <button type="button" onclick="closeWorkflowModal()" aria-label="Close">x</button>
        </div>
        <form id="workflowForm" onsubmit="return saveWorkflowRecord(event)">
            <input type="hidden" name="workflow_type" id="workflowType" />
            <input type="hidden" name="record_id" id="workflowRecordId" />
            <div class="inv-form-grid" id="workflowFields"></div>
            <div class="inv-modal-actions">
                <button type="button" class="inv-btn ghost" onclick="closeWorkflowModal()">Cancel</button>
                <button type="submit" class="inv-btn primary" id="workflowSaveBtn">Run Action</button>
            </div>
        </form>
    </div>
</div>

<div class="inv-modal-backdrop" id="invInvoiceModal" aria-hidden="true">
    <div class="inv-modal inv-invoice-modal">
        <div class="inv-modal-head">
            <div>
                <span id="invoiceModalKicker">Invoice preview</span>
                <h2 id="invoiceModalTitle">Invoice Details</h2>
            </div>
            <button type="button" onclick="closeInvoiceModal()" aria-label="Close">x</button>
        </div>
        <div id="invoiceDetailBody"></div>
        <div class="inv-modal-actions">
            <button type="button" class="inv-btn ghost" onclick="closeInvoiceModal()">Close</button>
            <button type="button" class="inv-btn ghost" onclick="downloadInvoiceDetail()">Download Invoice</button>
            <button type="button" class="inv-btn primary" onclick="printInvoiceDetail()">Print Invoice</button>
        </div>
    </div>
</div>

@section Styles {
<style>
    .inv-shell { display: flex; flex-direction: column; gap: 16px; }

    .inv-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 280px;
        gap: 20px;
        align-items: center;
        padding: 24px;
        border: 1px solid rgba(37, 99, 235, .16);
        border-radius: 18px;
        background:
            radial-gradient(circle at 12% 10%, rgba(37,99,235,.16), transparent 30%),
            radial-gradient(circle at 88% 12%, rgba(5,150,105,.12), transparent 28%),
            linear-gradient(135deg, #ffffff, #f8fbff 54%, #edf7ff);
        box-shadow: 0 18px 48px rgba(15, 23, 42, .08);
    }

    .inv-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--muted);
        font-size: 11px;
        font-weight: 900;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .inv-live-dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: var(--accent2);
        box-shadow: 0 0 0 6px rgba(5,150,105,.14);
    }

    .inv-hero h1 {
        margin: 8px 0 8px;
        color: #0f172a;
        font-size: 30px;
        line-height: 1.12;
    }

    .inv-hero p {
        max-width: 860px;
        color: var(--muted);
        line-height: 1.55;
        font-size: 14px;
    }

    .inv-status-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 14px; }

    .inv-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 7px 10px;
        background: #eef4ff;
        color: var(--text2);
        border: 1px solid var(--border);
        font-size: 11px;
        font-weight: 800;
    }

    .inv-pill.live { color: var(--accent2); background: var(--accent2-light); border-color: rgba(5,150,105,.16); }

    .inv-hero-card {
        padding: 18px;
        border-radius: 16px;
        background: rgba(255,255,255,.78);
        border: 1px solid rgba(255,255,255,.86);
        box-shadow: var(--shadow-md);
    }

    .inv-hero-card span,
    .inv-panel-head span {
        color: var(--muted);
        font-size: 11px;
        font-weight: 900;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .inv-hero-card strong {
        display: block;
        color: #0f172a;
        font-size: 22px;
        margin-top: 8px;
    }

