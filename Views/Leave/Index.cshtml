@{
    ViewData["Title"] = "Leave Management";
    ViewData["Active"] = "Leave";
}

<!-- PAGE HEADER -->
<div class="page-header anim-fade-in-up">
    <div>
        <h1 class="page-title">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Leave Management
        </h1>
        <div class="page-date">Review, approve, and manage employee leave requests</div>
    </div>
</div>

<!-- STAT CARDS -->
<div class="kpi-grid stagger" style="grid-template-columns: repeat(4, 1fr); margin-bottom: 20px;">
    <div class="stat-card amber"><div class="kpi-label"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Pending Requests</div><div class="kpi-num" style="color:var(--accent3)" id="lvPending">--</div><div class="kpi-sub">Requires action</div></div>
    <div class="stat-card green"><div class="kpi-label"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> Approved</div><div class="kpi-num" style="color:var(--accent2)" id="lvApproved">--</div><div class="kpi-sub">This period</div></div>
    <div class="stat-card red"><div class="kpi-label"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg> Rejected</div><div class="kpi-num" style="color:var(--accent4)" id="lvRejected">--</div><div class="kpi-sub">Capacity conflicts</div></div>
    <div class="stat-card blue"><div class="kpi-label"><svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg> On Leave Today</div><div class="kpi-num" id="lvToday">--</div><div class="kpi-sub" id="lvTodaySub">Loading...</div></div>
</div>

<!-- TWO-COLUMN LAYOUT: TABLE + ANALYTICS CHART -->
<div class="two-col" style="grid-template-columns: 1fr 340px; margin-bottom: 20px; align-items: flex-start; gap:20px;">
    <!-- LEAVE REQUESTS TABLE -->
    <div class="table-container anim-fade-in-up" style="margin: 0; height:100%;">
        <div class="filter-bar">
            <div class="filter-group">
                <label class="filter-label">Status</label>
                <select class="filter-select" id="lvFilterStatus" onchange="filterLeaves()">
                    <option value="all">All Statuses</option><option value="pending">Pending</option><option value="approved">Approved</option><option value="rejected">Rejected</option>
                </select>
            </div>
            <div class="filter-group">
                <label class="filter-label">Department</label>
                <select class="filter-select" id="lvFilterDept" onchange="filterLeaves()"><option value="all">All</option></select>
            </div>
            <input class="filter-search" type="text" placeholder="Search…" id="lvSearch" oninput="filterLeaves()" />
        </div>

        <div class="table-scroll-wrapper">
            <table class="data-table" id="leaveTable">
                <thead>
                    <tr>
                        <th>Employee</th><th>ID</th><th>Department</th><th>Leave Type</th><th>Dates</th><th>Status</th><th>Reason</th><th>Actions</th>
                    </tr>
                </thead>
                <tbody id="lvTableBody">
                    <tr><td colspan="8" style="text-align:center;padding:40px;color:var(--muted);">Loading leave requests...</td></tr>
                </tbody>
            </table>
        </div>
        <div class="table-pagination"><div class="pagination-info" id="lvPagInfo">Loading...</div></div>
    </div>

    <!-- LEAVE ANALYTICS CHART CARD -->
    <div class="card anim-fade-in-up" style="margin: 0; min-height: 400px; display:flex; flex-direction:column; justify-content:flex-start;">
        <div class="card-title" style="margin-bottom:8px;">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="color:var(--accent)"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M21 9H3M21 15H3M12 3v18"/></svg>
            Leave by Department
        </div>
        <div style="font-size:11px; color:var(--muted); margin-bottom:16px;">Approved days of absence composition</div>
        <div id="leaveChartContainer" style="display:flex; flex-direction:column; gap:12px;">
            <div style="text-align:center; padding:40px; color:var(--muted); font-size:12px;">Loading leave analytics...</div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/tables.js" asp-append-version="true"></script>
<script src="~/js/modals.js" asp-append-version="true"></script>
<script>
    let allLeaves = [];

    (async function loadLeaves() {
        const res = await EmsApi.leave.list();
        if (res.success && res.data) {
            allLeaves = Array.isArray(res.data) ? res.data : (res.data.data || []);
            renderLeaves(allLeaves);
            updateLeaveKPIs(allLeaves);
            renderLeaveAnalytics(allLeaves);
        } else {
            document.getElementById('lvTableBody').innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;color:var(--accent4);">' + (res.error || 'Could not load leave requests') + '</td></tr>';
            document.getElementById('leaveChartContainer').innerHTML = '<div style="text-align:center; padding:40px; color:var(--accent4); font-size:12px;">Failed to load analytics</div>';
        }
        // Load department filter
        const deptRes = await EmsApi.config.get('departments');
        if (deptRes.success && Array.isArray(deptRes.data)) {
            const sel = document.getElementById('lvFilterDept');
            deptRes.data.forEach(d => { const o = document.createElement('option'); o.value = d.department_name || d.name; o.textContent = d.department_name || d.name; sel.appendChild(o); });
        }
    })();

    function renderLeaves(leaves) {
        const tbody = document.getElementById('lvTableBody');
        const pagInfo = document.getElementById('lvPagInfo');
        if (!leaves.length) {
            tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;color:var(--muted);">No leave requests found</td></tr>';
            if (pagInfo) pagInfo.textContent = 'No results';
            return;
        }
        tbody.innerHTML = leaves.map(lv => {
            const name = lv.employee_name || lv.employee_id || 'Employee';
            const initials = name.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase();
            const status = (lv.status || 'pending').toLowerCase();
            const statusClass = status === 'approved' ? 'approved' : status === 'rejected' ? 'rejected' : 'pending';
            const statusLabel = status.charAt(0).toUpperCase() + status.slice(1);
            const colors = ['blue','green','amber','purple','teal','red'];
            const ci = name.charCodeAt(0) % colors.length;
            const typeClass = (lv.leave_type_name || lv.leave_type || '').toLowerCase().includes('sick') ? 'tag-red' : (lv.leave_type_name || lv.leave_type || '').toLowerCase().includes('annual') ? 'tag-blue' : (lv.leave_type_name || lv.leave_type || '').toLowerCase().includes('emergency') ? 'tag-amber' : 'tag-green';
            const start = lv.start_date ? new Date(lv.start_date).toLocaleDateString('en-US',{month:'short',day:'numeric'}) : '—';
            const end = lv.end_date ? new Date(lv.end_date).toLocaleDateString('en-US',{month:'short',day:'numeric'}) : '—';
            const days = lv.total_days || (lv.start_date && lv.end_date ? Math.ceil((new Date(lv.end_date)-new Date(lv.start_date))/(86400000))+1 : '—');

            return `<tr>
                <td><div class="cell-employee"><div class="cell-avatar ${colors[ci]}">${initials}</div><div class="cell-name">${name}</div></div></td>
                <td><span class="cell-mono">${lv.employee_id || '—'}</span></td>
                <td>${lv.department_name || '—'}</td>
                <td><span class="tag ${typeClass}">${lv.leave_type_name || lv.leave_type || '—'}</span></td>
                <td><div style="white-space:nowrap;font-size:12px;">${start} – ${end}</div><div class="cell-sub">${days} day(s)</div></td>
                <td><span class="status-badge ${statusClass}">${statusLabel}</span></td>
                <td><span style="font-size:12px;color:var(--muted);max-width:140px;display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${lv.reason || '—'}</span></td>
                <td>
                    ${status === 'pending' ? `<div class="table-actions">
                        <button class="table-action-btn" title="Approve" onclick="approveLeave('${lv.id}')" style="color:var(--accent2);"><svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></button>
                        <button class="table-action-btn danger" title="Reject" onclick="rejectLeave('${lv.id}')"><svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
                    </div>` : '<span style="font-size:11px;color:var(--muted);">—</span>'}
                </td>
            </tr>`;
        }).join('');
        if (pagInfo) pagInfo.innerHTML = `Showing <strong>${leaves.length}</strong> of <strong>${allLeaves.length}</strong>`;
    }

    function updateLeaveKPIs(leaves) {
        const pending = leaves.filter(l => (l.status||'').toLowerCase() === 'pending').length;
        const approved = leaves.filter(l => (l.status||'').toLowerCase() === 'approved').length;
        const rejected = leaves.filter(l => (l.status||'').toLowerCase() === 'rejected').length;
        document.getElementById('lvPending').textContent = pending;
        document.getElementById('lvApproved').textContent = approved;
        document.getElementById('lvRejected').textContent = rejected;
        document.getElementById('lvToday').textContent = approved;
        document.getElementById('lvTodaySub').textContent = pending + ' pending · ' + approved + ' approved';
    }

    function renderLeaveAnalytics(leaves) {
        const approved = leaves.filter(l => (l.status||'').toLowerCase() === 'approved');
        const deptDays = {};
        let maxDays = 1;
        
        approved.forEach(lv => {
            const days = lv.total_days || (lv.start_date && lv.end_date ? Math.ceil((new Date(lv.end_date)-new Date(lv.start_date))/(86400000))+1 : 0);
            const dept = lv.department_name || 'Unassigned';
            deptDays[dept] = (deptDays[dept] || 0) + days;
        });

        const sortedDepts = Object.keys(deptDays).map(k => ({ name: k, days: deptDays[k] })).sort((a,b) => b.days - a.days);
        
        if (sortedDepts.length > 0) {
            maxDays = Math.max(...sortedDepts.map(d => d.days), 1);
        }

        const container = document.getElementById('leaveChartContainer');
        if (sortedDepts.length === 0) {
            container.innerHTML = '<div style="text-align:center; padding:40px; color:var(--muted); font-size:12px;">No approved leaves found.</div>';
            return;
        }

        const colors = ['#3b82f6', '#10b981', '#f59e0b', '#8b5cf6', '#ef4444'];
        
        container.innerHTML = sortedDepts.map((d, i) => {
            const pct = Math.max(5, (d.days / maxDays) * 100);
            return `<div style="display:flex; flex-direction:column; gap:4px; margin-bottom:8px;">
                <div style="display:flex; justify-content:space-between; font-size:11px;">
                    <span style="color:var(--foreground);">${d.name}</span>
                    <span style="color:var(--muted); font-family:'DM Mono', monospace;">${d.days} days</span>
                </div>
                <div style="height:6px; background:rgba(255,255,255,0.05); border-radius:3px; overflow:hidden;">
                    <div style="height:100%; width:${pct}%; background:${colors[i % colors.length]}; border-radius:3px; transition:width 0.8s ease;"></div>
                </div>
            </div>`;
        }).join('');
    }

    async function approveLeave(id) {
        const lv = allLeaves.find(l => l.id === id);
        showConfirm({
            title: 'Approve Leave Request?',
            message: `Are you sure you want to approve ${lv.employee_name}'s request for ${lv.leave_type_name}?`,
            type: 'success',
            confirmText: 'Yes, Approve',
            onConfirm: async function() {
                const res = await EmsApi.leave.approve(id);
                if (res.success) {
                    showToast('Leave approved successfully', 'success');
                    if (lv) lv.status = 'approved';
                    renderLeaves(allLeaves);
                    updateLeaveKPIs(allLeaves);
                } else {
                    showToast(res.error || 'Failed to approve', 'error');
                }
            }
        });
    }

    async function rejectLeave(id) {
        const lv = allLeaves.find(l => l.id === id);
        showConfirm({
            title: 'Reject Leave Request?',
            message: 'Please provide a reason for rejection:',
            type: 'warning',
            confirmText: 'Reject',
            showInput: true,
            inputPlaceholder: 'Reason for rejection...',
            onConfirm: async function(reason) {
                if (!reason) {
                    showToast('Rejection reason is required', 'error');
                    return;
                }
                const res = await EmsApi.leave.reject(id, reason);
                if (res.success) {
                    showToast('Leave request rejected', 'success');
                    if (lv) lv.status = 'rejected';
                    renderLeaves(allLeaves);
                    updateLeaveKPIs(allLeaves);
                } else {
                    showToast(res.error || 'Failed to reject', 'error');
                }
            }
        });
    }

    function filterLeaves() {
        const status = document.getElementById('lvFilterStatus').value;
        const dept = document.getElementById('lvFilterDept').value;
        const search = document.getElementById('lvSearch').value.toLowerCase();
        let filtered = allLeaves;
        if (status !== 'all') filtered = filtered.filter(l => (l.status||'').toLowerCase() === status);
        if (dept !== 'all') filtered = filtered.filter(l => (l.department_name||'').toLowerCase() === dept.toLowerCase());
        if (search) filtered = filtered.filter(l => (l.employee_name||'').toLowerCase().includes(search));
        renderLeaves(filtered);
    }
</script>
}
