@{ ViewData["Title"] = "Apply for Leave"; }

<div class="page-header anim-fade-in-up">
    <div>
        <h1 class="page-title"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg> Apply for Leave</h1>
        <div class="page-date">Submit a new leave request for approval</div>
    </div>
    <a class="btn btn-ghost" asp-action="Dashboard">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Back to Dashboard
    </a>
</div>

<div class="two-col staggered">
    <div class="card anim-fade-in-up">
        <div class="card-title">Leave Request Form</div>
        <form id="leaveForm" onsubmit="return handleLeaveSubmit(event)">
            <div class="field-group">
                <label class="field-label">Leave Type <span class="field-required">*</span></label>
                <select name="leave_type_id" id="leave_type_id" class="field-select" required onchange="updateBalanceDisplay()">
                    <option value="">Select Leave Type</option>
                </select>
            </div>
            
            <div class="form-grid form-grid-2">
                <div class="field-group">
                    <label class="field-label">Start Date <span class="field-required">*</span></label>
                    <input type="date" name="start_date" id="start_date" class="field-input" required />
                </div>
                <div class="field-group">
                    <label class="field-label">End Date <span class="field-required">*</span></label>
                    <input type="date" name="end_date" id="end_date" class="field-input" required />
                </div>
            </div>

            <div class="field-group">
                <label class="field-label">Reason / Remarks <span class="field-required">*</span></label>
                <textarea name="reason" class="field-textarea" rows="4" placeholder="Briefly explain the reason for leave" required></textarea>
            </div>

            <div style="margin-top:20px; display:flex; justify-content:flex-end;">
                <button type="submit" class="btn btn-primary" id="btnSubmit">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polyline points="22 2 15 22 11 13 2 9 22 2"/></svg>
                    Submit Request
                </button>
            </div>
        </form>
    </div>

    <div class="card anim-fade-in-up">
        <div class="card-title">My Leave Balances</div>
        <div id="balanceList" style="display:flex; flex-direction:column; gap:12px;">
            <div style="text-align:center; padding:20px; color:var(--muted);">Loading balances...</div>
        </div>
        
        <div class="form-divider" style="margin: 20px 0;"></div>
        
        <div class="info-alert" style="background:var(--surface2); border-radius:8px; padding:12px;">
            <div style="font-size:12px; font-weight:600; margin-bottom:4px; display:flex; align-items:center; gap:6px;">
                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                Important Note
            </div>
            <div style="font-size:11px; color:var(--muted); line-height:1.4;">
                All leave requests are subject to approval by your reporting manager. Please submit requests at least 2 days in advance.
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    let leaveBalances = [];

    async function loadData() {
        // Load Balances
        const balRes = await EmsApi.leave.getMyBalances();
        const list = document.getElementById('balanceList');
        if (balRes.success && Array.isArray(balRes.data)) {
            leaveBalances = balRes.data;
            list.innerHTML = leaveBalances.map(b => `
                <div style="display:flex; justify-content:space-between; align-items:center; padding:10px; background:var(--surface2); border-radius:8px;">
                    <div>
                        <div style="font-size:13px; font-weight:600;">${b.name}</div>
                        <div style="font-size:10px; color:var(--muted);">Used: ${b.used} / Total: ${b.balance}</div>
                    </div>
                    <div style="font-size:18px; font-weight:700; color:var(--accent);">${b.remaining}</div>
                </div>
            `).join('');

            // Populate Dropdown
            const sel = document.getElementById('leave_type_id');
            sel.innerHTML = '<option value="">Select Leave Type</option>' + 
                leaveBalances.map(b => `<option value="${b.leave_type_id}">${b.name} (${b.remaining} left)</option>`).join('');
        } else {
            list.innerHTML = '<div style="text-align:center; padding:20px; color:var(--muted);">No balances found</div>';
        }
    }

    async function handleLeaveSubmit(e) {
        e.preventDefault();
        const btn = document.getElementById('btnSubmit');
        const form = document.getElementById('leaveForm');
        const formData = new FormData(form);
        const data = {};
        formData.forEach((v, k) => data[k] = v);

        // Required field check with visual feedback
        let allValid = true;
        const requiredFields = form.querySelectorAll('[required]');
        requiredFields.forEach(f => {
            if (!f.value.trim()) {
                f.style.borderColor = 'var(--accent4)';
                allValid = false;
            } else {
                f.style.borderColor = '';
            }
        });

        if (!allValid) {
            showToast('Please fill the required field', 'error');
            return false;
        }

        // Logical validation
        if (new Date(data.start_date) > new Date(data.end_date)) {
            showToast('Start date cannot be after end date', 'error');
            return false;
        }

        btn.disabled = true;
        btn.textContent = 'Submitting...';

        const res = await EmsApi.leave.submit(data);
        if (res.success) {
            showToast('Leave request submitted successfully!', 'success');
            setTimeout(() => window.location.href = '/MyPortal/Dashboard', 1500);
        } else {
            btn.disabled = false;
            btn.innerHTML = '<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polyline points="22 2 15 22 11 13 2 9 22 2"/></svg> Submit Request';
            showToast(res.error || 'Failed to submit request', 'error');
        }
        return false;
    }

    loadData();
</script>
}
