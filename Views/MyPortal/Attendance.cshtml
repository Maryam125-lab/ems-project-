@{ ViewData["Title"] = "My Attendance"; }

<div class="page-header anim-fade-in-up">
    <div>
        <h1 class="page-title"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> My Attendance Log</h1>
        <div class="page-date">View your check-in and check-out history</div>
    </div>
    <button class="btn btn-ghost" onclick="downloadMyAttendanceCsv()">Download CSV</button>
</div>

<div class="table-container anim-fade-in-up">
    <div class="table-scroll-wrapper">
        <table class="data-table" id="attendanceTable">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Check In</th>
                    <th>Check Out</th>
                    <th>Work Hours</th>
                </tr>
            </thead>
            <tbody id="attendanceBody">
                <tr><td colspan="5" style="text-align:center; padding:40px; color:var(--muted);">Loading your attendance...</td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    let myAttendanceLogs = [];

    async function loadAttendance() {
        const res = await EmsApi.attendance.getMine();
        const tbody = document.getElementById('attendanceBody');
        
        if (res.success && res.data) {
            const logs = Array.isArray(res.data) ? res.data : [];
            myAttendanceLogs = logs;
            if (logs.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:40px; color:var(--muted);">No attendance records found yet.</td></tr>';
                return;
            }

            tbody.innerHTML = logs.map(l => {
                const status = l.status.toLowerCase();
                const statusClass = status === 'present' ? 'approved' : status === 'absent' ? 'rejected' : 'pending';
                const statusLabel = status.charAt(0).toUpperCase() + status.slice(1);
                
                // Calculate work hours if both check_in and check_out exist
                let workHours = '—';
                if (l.check_in && l.check_out) {
                    const start = new Date(`1970-01-01T${l.check_in}`);
                    const end = new Date(`1970-01-01T${l.check_out}`);
                    const diff = (end - start) / (1000 * 60 * 60);
                    workHours = diff.toFixed(2) + ' hrs';
                }

                return `
                    <tr>
                        <td class="cell-mono">${new Date(l.date).toLocaleDateString(undefined, { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' })}</td>
                        <td><span class="status-badge ${statusClass}">${statusLabel}</span></td>
                        <td class="cell-mono">${l.check_in || '—'}</td>
                        <td class="cell-mono">${l.check_out || '—'}</td>
                        <td class="cell-mono" style="font-weight:600;">${workHours}</td>
                    </tr>
                `;
            }).join('');
        } else {
            tbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:40px; color:var(--muted);">Failed to load attendance records.</td></tr>';
        }
    }

    function csvValue(value) {
        const text = String(value ?? '').replace(/"/g, '""');
        return `"${text}"`;
    }

    function calculateWorkHours(row) {
        if (!row.check_in || !row.check_out) return '-';
        const start = new Date(`1970-01-01T${row.check_in}`);
        const end = new Date(`1970-01-01T${row.check_out}`);
        const diff = (end - start) / (1000 * 60 * 60);
        return Number.isFinite(diff) ? `${diff.toFixed(2)} hrs` : '-';
    }

    function downloadMyAttendanceCsv() {
        if (!myAttendanceLogs.length) {
            showToast('No attendance data available to download', 'warning');
            return;
        }

        const header = ['Date', 'Status', 'Check In', 'Check Out', 'Work Hours'];
        const rows = myAttendanceLogs.map(row => [
            row.date,
            row.status,
            row.check_in || '-',
            row.check_out || '-',
            calculateWorkHours(row)
        ].map(csvValue).join(','));

        const csv = [header.map(csvValue).join(','), ...rows].join('\r\n');
        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = `My_Attendance_${new Date().toISOString().slice(0, 10)}.csv`;
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(link.href);
        showToast('Attendance file downloaded', 'success');
    }

    loadAttendance();
</script>
}
