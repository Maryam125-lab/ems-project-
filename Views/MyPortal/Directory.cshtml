@{ ViewData["Title"] = "Company Directory"; }

<div class="page-header anim-fade-in-up">
    <div>
        <h1 class="page-title"><svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg> Company Directory</h1>
        <div class="page-date">Find and connect with your colleagues</div>
    </div>
</div>

<div class="card anim-fade-in-up" style="margin-bottom: 20px;">
    <div class="filter-bar" style="padding: 0; border: none;">
        <div style="position:relative; flex:1;">
            <svg style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--muted);" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input class="filter-search" type="text" placeholder="Search by name, department or designation..." id="dirSearch" style="padding-left:40px; width:100%;" oninput="filterDirectory()" />
        </div>
    </div>
</div>

<div class="directory-grid" id="directoryGrid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap:20px;">
    <!-- Directory cards will be loaded here -->
    <div style="grid-column: 1/-1; text-align:center; padding:60px; color:var(--muted);">
        <div class="spinner" style="margin: 0 auto 16px;"></div>
        Loading directory...
    </div>
</div>

@section Scripts {
<script>
    let allEmployees = [];

    async function loadDirectory() {
        const res = await EmsApi.employees.list();
        if (res.success && Array.isArray(res.data)) {
            allEmployees = res.data;
            renderDirectory(allEmployees);
        } else {
            document.getElementById('directoryGrid').innerHTML = '<div style="grid-column: 1/-1; text-align:center; padding:60px; color:var(--muted);">Failed to load directory.</div>';
        }
    }

    function renderDirectory(employees) {
        const grid = document.getElementById('directoryGrid');
        if (employees.length === 0) {
            grid.innerHTML = '<div style="grid-column: 1/-1; text-align:center; padding:60px; color:var(--muted);">No colleagues found matching your search.</div>';
            return;
        }

        grid.innerHTML = employees.map(e => {
            const initials = e.name.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase();
            const colors = ['blue','green','amber','purple','teal','red'];
            const ci = e.name.charCodeAt(0) % colors.length;
            
            return `
                <div class="card employee-card anim-fade-in-up" style="padding:20px; transition: transform 0.2s; cursor:default;">
                    <div style="display:flex; align-items:center; gap:16px;">
                        <div class="cell-avatar ${colors[ci]}" style="width:60px; height:60px; font-size:20px;">${initials}</div>
                        <div style="flex:1;">
                            <div style="font-size:16px; font-weight:700; color:var(--text);">${e.name}</div>
                            <div style="font-size:12px; color:var(--accent); font-weight:600; margin-top:2px;">${e.designation_title || e.designation_name || 'Team Member'}</div>
                            <div style="font-size:11px; color:var(--muted); margin-top:1px;">${e.department_name || 'General'}</div>
                        </div>
                    </div>
                    <div class="form-divider" style="margin:16px 0;"></div>
                    <div style="display:flex; flex-direction:column; gap:8px;">
                        <div style="display:flex; align-items:center; gap:10px; font-size:12px; color:var(--muted);">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            ${e.email || 'N/A'}
                        </div>
                        <div style="display:flex; align-items:center; gap:10px; font-size:12px; color:var(--muted);">
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                            ${e.phone || 'N/A'}
                        </div>
                    </div>
                </div>
            `;
        }).join('');
    }

    function filterDirectory() {
        const q = document.getElementById('dirSearch').value.toLowerCase();
        const filtered = allEmployees.filter(e => 
            e.name.toLowerCase().includes(q) || 
            (e.designation_title && e.designation_title.toLowerCase().includes(q)) ||
            (e.designation_name && e.designation_name.toLowerCase().includes(q)) ||
            (e.department_name && e.department_name.toLowerCase().includes(q))
        );
        renderDirectory(filtered);
    }

    loadDirectory();
</script>
}

<style>
    .employee-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
        border-color: var(--accent);
    }
</style>
