@{ ViewData["Title"] = "My Payslips"; }
<div class="page-header anim-fade-in-up">
    <div><h1 class="page-title"><i class="fa-solid fa-money-bill-wave" aria-hidden="true"></i> My Payslips</h1><div class="page-date">View and download your monthly payslips</div></div>
</div>
<div class="card anim-fade-in-up" style="margin-bottom:16px;">
    <div class="card-title">Latest Payslip – April 2026</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;font-size:13px;">
        <div><span style="color:var(--muted);font-size:11px;display:block;">Basic Salary</span><strong class="cell-mono" style="font-size:15px;">PKR 120,000</strong></div>
        <div><span style="color:var(--muted);font-size:11px;display:block;">House Rent</span><span style="color:var(--accent2);font-family:'DM Mono',monospace;">+15,000</span></div>
        <div><span style="color:var(--muted);font-size:11px;display:block;">Transport</span><span style="color:var(--accent2);font-family:'DM Mono',monospace;">+10,000</span></div>
        <div><span style="color:var(--muted);font-size:11px;display:block;">Tax Deduction</span><span style="color:var(--accent4);font-family:'DM Mono',monospace;">-12,000</span></div>
        <div><span style="color:var(--muted);font-size:11px;display:block;">Provident Fund</span><span style="color:var(--accent4);font-family:'DM Mono',monospace;">-6,500</span></div>
        <div style="background:var(--accent-light);padding:12px;border-radius:10px;"><span style="color:var(--accent);font-size:11px;display:block;font-weight:700;">NET PAYABLE</span><strong style="font-size:20px;font-family:'DM Mono',monospace;color:var(--accent);">PKR 126,500</strong></div>
    </div>
    <div style="margin-top:16px;display:flex;gap:8px;"><button class="btn btn-outline" onclick="showToast('PDF Downloaded','success')">Download PDF</button><button class="btn btn-ghost">Print</button></div>
</div>
<div class="card anim-fade-in-up">
    <div class="card-title">Payslip History</div>
    <table class="data-table"><thead><tr><th>Month</th><th>Basic</th><th>Gross</th><th>Deductions</th><th>Net Pay</th><th>Action</th></tr></thead>
    <tbody>
        <tr><td><strong>April 2026</strong></td><td class="cell-mono">120,000</td><td class="cell-mono">145,000</td><td class="cell-mono" style="color:var(--accent4)">-18,500</td><td><strong class="cell-mono">126,500</strong></td><td><button class="btn btn-sm btn-outline" onclick="showToast('Downloaded','success')">PDF</button></td></tr>
        <tr><td><strong>March 2026</strong></td><td class="cell-mono">120,000</td><td class="cell-mono">145,000</td><td class="cell-mono" style="color:var(--accent4)">-18,500</td><td><strong class="cell-mono">126,500</strong></td><td><button class="btn btn-sm btn-outline">PDF</button></td></tr>
        <tr><td><strong>February 2026</strong></td><td class="cell-mono">120,000</td><td class="cell-mono">145,000</td><td class="cell-mono" style="color:var(--accent4)">-19,000</td><td><strong class="cell-mono">126,000</strong></td><td><button class="btn btn-sm btn-outline">PDF</button></td></tr>
    </tbody></table>
</div>
