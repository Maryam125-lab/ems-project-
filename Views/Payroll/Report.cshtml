@{
    ViewData["Title"] = "Payroll Report";
    ViewData["Active"] = "Payroll";
}

<!-- PAGE HEADER -->
<div class="page-header anim-fade-in-up">
    <div>
        <h1 class="page-title">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <line x1="12" y1="1" x2="12" y2="23" />
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
            </svg>
            Payroll Report
        </h1>
        <div class="page-date">Monthly salary breakdown by department and employee</div>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
        <button class="btn btn-primary" onclick="exportCSV()">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            Export CSV
        </button>
        <button class="btn btn-primary" onclick="printReport()">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <polyline points="6 9 6 2 18 2 18 9" />
                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                <rect x="6" y="14" width="12" height="8" />
            </svg>
            Print
        </button>
    </div>
</div>

<!-- FILTERS -->
<div class="card anim-fade-in-up" style="margin-bottom:20px;">
    <div class="card-body" style="padding:16px 20px;">
        <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:12px;align-items:end;">
            <div>
                <label class="form-label">Month</label>
                <select class="form-select" id="filterMonth">
                    <option value="1">January</option>
                    <option value="2">February</option>
                    <option value="3">March</option>
                    <option value="4">April</option>
                    <option value="5">May</option>
                    <option value="6">June</option>
                    <option value="7">July</option>
                    <option value="8">August</option>
                    <option value="9">September</option>
                    <option value="10">October</option>
                    <option value="11">November</option>
                    <option value="12">December</option>
                </select>
            </div>
            <div>
                <label class="form-label">Year</label>
                <select class="form-select" id="filterYear">
                    <option value="2026">2026</option>
                    <option value="2025">2025</option>
                    <option value="2024">2024</option>
                </select>
            </div>
            <div>
                <label class="form-label">Department</label>
                <select class="form-select" id="filterDept">
                    <option value="">All Departments</option>
                </select>
            </div>
            <div>
                <label class="form-label">Status</label>
                <select class="form-select" id="filterStatus">
                    <option value="">All</option>
                    <option value="pending">Pending</option>
                    <option value="processed">Processed</option>
                </select>
            </div>
            <div>
                <button class="btn btn-primary" style="width:100%;" onclick="loadReport()">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                    Generate Report
                </button>
            </div>
        </div>
    </div>
</div>

<!-- KPI SUMMARY CARDS -->
<div class="kpi-grid stagger" style="grid-template-columns:repeat(5,1fr);margin-bottom:20px;" id="kpiSection"
     style="display:none;">
    <div class="stat-card blue">
        <div class="kpi-label">Total Employees</div>
        <div class="kpi-num" id="kpiEmployees">--</div>
        <div class="kpi-sub">In this period</div>
    </div>
    <div class="stat-card green">
        <div class="kpi-label">Total Basic</div>
        <div class="kpi-num" id="kpiBasic">--</div>
        <div class="kpi-sub">Basic salaries</div>
    </div>
    <div class="stat-card purple">
        <div class="kpi-label">Total Allowances</div>
        <div class="kpi-num" id="kpiAllowances">--</div>
        <div class="kpi-sub">All allowances</div>
    </div>
    <div class="stat-card amber">
        <div class="kpi-label">Total Deductions</div>
        <div class="kpi-num" id="kpiDeductions">--</div>
        <div class="kpi-sub">Penalties etc.</div>
    </div>
    <div class="stat-card green">
        <div class="kpi-label">Net Payroll</div>
        <div class="kpi-num" id="kpiNet">--</div>
        <div class="kpi-sub" id="kpiNetSub">--</div>
    </div>
</div>

<!-- REPORT TABLE -->
<div class="card anim-fade-in-up" id="reportSection" style="display:none;">
    <div class="card-header" style="display:flex;justify-content:space-between;align-items:center;">
        <span style="font-weight:600;font-size:14px;">Payroll Details</span>
        <span style="font-size:12px;color:var(--muted);" id="reportMeta"></span>
    </div>
    <div class="table-wrap">
        <table class="data-table" id="reportTable">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Employee ID</th>
                    <th>Employee Name</th>
                    <th>Department</th>
                    <th>Designation</th>
                    <th style="text-align:right;">Basic Salary</th>
                    <th style="text-align:right;">Allowances</th>
                    <th style="text-align:right;">Deductions</th>
                    <th style="text-align:right;">Net Salary</th>
                    <th style="text-align:center;">Status</th>
                </tr>
            </thead>
            <tbody id="reportBody">
                <tr>
                    <td colspan="10" style="text-align:center;padding:40px;color:var(--muted);">
                        Select filters and click Generate Report
                    </td>
                </tr>
            </tbody>
            <tfoot id="reportFoot" style="display:none;">
                <tr style="font-weight:700;background:var(--hover);">
                    <td colspan="5" style="padding:10px 12px;">TOTAL</td>
                    <td style="text-align:right;padding:10px 12px;" id="footBasic"></td>
                    <td style="text-align:right;padding:10px 12px;" id="footAllowances"></td>
                    <td style="text-align:right;padding:10px 12px;" id="footDeductions"></td>
                    <td style="text-align:right;padding:10px 12px;" id="footNet"></td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<!-- EMPTY STATE -->
<div id="emptyState" style="display:none;text-align:center;padding:60px 20px;">
    <svg width="48" height="48" fill="none" stroke="var(--muted)" stroke-width="1.5" viewBox="0 0 24 24"
         style="margin-bottom:12px;">
        <line x1="12" y1="1" x2="12" y2="23" />
        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
    </svg>
    <div style="font-size:15px;font-weight:600;color:var(--text);margin-bottom:6px;">No Records Found</div>
    <div style="font-size:13px;color:var(--muted);">No payroll records for selected period. Please generate payroll
        first.</div>
    </div>

    @section Scripts {
        <script>
            // ── Auth & Role Check (Employees cannot access) ──
            EmsApi.requireAuth();
            const _role = EmsApi.getRoleName();
            if (_role === 'employee') {
                window.location.href = '/MyPortal/Dashboard';
            }

            const MONTHS = ['', 'January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

            function fmt(n) {
                return 'PKR ' + Number(n || 0).toLocaleString('en-PK', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
            }

            function statusBadge(s) {
                if (s === 'processed') return '<span style="background:rgba(5,150,105,0.1);color:#059669;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:600;">Processed</span>';
                return '<span style="background:rgba(217,119,6,0.1);color:#d97706;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:600;">Pending</span>';
            }

            // ── Load Departments for filter ──
            async function loadDepts() {
                const res = await EmsApi.config.get('departments');
                const sel = document.getElementById('filterDept');
                if (res.success && Array.isArray(res.data)) {
                    res.data.forEach(d => {
                        const opt = document.createElement('option');
                        opt.value = d.id;
                        opt.textContent = d.department_name;
                        sel.appendChild(opt);
                    });
                }
            }

            // ── Set current month/year as default ──
            function setDefaults() {
                const now = new Date();
                document.getElementById('filterMonth').value = now.getMonth() + 1;
                document.getElementById('filterYear').value = now.getFullYear();
            }

            // ── Load Report ──
            async function loadReport() {
                const month = document.getElementById('filterMonth').value;
                const year = document.getElementById('filterYear').value;
                const dept = document.getElementById('filterDept').value;
                const status = document.getElementById('filterStatus').value;

                const tbody = document.getElementById('reportBody');
                tbody.innerHTML = `<tr><td colspan="10" style="text-align:center;padding:40px;color:var(--muted);">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="animation:spin 1s linear infinite;"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
                    Loading...
                </td></tr>`;

                let url = `/api/payroll/report?month=${month}&year=${year}`;
                if (dept) url += `&department_id=${dept}`;
                if (status) url += `&status=${status}`;

                const res = await EmsApi.get(url);

                document.getElementById('emptyState').style.display = 'none';
                document.getElementById('reportSection').style.display = 'none';
                document.getElementById('kpiSection').style.display = 'none';

                if (!res.success) {
                    tbody.innerHTML = `<tr><td colspan="10" style="text-align:center;padding:40px;color:var(--accent4);">Error: ${res.error}</td></tr>`;
                    return;
                }

                const { records, summary } = res.data;

                if (!records || records.length === 0) {
                    document.getElementById('emptyState').style.display = 'block';
                    return;
                }

                // KPI Cards update
                document.getElementById('kpiSection').style.display = 'grid';
                document.getElementById('kpiEmployees').textContent = summary.total_employees;
                document.getElementById('kpiBasic').textContent = fmt(summary.total_basic);
                document.getElementById('kpiAllowances').textContent = fmt(summary.total_allowances);
                document.getElementById('kpiDeductions').textContent = fmt(summary.total_deductions);
                document.getElementById('kpiNet').textContent = fmt(summary.total_net);
                document.getElementById('kpiNetSub').textContent = `${summary.processed_count} processed, ${summary.pending_count} pending`;

                // Table
                document.getElementById('reportSection').style.display = 'block';
                document.getElementById('reportMeta').textContent = `${MONTHS[month]} ${year} — ${records.length} records`;

                tbody.innerHTML = records.map((r, i) => `
                    <tr>
                        <td>${i + 1}</td>
                        <td><span style="font-family:monospace;font-size:12px;">${r.employee_id}</span></td>
                        <td style="font-weight:500;">${r.employee_name || '--'}</td>
                        <td>${r.department_name || '--'}</td>
                        <td>${r.designation_title || '--'}</td>
                        <td style="text-align:right;">${fmt(r.basic_salary)}</td>
                        <td style="text-align:right;">${fmt(r.allowances)}</td>
                        <td style="text-align:right;color:var(--accent4);">${fmt(r.deductions)}</td>
                        <td style="text-align:right;font-weight:600;color:var(--accent2);">${fmt(r.net_salary)}</td>
                        <td style="text-align:center;">${statusBadge(r.status)}</td>
                    </tr>
                `).join('');

                // Footer totals
                document.getElementById('reportFoot').style.display = '';
                document.getElementById('footBasic').textContent = fmt(summary.total_basic);
                document.getElementById('footAllowances').textContent = fmt(summary.total_allowances);
                document.getElementById('footDeductions').textContent = fmt(summary.total_deductions);
                document.getElementById('footNet').textContent = fmt(summary.total_net);
            }

            // ── Export CSV ──
            function exportCSV() {
                const rows = document.querySelectorAll('#reportTable tbody tr');
                if (!rows.length || rows[0].cells.length === 1) {
                    alert('Pehle report generate karein.');
                    return;
                }
                const month = document.getElementById('filterMonth').value;
                const year = document.getElementById('filterYear').value;

                let csv = 'Sr,Employee ID,Employee Name,Department,Designation,Basic Salary,Allowances,Deductions,Net Salary,Status\n';
                rows.forEach(row => {
                    const cells = Array.from(row.cells).map(c => `"${c.innerText.trim()}"`);
                    csv += cells.join(',') + '\n';
                });

                const blob = new Blob([csv], { type: 'text/csv' });
                const a = document.createElement('a');
                a.href = URL.createObjectURL(blob);
                a.download = `Payroll_Report_${MONTHS[month]}_${year}.csv`;
                a.click();
            }

            // ── Print ──
            function printReport() {
                window.print();
            }

            // ── Init ──
            setDefaults();
            loadDepts();
        </script>
    }