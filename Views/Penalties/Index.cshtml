@{
    ViewData["Title"] = "Penalties";
    ViewData["Active"] = "Penalties";
}

<div class="page-header anim-fade-in-up">
    <div>
        <h1 class="page-title">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
            Penalty & Fine Engine
        </h1>
        <div class="page-date">Track and manage employee penalties with database-backed approval flow</div>
    </div>
    <button class="btn btn-primary" onclick="openModal('applyPenaltyModal')">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Apply Penalty
    </button>
</div>

<div class="kpi-grid stagger" style="grid-template-columns: repeat(4, 1fr); margin-bottom: 20px;">
    <div class="stat-card red">
        <div class="kpi-label">Approved Fines</div>
        <div class="kpi-num" style="color:var(--accent4)" id="kpiPenTotal">-</div>
        <div class="kpi-sub">PKR approved total</div>
    </div>
    <div class="stat-card amber">
        <div class="kpi-label">Pending Approval</div>
        <div class="kpi-num" style="color:var(--accent3)" id="kpiPenPending">-</div>
        <div class="kpi-sub">Awaiting review</div>
    </div>
    <div class="stat-card green">
        <div class="kpi-label">Approved</div>
        <div class="kpi-num" style="color:var(--accent2)" id="kpiPenApproved">-</div>
        <div class="kpi-sub">Applied records</div>
    </div>
    <div class="stat-card blue">
        <div class="kpi-label">Employees Affected</div>
        <div class="kpi-num" id="kpiPenAffected">-</div>
        <div class="kpi-sub">Unique employees</div>
    </div>
</div>

<div class="table-container anim-fade-in-up">
    <div class="filter-bar">
        <div class="filter-group">
            <label class="filter-label">Status</label>
            <select class="filter-select" onchange="filterTableByColumn('penaltyTable', 4, this.value)">
                <option value="all">All</option>
                <option value="Approved">Approved</option>
                <option value="Pending">Pending</option>
                <option value="Rejected">Rejected</option>
            </select>
        </div>
        <input class="filter-search" type="text" placeholder="Search penalties..." id="penSearch" oninput="filterTable('penaltyTable','penSearch')" />
    </div>

    <div class="table-scroll-wrapper">
        <table class="data-table" id="penaltyTable">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Date</th>
                    <th>Penalty Rule</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th>Proposed By</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="penaltyTableBody">
                <tr><td colspan="7" style="text-align:center;padding:40px;color:var(--muted);">Loading penalties...</td></tr>
            </tbody>
        </table>
    </div>

    <div class="table-pagination">
        <div class="pagination-info" id="penPagInfo">Loading...</div>
    </div>
</div>

<div class="modal-backdrop" id="applyPenaltyModal">
    <div class="modal-dialog">
        <div class="modal-header">
            <div class="modal-title">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                    <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                Apply Penalty
            </div>
            <button class="modal-close" onclick="closeModal('applyPenaltyModal')">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <div class="modal-body">
            <div class="form-grid form-grid-2">
                <div class="field-group">
                    <label class="field-label">Employee <span class="field-required">*</span></label>
                    <select class="field-select" id="penEmpId" required>
                        <option value="">Loading employees...</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Penalty Rule <span class="field-required">*</span></label>
                    <select class="field-select" id="penRuleId" required onchange="onRuleChange()">
                        <option value="">Loading rules...</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">Date</label>
                    <input type="date" class="field-input" id="penDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                </div>
                <div class="field-group">
                    <label class="field-label">Amount (PKR)</label>
                    <input type="number" class="field-input" id="penAmount" readonly placeholder="Auto-filled from rule" />
                </div>
                <div class="field-group form-full">
                    <label class="field-label">Remarks</label>
                    <textarea class="field-textarea" id="penRemarks" rows="2" placeholder="Additional notes (optional)"></textarea>
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="closeModal('applyPenaltyModal')">Cancel</button>
            <button class="btn btn-danger" id="btnApplyPen" onclick="savePenalty()">Apply Penalty</button>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/tables.js" asp-append-version="true"></script>
<script src="~/js/modals.js" asp-append-version="true"></script>
<script>
    let allPenalties = [];
    let penaltyRules = [];

    document.addEventListener('DOMContentLoaded', initPenalties);

    async function initPenalties() {
        await Promise.allSettled([loadPenalties(), loadPenaltyEmployees(), loadPenaltyRules()]);
    }

    async function loadPenalties() {
        const res = await EmsApi.penalties.list();
        const tbody = document.getElementById('penaltyTableBody');
        if (!res.success) {
            tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:40px;color:#dc2626;">${escapeHtml(res.error || 'Unable to load penalties')}</td></tr>`;
            return;
        }
        allPenalties = Array.isArray(res.data) ? res.data : (res.data?.data || []);
        renderPenalties(allPenalties);
        updatePenaltyKPIs(allPenalties);
    }

    async function loadPenaltyEmployees() {
        const res = await EmsApi.employees.list();
        const sel = document.getElementById('penEmpId');
        if (!res.success) {
            sel.innerHTML = '<option value="">Unable to load employees</option>';
            return;
        }
        const rows = Array.isArray(res.data) ? res.data : (res.data?.data || []);
        sel.innerHTML = '<option value="">Select Employee</option>' + rows.map(e =>
            `<option value="${escapeAttr(e.employee_id)}">${escapeHtml(e.name)} (${escapeHtml(e.employee_id)})</option>`
        ).join('');
    }

    async function loadPenaltyRules() {
        const res = await EmsApi.penalties.getRules();
        const sel = document.getElementById('penRuleId');
        if (!res.success) {
            sel.innerHTML = '<option value="">Unable to load rules</option>';
            return;
        }
        penaltyRules = Array.isArray(res.data) ? res.data.filter(r => r.is_active !== false) : [];
        if (!penaltyRules.length) {
            sel.innerHTML = '<option value="">No active rules found</option>';
            showToast('Please add penalty rules in Configuration before applying penalties.', 'warning');
            return;
        }
        sel.innerHTML = '<option value="">Select Rule</option>' + penaltyRules.map(r => {
            const name = r.name || r.rule_name || 'Penalty Rule';
            const amount = r.amount_pkr ?? r.amount ?? 0;
            return `<option value="${escapeAttr(r.id)}" data-amount="${escapeAttr(amount)}" data-type="${escapeAttr(name)}">${escapeHtml(name)} - PKR ${Number(amount).toLocaleString()}</option>`;
        }).join('');
    }

    function onRuleChange() {
        const sel = document.getElementById('penRuleId');
        const opt = sel.options[sel.selectedIndex];
        document.getElementById('penAmount').value = opt?.dataset?.amount || '';
    }

    function renderPenalties(data) {
        const tbody = document.getElementById('penaltyTableBody');
        const pagInfo = document.getElementById('penPagInfo');
        if (!data.length) {
            tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;padding:40px;color:var(--muted);">No penalty records found.</td></tr>';
            if (pagInfo) pagInfo.textContent = 'No records';
            return;
        }

        tbody.innerHTML = data.map(pen => {
            const name = pen.employee_name || pen.name || pen.employee_id || 'Employee';
            const initials = name.split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
            const colors = ['blue', 'green', 'amber', 'purple', 'teal', 'red'];
            const color = colors[name.charCodeAt(0) % colors.length];
            const status = (pen.status || 'pending').toLowerCase();
            const statusClass = status === 'approved' ? 'approved' : status === 'rejected' ? 'rejected' : 'pending';
            const statusLabel = status.charAt(0).toUpperCase() + status.slice(1);
            const amount = pen.amount_pkr ?? pen.amount ?? 0;
            return `<tr>
                <td><div class="cell-employee"><div class="cell-avatar ${color}">${escapeHtml(initials)}</div><div><div class="cell-name">${escapeHtml(name)}</div><div style="font-size:11px;color:var(--muted);">${escapeHtml(pen.employee_id || '')}</div></div></div></td>
                <td><span class="cell-mono" style="font-size:11px;">${pen.date ? new Date(pen.date).toLocaleDateString() : '-'}</span></td>
                <td><span class="tag tag-amber">${escapeHtml(pen.rule_name || pen.penalty_type || '-')}</span></td>
                <td><strong style="font-family:'DM Mono',monospace;color:var(--accent4);">PKR ${Number(amount).toLocaleString()}</strong></td>
                <td><span class="status-badge ${statusClass}">${statusLabel}</span></td>
                <td><span style="font-size:12px;color:var(--muted);">${escapeHtml(pen.proposed_by || pen.applied_by_name || '-')}</span></td>
                <td>${status === 'pending' ? `<div class="table-actions">
                    <button class="table-action-btn" title="Approve" style="color:var(--accent2);" onclick="approvePenalty('${escapeAttr(pen.id)}')"><svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></button>
                    <button class="table-action-btn danger" title="Reject" onclick="rejectPenalty('${escapeAttr(pen.id)}')"><svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
                </div>` : '<span style="font-size:11px;color:var(--muted);">-</span>'}</td>
            </tr>`;
        }).join('');
        if (pagInfo) pagInfo.innerHTML = `Showing <strong>${data.length}</strong> records`;
    }

    function updatePenaltyKPIs(data) {
        const pending = data.filter(p => (p.status || '').toLowerCase() === 'pending').length;
        const approved = data.filter(p => (p.status || '').toLowerCase() === 'approved').length;
        const totalAmt = data.filter(p => (p.status || '').toLowerCase() === 'approved')
            .reduce((sum, p) => sum + Number(p.amount_pkr ?? p.amount ?? 0), 0);
        const affected = [...new Set(data.map(p => p.employee_id).filter(Boolean))].length;
        document.getElementById('kpiPenTotal').textContent = totalAmt > 0 ? (totalAmt / 1000).toFixed(1) + 'K' : '-';
        document.getElementById('kpiPenPending').textContent = pending;
        document.getElementById('kpiPenApproved').textContent = approved;
        document.getElementById('kpiPenAffected').textContent = affected;
    }

    async function savePenalty() {
        const employeeId = document.getElementById('penEmpId').value;
        const ruleSel = document.getElementById('penRuleId');
        const ruleId = ruleSel.value;
        const ruleOpt = ruleSel.options[ruleSel.selectedIndex];
        const date = document.getElementById('penDate').value;
        const remarks = document.getElementById('penRemarks').value;
        if (!employeeId || !ruleId) {
            showToast('Employee and penalty rule are required', 'error');
            return;
        }

        const btn = document.getElementById('btnApplyPen');
        btn.disabled = true;
        btn.textContent = 'Applying...';
        const res = await EmsApi.penalties.propose({
            employee_id: employeeId,
            rule_id: ruleId,
            date: date || new Date().toISOString().split('T')[0],
            reason: remarks || ruleOpt?.dataset?.type || 'Penalty'
        });
        btn.disabled = false;
        btn.textContent = 'Apply Penalty';

        if (!res.success) {
            showToast(res.error || 'Unable to save penalty in database', 'error');
            return;
        }

        closeModal('applyPenaltyModal');
        showToast('Penalty saved and sent for approval', 'success');
        await loadPenalties();
    }

    async function approvePenalty(id) {
        const res = await EmsApi.penalties.approve(id);
        if (!res.success) {
            showToast(res.error || 'Unable to approve penalty', 'error');
            return;
        }
        showToast('Penalty approved', 'success');
        await loadPenalties();
    }

    async function rejectPenalty(id) {
        showConfirm({
            title: 'Reject Penalty?',
            message: 'This will reject the selected penalty.',
            type: 'warning',
            confirmText: 'Reject',
            onConfirm: async () => {
                const res = await EmsApi.penalties.reject(id);
                if (!res.success) {
                    showToast(res.error || 'Unable to reject penalty', 'error');
                    return;
                }
                showToast('Penalty rejected', 'success');
                await loadPenalties();
            }
        });
    }

    function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function escapeAttr(value) {
        return escapeHtml(value).replace(/`/g, '&#96;');
    }
</script>
}
