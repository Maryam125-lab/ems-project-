@{
    ViewData["Title"] = "Promotions";
    ViewData["Active"] = "Promotions";
}

<div class="page-header anim-fade-in-up">
    <div>
        <h1 class="page-title">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            Promotions & Transitions
        </h1>
        <div class="page-date">Record role changes, department transfers, salary revisions, and approval status</div>
    </div>
    <button class="btn btn-primary" onclick="openModal('promoModal')">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Record Promotion
    </button>
</div>

<div class="kpi-grid stagger" style="grid-template-columns: repeat(3, 1fr); margin-bottom: 20px;">
    <div class="stat-card blue"><div class="kpi-label">Total Promotions</div><div class="kpi-num" id="promoTotal">-</div><div class="kpi-sub">Live DB records</div></div>
    <div class="stat-card amber"><div class="kpi-label">Pending</div><div class="kpi-num" id="promoPending">-</div><div class="kpi-sub">Awaiting approval</div></div>
    <div class="stat-card green"><div class="kpi-label">Approved</div><div class="kpi-num" id="promoApproved">-</div><div class="kpi-sub">Applied transitions</div></div>
</div>

<div class="table-container anim-fade-in-up">
    <div class="filter-bar">
        <input class="filter-search" type="text" placeholder="Search promotions..." id="promoSearch" oninput="filterTable('promoTable','promoSearch')" />
    </div>
    <div class="table-scroll-wrapper">
        <table class="data-table" id="promoTable">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>From Designation</th>
                    <th>To Designation</th>
                    <th>Department</th>
                    <th>Effective Date</th>
                    <th>Approved By</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="promoTableBody">
                <tr><td colspan="8" style="text-align:center;padding:40px;color:var(--muted);">Loading promotions...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="table-pagination">
        <div class="pagination-info" id="promoPagInfo">Loading...</div>
    </div>
</div>

<div class="modal-backdrop" id="promoModal">
    <div class="modal-dialog">
        <div class="modal-header">
            <div class="modal-title">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                Record Promotion
            </div>
            <button class="modal-close" onclick="closeModal('promoModal')"><svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
        </div>
        <div class="modal-body">
            <div class="form-grid form-grid-2">
                <div class="field-group form-full">
                    <label class="field-label">Employee <span class="field-required">*</span></label>
                    <select class="field-select" id="promoEmployeeId"><option value="">Loading employees...</option></select>
                </div>
                <div class="field-group"><label class="field-label">From Designation</label><input type="text" class="field-input" id="promoFromDesg" readonly /></div>
                <div class="field-group"><label class="field-label">To Designation <span class="field-required">*</span></label><select class="field-select" id="promoToDesg"><option value="">Loading...</option></select></div>
                <div class="field-group"><label class="field-label">From Department</label><input type="text" class="field-input" id="promoFromDept" readonly /></div>
                <div class="field-group"><label class="field-label">To Department</label><select class="field-select" id="promoToDept"><option value="">Same Department</option></select></div>
                <div class="field-group"><label class="field-label">Effective Date <span class="field-required">*</span></label><input type="date" class="field-input" id="promoDate" /></div>
                <div class="field-group"><label class="field-label">Salary Revision (PKR)</label><input type="number" class="field-input" id="promoSalary" placeholder="New basic salary" /></div>
                <div class="field-group form-full"><label class="field-label">Remarks</label><textarea class="field-textarea" id="promoRemarks" rows="2" placeholder="Reason for promotion"></textarea></div>
            </div>
        </div>
        <div class="modal-footer">
            <button class="btn btn-ghost" onclick="closeModal('promoModal')">Cancel</button>
            <button class="btn btn-success" id="btnSavePromo" onclick="savePromotion()">Save Promotion</button>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/tables.js" asp-append-version="true"></script>
<script src="~/js/modals.js" asp-append-version="true"></script>
<script>
    let allPromotions = [];

    document.addEventListener('DOMContentLoaded', async () => {
        await Promise.allSettled([loadPromotionLookups(), loadPromotions()]);
    });

    async function loadPromotionLookups() {
        const [empRes, desgRes, deptRes] = await Promise.allSettled([
            EmsApi.employees.list(),
            EmsApi.config.get('designations'),
            EmsApi.config.get('departments')
        ]);
        const empSel = document.getElementById('promoEmployeeId');
        const desgSel = document.getElementById('promoToDesg');
        const deptSel = document.getElementById('promoToDept');
        const employees = empRes.value?.success ? (Array.isArray(empRes.value.data) ? empRes.value.data : empRes.value.data?.data || []) : [];
        const designations = desgRes.value?.success ? desgRes.value.data : [];
        const departments = deptRes.value?.success ? deptRes.value.data : [];

        empSel.innerHTML = '<option value="">Select Employee</option>' + employees.map(e => `
            <option value="${escapeAttr(e.employee_id)}" data-desg="${escapeAttr(e.designation_title || '')}" data-dept="${escapeAttr(e.department_name || '')}" data-desg-id="${escapeAttr(e.designation_id || '')}" data-dept-id="${escapeAttr(e.department_id || '')}">
                ${escapeHtml(e.name)} (${escapeHtml(e.employee_id)})
            </option>
        `).join('');
        desgSel.innerHTML = '<option value="">Select Designation</option>' + designations.map(d => `<option value="${escapeAttr(d.id)}">${escapeHtml(d.title || d.name)}</option>`).join('');
        deptSel.innerHTML = '<option value="">Same Department</option>' + departments.map(d => `<option value="${escapeAttr(d.id)}">${escapeHtml(d.department_name || d.name)}</option>`).join('');
    }

    document.getElementById('promoEmployeeId').addEventListener('change', function () {
        const opt = this.options[this.selectedIndex];
        document.getElementById('promoFromDesg').value = opt?.dataset?.desg || '';
        document.getElementById('promoFromDept').value = opt?.dataset?.dept || '';
    });

    async function loadPromotions() {
        const tbody = document.getElementById('promoTableBody');
        tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;color:var(--muted);">Loading promotions...</td></tr>';
        const res = await EmsApi.promotions.list();
        if (!res.success) {
            tbody.innerHTML = `<tr><td colspan="8" style="text-align:center;padding:40px;color:#dc2626;">${escapeHtml(res.error || 'Unable to load promotions')}</td></tr>`;
            return;
        }
        allPromotions = Array.isArray(res.data) ? res.data : (res.data?.data || []);
        renderPromotionKpis(allPromotions);
        renderPromotions(allPromotions);
    }

    function renderPromotionKpis(rows) {
        document.getElementById('promoTotal').textContent = rows.length;
        document.getElementById('promoPending').textContent = rows.filter(x => String(x.status || '').toLowerCase() === 'pending').length;
        document.getElementById('promoApproved').textContent = rows.filter(x => String(x.status || '').toLowerCase() === 'approved').length;
    }

    function renderPromotions(rows) {
        const tbody = document.getElementById('promoTableBody');
        const pagInfo = document.getElementById('promoPagInfo');
        if (!rows.length) {
            tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;color:var(--muted);">No promotion records found.</td></tr>';
            pagInfo.textContent = 'No records';
            return;
        }
        tbody.innerHTML = rows.map(p => {
            const name = p.employee_name || p.name || p.employee_id || 'Employee';
            const status = String(p.status || 'pending').toLowerCase();
            const statusClass = status === 'approved' ? 'approved' : status === 'rejected' ? 'rejected' : 'pending';
            return `<tr>
                <td><strong>${escapeHtml(name)}</strong><div style="font-size:11px;color:var(--muted);">${escapeHtml(p.employee_id || '')}</div></td>
                <td>${escapeHtml(p.from_designation_title || p.from_designation || p.curr_designation || '-')}</td>
                <td><strong>${escapeHtml(p.to_designation_title || p.to_designation || '-')}</strong></td>
                <td>${escapeHtml(p.department_name || p.to_department || p.from_department || p.curr_department || '-')}</td>
                <td><span class="cell-mono" style="font-size:11px;">${p.effective_date ? new Date(p.effective_date).toLocaleDateString() : '-'}</span></td>
                <td>${escapeHtml(p.approved_by_name || '-')}</td>
                <td><span class="status-badge ${statusClass}">${escapeHtml(status.charAt(0).toUpperCase() + status.slice(1))}</span></td>
                <td>${status === 'pending' ? `<div class="table-actions"><button class="table-action-btn" title="Approve" style="color:var(--accent2);" onclick="approvePromotion('${escapeAttr(p.id)}')"><svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></button><button class="table-action-btn danger" title="Reject" onclick="rejectPromotion('${escapeAttr(p.id)}')"><svg fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>` : '<span style="font-size:11px;color:var(--muted);">-</span>'}</td>
            </tr>`;
        }).join('');
        pagInfo.innerHTML = `Showing <strong>${rows.length}</strong> records`;
    }

    async function savePromotion() {
        const empSel = document.getElementById('promoEmployeeId');
        const empOpt = empSel.options[empSel.selectedIndex];
        const payload = {
            employee_id: empSel.value,
            from_designation_id: empOpt?.dataset?.desgId || null,
            to_designation_id: document.getElementById('promoToDesg').value,
            from_department_id: empOpt?.dataset?.deptId || null,
            to_department_id: document.getElementById('promoToDept').value || null,
            effective_date: document.getElementById('promoDate').value,
            new_salary: document.getElementById('promoSalary').value ? Number(document.getElementById('promoSalary').value) : null,
            remarks: document.getElementById('promoRemarks').value
        };
        if (!payload.employee_id) { showToast('Please select an employee', 'error'); return; }
        if (!payload.to_designation_id) { showToast('Please select a designation', 'error'); return; }
        if (!payload.effective_date) { showToast('Please select effective date', 'error'); return; }

        const btn = document.getElementById('btnSavePromo');
        btn.disabled = true;
        btn.textContent = 'Saving...';
        const res = await EmsApi.promotions.create(payload);
        btn.disabled = false;
        btn.textContent = 'Save Promotion';
        if (!res.success) {
            showToast(res.error || 'Unable to save promotion in database', 'error');
            return;
        }
        closeModal('promoModal');
        showToast('Promotion saved successfully', 'success');
        await loadPromotions();
    }

    async function approvePromotion(id) {
        const res = await EmsApi.promotions.approve(id);
        if (!res.success) { showToast(res.error || 'Unable to approve promotion', 'error'); return; }
        showToast('Promotion approved', 'success');
        await loadPromotions();
    }

    async function rejectPromotion(id) {
        showConfirm({
            title: 'Reject Promotion?',
            message: 'This will reject the promotion record.',
            type: 'warning',
            confirmText: 'Reject',
            onConfirm: async () => {
                const res = await EmsApi.promotions.reject(id);
                if (!res.success) { showToast(res.error || 'Unable to reject promotion', 'error'); return; }
                showToast('Promotion rejected', 'success');
                await loadPromotions();
            }
        });
    }

    function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    }

    function escapeAttr(value) {
        return escapeHtml(value).replace(/`/g, '&#96;');
    }
</script>
}
