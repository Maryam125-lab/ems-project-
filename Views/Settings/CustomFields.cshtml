@{ ViewData["Icon"] = "<i class='fa-solid fa-chart-simple' aria-hidden='true'></i>"; ViewData["Subtitle"] = "Add custom data fields to employee records"; ViewData["ItemName"] = "Field"; ViewData["Count"] = "3";
