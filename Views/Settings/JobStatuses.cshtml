@{ ViewData["Icon"] = "<i class='fa-solid fa-square-check' aria-hidden='true'></i>"; ViewData["Subtitle"] = "Define employment status types"; ViewData["ItemName"] = "Status"; ViewData["Count"] = "4";
ViewData["TableHeaders"] = @"<th>Status Name</th><th>Color</th><th>Description</th><th>Actions</th>";
ViewData["TableBody"] = @"<tr><td><strong>Active</strong></td><td><span class=""tag tag-green"">Green</span></td><td>Currently employed and working</td><td><div class=""table-actions""><button class=""table-action-btn"" onclick=""openModal('configModal')""><svg fill=""none"" stroke=""currentColor"" stroke-width=""2"" viewBox=""0 0 24 24""><path d=""M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z""/><path d=""M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7""/></svg></button></div></td></tr><tr><td><strong>Probation</strong></td><td><span class=""tag tag-amber"">Amber</span></td><td>Under probation period</td><td><div class=""table-actions""><button class=""table-action-btn"" onclick=""openModal('configModal')""><svg fill=""none"" stroke=""currentColor"" stroke-width=""2"" viewBox=""0 0 24 24""><path d=""M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z""/><path d=""M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7""/></svg></button></div></td></tr><tr><td><strong>Resigned</strong></td><td><span class=""tag tag-red"">Red</span></td><td>Voluntarily left the company</td><td><div class=""table-actions""><button class=""table-action-btn"" onclick=""openModal('configModal')""><svg fill=""none"" stroke=""currentColor"" stroke-width=""2"" viewBox=""0 0 24 24""><path d=""M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z""/><path d=""M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7""/></svg></button></div></td></tr><tr><td><strong>Terminated</strong></td><td><span class=""tag tag-red"">Red</span></td><td>Employment terminated by company</td><td><div class=""table-actions""><button class=""table-action-btn"" onclick=""openModal('configModal')""><svg fill=""none"" stroke=""currentColor"" stroke-width=""2"" viewBox=""0 0 24 24""><path d=""M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z""/><path d=""M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7""/></svg></button></div></td></tr>";
ViewData["ModalFields"] = @"<div class=""form-grid""><div class=""field-group""><label class=""field-label"">Status Name <span class=""field-required"">*</span></label><input type=""text"" class=""field-input"" /></div><div class=""field-group""><label class=""field-label"">Color</label><select class=""field-select""><option>Green</option><option>Amber</option><option>Red</option><option>Blue</option></select></div><div class=""field-group""><label class=""field-label"">Description</label><textarea class=""field-textarea"" rows=""2""></textarea></div></div>"; }
@await Html.PartialAsync("_ConfigPage")
@section Scripts { <script src="~/js/tables.js"></script><script src="~/js/modals.js"></script> }

