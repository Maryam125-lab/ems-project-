@{ ViewData["Icon"] = "<i class='fa-solid fa-clipboard-list' aria-hidden='true'></i>"; ViewData["Subtitle"] = "Define leave allocation rules per employee type"; ViewData["ItemName"] = "Policy"; ViewData["Count"] = "3";
