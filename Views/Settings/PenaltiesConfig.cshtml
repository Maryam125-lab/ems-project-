@{ ViewData["Icon"] = "<i class='fa-solid fa-triangle-exclamation' aria-hidden='true'></i>"; ViewData["Subtitle"] = "Define penalty rules and fine amounts"; ViewData["ItemName"] = "Rule"; ViewData["Count"] = "4";
ViewData["TableHeaders"] = @"<th>Rule Name</th><th>Category</th><th>Amount (PKR)</th><th>Auto-Apply</th><th>Status</th><th>Actions</th>";
ViewData["TableBody"] = @"<tr><td><strong>Late Arrival (&gt;10 min)</strong></td><td><span class=""tag tag-amber"">Attendance</span></td><td><strong class=""cell-mono"">500</strong></td><td><span class=""tag tag-green"">Yes</span></td><td><span class=""status-badge approved"">Active</span></td><td><div class=""table-actions""><button class=""table-action-btn"" onclick=""openModal('configModal')""><svg fill=""none"" stroke=""currentColor"" stroke-width=""2"" viewBox=""0 0 24 24""><path d=""M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z""/><path d=""M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7""/></svg></button></div></td></tr><tr><td><strong>Early Leave (without approval)</strong></td><td><span class=""tag tag-amber"">Attendance</span></td><td><strong class=""cell-mono"">1,000</strong></td><td><span class=""tag tag-red"">No</span></td><td><span class=""status-badge approved"">Active</span></td><td><div class=""table-actions""><button class=""table-action-btn"" onclick=""openModal('configModal')""><svg fill=""none"" stroke=""currentColor"" stroke-width=""2"" viewBox=""0 0 24 24""><path d=""M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z""/><path d=""M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7""/></svg></button></div></td></tr><tr><td><strong>Policy Violation</strong></td><td><span class=""tag tag-red"">Conduct</span></td><td><strong class=""cell-mono"">2,000</strong></td><td><span class=""tag tag-red"">No</span></td><td><span class=""status-badge approved"">Active</span></td><td><div class=""table-actions""><button class=""table-action-btn"" onclick=""openModal('configModal')""><svg fill=""none"" stroke=""currentColor"" stroke-width=""2"" viewBox=""0 0 24 24""><path d=""M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z""/><path d=""M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7""/></svg></button></div></td></tr><tr><td><strong>Misconduct</strong></td><td><span class=""tag tag-red"">Conduct</span></td><td><strong class=""cell-mono"">5,000</strong></td><td><span class=""tag tag-red"">No</span></td><td><span class=""status-badge approved"">Active</span></td><td><div class=""table-actions""><button class=""table-action-btn"" onclick=""openModal('configModal')""><svg fill=""none"" stroke=""currentColor"" stroke-width=""2"" viewBox=""0 0 24 24""><path d=""M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z""/><path d=""M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7""/></svg></button></div></td></tr>";
ViewData["ModalFields"] = @"<div class=""form-grid form-grid-2""><div class=""field-group""><label class=""field-label"">Rule Name <span class=""field-required"">*</span></label><input type=""text"" class=""field-input"" placeholder=""e.g. Late Arrival"" /></div><div class=""field-group""><label class=""field-label"">Category</label><select class=""field-select""><option>Attendance</option><option>Conduct</option><option>Performance</option></select></div><div class=""field-group""><label class=""field-label"">Amount (PKR)</label><input type=""number"" class=""field-input"" value=""500"" /></div><div class=""field-group""><label class=""field-label"">Auto-Apply</label><select class=""field-select""><option>Yes</option><option>No</option></select></div></div>"; }
@await Html.PartialAsync("_ConfigPage")
