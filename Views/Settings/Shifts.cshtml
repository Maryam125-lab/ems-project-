@{ ViewData["Icon"] = "<i class='fa-regular fa-clock' aria-hidden='true'></i>"; ViewData["Subtitle"] = "Define working shifts and timings"; ViewData["ItemName"] = "Shift"; ViewData["Count"] = "3";
ViewData["TableHeaders"] = @"<th>Shift Name</th><th>Start Time</th><th>End Time</th><th>Grace (min)</th><th>Status</th><th>Actions</th>";
ViewData["TableBody"] = @"<tr><td><strong>Morning Shift</strong></td><td><span class=""cell-mono"">09:00 AM</span></td><td><span class=""cell-mono"">06:00 PM</span></td><td>15</td><td><span class=""status-badge approved"">Active</span></td><td><div class=""table-actions""><button class=""table-action-btn"" onclick=""openModal('configModal')""><svg fill=""none"" stroke=""currentColor"" stroke-width=""2"" viewBox=""0 0 24 24""><path d=""M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z""/><path d=""M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7""/></svg></button></div></td></tr><tr><td><strong>Evening Shift</strong></td><td><span class=""cell-mono"">02:00 PM</span></td><td><span class=""cell-mono"">11:00 PM</span></td><td>10</td><td><span class=""status-badge approved"">Active</span></td><td><div class=""table-actions""><button class=""table-action-btn"" onclick=""openModal('configModal')""><svg fill=""none"" stroke=""currentColor"" stroke-width=""2"" viewBox=""0 0 24 24""><path d=""M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z""/><path d=""M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7""/></svg></button></div></td></tr><tr><td><strong>Night Shift</strong></td><td><span class=""cell-mono"">10:00 PM</span></td><td><span class=""cell-mono"">07:00 AM</span></td><td>10</td><td><span class=""status-badge approved"">Active</span></td><td><div class=""table-actions""><button class=""table-action-btn"" onclick=""openModal('configModal')""><svg fill=""none"" stroke=""currentColor"" stroke-width=""2"" viewBox=""0 0 24 24""><path d=""M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z""/><path d=""M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7""/></svg></button></div></td></tr>";
ViewData["ModalFields"] = @"<div class=""form-grid form-grid-2""><div class=""field-group form-full""><label class=""field-label"">Shift Name <span class=""field-required"">*</span></label><input type=""text"" class=""field-input"" placeholder=""e.g. Morning Shift"" /></div><div class=""field-group""><label class=""field-label"">Start Time</label><input type=""time"" class=""field-input"" value=""09:00"" /></div><div class=""field-group""><label class=""field-label"">End Time</label><input type=""time"" class=""field-input"" value=""18:00"" /></div><div class=""field-group""><label class=""field-label"">Grace Period (minutes)</label><input type=""number"" class=""field-input"" value=""15"" /></div><div class=""field-group""><label class=""field-label"">Status</label><select class=""field-select""><option>Active</option><option>Inactive</option></select></div></div>"; }
@await Html.PartialAsync("_ConfigPage")
