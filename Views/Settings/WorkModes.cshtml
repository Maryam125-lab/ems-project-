@{ ViewData["Icon"] = "<i class='fa-solid fa-desktop' aria-hidden='true'></i>"; ViewData["Subtitle"] = "Define remote, on-site, and hybrid work modes"; ViewData["ItemName"] = "Mode"; ViewData["Count"] = "3";
