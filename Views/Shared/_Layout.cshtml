@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TRACK360 ERP</title>
    <meta name="description" content="TRACK360 ERP - Enterprise Resource Planning System by ESSPL" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/ems.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/animations.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script>window.__EMS_API_BASE = '@(Configuration["ApiBaseUrl"] ?? "")';</script>
    <script src="~/js/api.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- SIDEBAR -->
    <nav class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon">
                <svg width="18" height="18" fill="none" stroke="#fff" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                </svg>
            </div>
            <div>
                <div class="logo-text">TRACK360</div>
                <div class="logo-sub">Enterprise Resource Planning</div>
            </div>
        </div>

        <!-- ERP MODULES -->
        <div class="nav-section">
            <div class="nav-label">ERP Modules</div>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "Inventory" ? "active" : "")"
               asp-controller="Inventory" asp-action="Index" id="nav-inventory">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="M3.3 7 12 12l8.7-5"/><path d="M12 22V12"/></svg>
                Inventory
            </a>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "Projects" ? "active" : "")"
               asp-controller="Projects" asp-action="Index" id="nav-projects">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 3h7v7H3z"/><path d="M14 3h7v7h-7z"/><path d="M14 14h7v7h-7z"/><path d="M7 10v4h10"/></svg>
                Projects
                <span class="nav-status-badge">Soon</span>
            </a>
        </div>

        <!-- HR WORKSPACE -->
        <div class="nav-section">
            <div class="nav-label">HR Workspace</div>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "Dashboard" ? "active" : "")"
               asp-controller="Dashboard" asp-action="Index" id="nav-dashboard">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                Dashboard
            </a>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "Employees" ? "active" : "")"
               asp-controller="Employees" asp-action="Index" id="nav-employees">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                Employees
            </a>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "Attendance" ? "active" : "")"
               asp-controller="Attendance" asp-action="Index" id="nav-attendance">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Attendance
                <span class="badge-count" id="attendance-badge" style="display:none;"></span>
            </a>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "Leave" ? "active" : "")"
               asp-controller="Leave" asp-action="Index" id="nav-leave">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                Leave
                <span class="badge-red">3</span>
            </a>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "Payroll" ? "active" : "")"
               asp-controller="Payroll" asp-action="Index" id="nav-payroll">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                Payroll
            </a>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "Promotions" ? "active" : "")"
               asp-controller="Promotions" asp-action="Index" id="nav-promotions">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                Promotions
            </a>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "Penalties" ? "active" : "")"
               asp-controller="Penalties" asp-action="Index" id="nav-penalties">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                Penalties
            </a>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "Announcements" ? "active" : "")"
               asp-controller="Announcements" asp-action="Index" id="nav-announcements">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                Announcements
            </a>
        </div>

        <!-- CONFIGURATION -->
        <div class="nav-section">
            <div class="nav-label nav-label-toggle" onclick="toggleSection('config-items')" id="config-toggle">
                Configuration
                <svg class="section-arrow" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
            <div class="nav-items-group collapsed" id="config-items">
                <a class="nav-item @(ViewData["Active"]?.ToString() == "Departments" ? "active" : "")"
                   asp-controller="Settings" asp-action="Departments">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
                    Departments
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "Designations" ? "active" : "")"
                   asp-controller="Settings" asp-action="Designations">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    Designations
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "Shifts" ? "active" : "")"
                   asp-controller="Settings" asp-action="Shifts">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Shifts
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "WorkLocations" ? "active" : "")"
                   asp-controller="Settings" asp-action="WorkLocations">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    Work Locations
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "LeaveTypes" ? "active" : "")"
                   asp-controller="Settings" asp-action="LeaveTypes">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/></svg>
                    Leave Types
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "LeavePolicies" ? "active" : "")"
                   asp-controller="Settings" asp-action="LeavePolicies">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Leave Policies
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "PenaltiesConfig" ? "active" : "")"
                   asp-controller="Settings" asp-action="PenaltiesConfig">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                    Penalty Rules
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "SalaryComponents" ? "active" : "")"
                   asp-controller="Settings" asp-action="SalaryComponents">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    Salary Components
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "GlobalDays" ? "active" : "")"
                   asp-controller="Settings" asp-action="GlobalDays">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    Global Holidays
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "EmployeeTypes" ? "active" : "")"
                   asp-controller="Settings" asp-action="EmployeeTypes">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
                    Employee Types
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "WorkModes" ? "active" : "")"
                   asp-controller="Settings" asp-action="WorkModes">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    Work Modes
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "JobStatuses" ? "active" : "")"
                   asp-controller="Settings" asp-action="JobStatuses">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                    Job Statuses
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "TaxConfig" ? "active" : "")"
                   asp-controller="Settings" asp-action="TaxConfig">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                    Tax Configuration
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "ReportingManagers" ? "active" : "")"
                   asp-controller="Settings" asp-action="ReportingManagers">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Reporting Managers
                </a>
            </div>
        </div>

        <!-- ADMINISTRATION -->
        <div class="nav-section">
            <div class="nav-label">Administration</div>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "HRAccounts" ? "active" : "")"
               asp-controller="Accounts" asp-action="Index" id="nav-accounts">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                HR Accounts
            </a>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "AuditLog" ? "active" : "")"
               asp-controller="AuditLog" asp-action="Index" id="nav-auditlog">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                Audit Log
            </a>
            <a class="nav-item @(ViewData["Active"]?.ToString() == "CustomFields" ? "active" : "")"
               asp-controller="Settings" asp-action="CustomFields" id="nav-customfields">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                Custom Fields
            </a>
        </div>

        <!-- EMPLOYEE SELF-SERVICE -->
        <div class="nav-section">
            <div class="nav-label nav-label-toggle" onclick="toggleSection('emp-items')" id="emp-toggle">
                Employee Portal
                <svg class="section-arrow" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
            </div>
            <div class="nav-items-group collapsed" id="emp-items">
                <a class="nav-item @(ViewData["Active"]?.ToString() == "MyDashboard" ? "active" : "")"
                   asp-controller="MyPortal" asp-action="Dashboard">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                    My Dashboard
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "MyAttendance" ? "active" : "")"
                   asp-controller="MyPortal" asp-action="Attendance">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    My Attendance
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "MyLeave" ? "active" : "")"
                   asp-controller="MyPortal" asp-action="ApplyLeave">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/></svg>
                    Apply for Leave
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "MyPayslips" ? "active" : "")"
                   asp-controller="MyPortal" asp-action="Payslips">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                    My Payslips
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "MyPenalties" ? "active" : "")"
                   asp-controller="MyPortal" asp-action="Penalties">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>
                    My Penalties
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "MyProfile" ? "active" : "")"
                   asp-controller="MyPortal" asp-action="Profile">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    My Profile
                </a>
                <a class="nav-item @(ViewData["Active"]?.ToString() == "Directory" ? "active" : "")"
                   asp-controller="MyPortal" asp-action="Directory">
                    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Company Directory
                </a>
            </div>
        </div>

        <!-- USER INFO -->
        <div class="sidebar-user" id="sidebarUser">
            <div class="user-avatar-sm" id="sidebarAvatar">U</div>
            <div style="flex:1;">
                <div style="font-size:13px;font-weight:600;" id="sidebarUserName">Loading...</div>
                <div style="font-size:11px;color:var(--muted);" id="sidebarUserRole">—</div>
            </div>
            <a href="javascript:void(0)" style="color:var(--muted);cursor:pointer;text-decoration:none;" title="Sign Out" onclick="EmsApi.logout()">
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
            </a>
        </div>
    </nav>

    <!-- MOBILE HAMBURGER -->
    <button class="mobile-menu-btn" id="mobileMenuBtn" onclick="toggleMobileMenu()">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>

    <!-- MAIN WRAPPER -->
    <div class="main">

        <!-- TOPBAR -->
        <div class="topbar">
            <div class="breadcrumb-nav">
                ERP &gt; <span>@ViewData["Title"]</span>
            </div>
            <div class="search-bar">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" placeholder="Search employees, records, reports…" id="globalSearch" />
                <span class="kbd">⌘K</span>
            </div>
            <div class="topbar-right">
                <div class="role-badge" id="roleBadge" style="font-size:11px;padding:4px 12px;border-radius:6px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;"></div>
                <!-- Notification Bell -->
                <div class="topbar-notification" id="notifBell" onclick="toggleNotifications()">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                    </svg>
                    <span class="notif-dot" id="notifDot"></span>
                </div>
                <div class="date-tag">@DateTime.Now.ToString("ddd, dd MMM yyyy")</div>
                <div class="user-avatar-sm" id="topbarAvatarMain">U</div>
            </div>
        </div>

        <!-- PAGE CONTENT -->
        <div class="content">
            @RenderBody()
        </div>

    </div>

    <!-- GLOBAL SEARCH MODAL -->
    <div class="search-modal-overlay" id="searchModalOverlay">
        <div class="search-modal">
            <div class="search-modal-header">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" id="modalSearchInput" placeholder="Search employees, records, reports..." autocomplete="off" />
                <span class="kbd">ESC</span>
            </div>
            <div class="search-modal-body">
                <div class="search-section" id="quickLinksSection">
                    <div class="search-section-title">Quick Links</div>
                    <a href="/Employees/Create" class="search-result-item">
                        <div class="search-result-icon"><i class="fa-solid fa-user-plus"></i></div>
                        <div class="search-result-content">
                            <div class="search-result-title">Add New Employee</div>
                            <div class="search-result-desc">Create a new employee profile</div>
                        </div>
                        <div class="search-result-arrow"><i class="fa-solid fa-chevron-right"></i></div>
                    </a>
                    <a href="/Leave" class="search-result-item">
                        <div class="search-result-icon blue"><i class="fa-solid fa-calendar-check"></i></div>
                        <div class="search-result-content">
                            <div class="search-result-title">Leave Approvals</div>
                            <div class="search-result-desc">Pending leave requests</div>
                        </div>
                        <div class="search-result-arrow"><i class="fa-solid fa-chevron-right"></i></div>
                    </a>
                </div>
                
                <div class="search-section" id="employeeSearchResults" style="display:none;">
                    <div class="search-section-title">Employees</div>
                    <!-- Dynamically populated via JS for simulation -->
                </div>

                <div class="search-section" id="inventorySearchResults" style="display:none;">
                    <div class="search-section-title">Inventory</div>
                </div>
            </div>
            <div class="search-modal-footer">
                <div style="display:flex; gap:16px;">
                    <span>Navigate with <kbd>↑</kbd> <kbd>↓</kbd></span>
                    <span>Select with <kbd>↵</kbd></span>
                </div>
            </div>
        </div>
    </div>

    <!-- NOTIFICATION PANEL (hidden by default) -->
    <div class="notif-panel" id="notifPanel">
        <div class="notif-panel-header">
            <span style="font-weight:700;font-size:14px;">Notifications</span>
            <button class="notif-mark-all" onclick="markAllRead()">Mark All Read</button>
        </div>
        <div class="notif-list" id="notifListContainer">
            <div style="text-align:center;padding:30px;color:var(--muted);font-size:12px;">Loading notifications...</div>
        </div>
    </div>

    <script src="~/js/sidebar.js" asp-append-version="true"></script>
    <script>
        // ── Auth Guard: Redirect to login if not authenticated ──
        if (!EmsApi.isLoggedIn()) {
            window.location.href = '/';
        }

        // ── Load user info & RBAC ──
        (async function loadUserInfo() {
            let user = EmsApi.getUser();
            const guidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;

            if (!user || (user.role_name && guidRegex.test(user.role_name))) {
                const session = await EmsApi.getSession();
                if (session.success && session.data) {
                    user = user || {};
                    user.role_name = session.data.role_name || session.data.role_id;
                    user.is_super_admin = session.data.is_super_admin || false;
                    user.permissions = session.data.permissions || [];
                    user.employee_name = session.data.employee_name;
                    user.email = session.data.email;
                    localStorage.setItem('ems_user_data', JSON.stringify(user));
                }
            }

            const normalizeRole = (value) => String(value || '').toLowerCase().trim().replace(/\s+/g, '_');
            const role = normalizeRole(EmsApi.getRoleName());
            const nameEl = document.getElementById('sidebarUserName');
            const roleEl = document.getElementById('sidebarUserRole');
            const avatarEl = document.getElementById('sidebarAvatar');
            const topAvatarEl = document.getElementById('topbarAvatarMain');
            const roleBadgeEl = document.getElementById('roleBadge');

            if (user) {
                const name = user.employee_name || (user.email ? user.email.split('@@')[0].replace(/[._]/g, ' ') : 'User');
                const initials = name.split(' ').map(function(w){ return w[0]; }).join('').substring(0,2).toUpperCase();
                const roleName = user.role_name || (role === 'super_admin' ? 'Super Admin' : (role === 'hr_manager' ? 'HR Manager' : 'Employee'));

                if (nameEl) nameEl.textContent = name;
                if (roleEl) roleEl.textContent = roleName;
                if (avatarEl) avatarEl.textContent = initials;
                if (topAvatarEl) topAvatarEl.textContent = initials;
                if (roleBadgeEl) {
                    roleBadgeEl.textContent = roleName;
                    if (role === 'super_admin') {
                        roleBadgeEl.style.background = 'rgba(139,92,246,0.15)'; roleBadgeEl.style.color = '#a78bfa';
                    } else if (role.includes('hr')) {
                        roleBadgeEl.style.background = 'rgba(59,130,246,0.15)'; roleBadgeEl.style.color = '#60a5fa';
                    } else {
                        roleBadgeEl.style.background = 'rgba(16,185,129,0.15)'; roleBadgeEl.style.color = '#34d399';
                    }
                }

                // ── RBAC Sidebar Visibility ──
                const isSuperAdmin = role === 'super_admin' || role === 'superadmin' || user.is_super_admin === true;
                const isHR = role.toLowerCase().includes('hr');
                const isEmployee = role === 'employee';

                // Helper to find sections by label
                const findSectionByLabel = (text) => {
                    return Array.from(document.querySelectorAll('.nav-label'))
                        .find(el => el.textContent.trim() === text)
                        ?.closest('.nav-section');
                };

                const configSection = document.getElementById('config-toggle')?.closest('.nav-section');
                const adminSection = document.getElementById('nav-accounts')?.closest('.nav-section');
                const empPortalSection = document.getElementById('emp-toggle')?.closest('.nav-section');
                const erpSection = findSectionByLabel('ERP Modules');
                const coreSection = findSectionByLabel('HR Workspace');

                if (isEmployee) {
                    // Employees only see Employee Portal
                    if (erpSection) erpSection.style.display = 'none';
                    if (configSection) configSection.style.display = 'none';
                    if (adminSection) adminSection.style.display = 'none';
                    if (coreSection) coreSection.style.display = 'none';
                    if (empPortalSection) {
                        empPortalSection.style.display = 'block';
                        // Auto-expand employee portal for employees
                        const empItems = document.getElementById('emp-items');
                        if (empItems) empItems.classList.remove('collapsed');
                    }
                    const searchBar = document.querySelector('.search-bar');
                    if (searchBar) searchBar.style.display = 'none';
                } else {
                    // Admin/HR see core modules
                    if (empPortalSection) empPortalSection.style.display = 'block';
                    if (!isSuperAdmin && erpSection) erpSection.style.display = 'none';
                    document.querySelectorAll('.super-admin-only').forEach(el => {
                        el.style.display = isSuperAdmin ? '' : 'none';
                    });
                    if (isHR && !isSuperAdmin) {
                        if (adminSection) adminSection.style.display = 'none';
                    }
                }
            }
        })();

        // ── Load Notifications from API ──
        (async function loadNotifications() {
            const res = await EmsApi.notifications.list();
            const notifList = document.getElementById('notifListContainer');
            const notifDot = document.getElementById('notifDot');
            if (res.success && Array.isArray(res.data) && res.data.length > 0) {
                const unread = res.data.filter(n => !n.is_read);
                if (notifDot) notifDot.style.display = unread.length > 0 ? 'block' : 'none';
                if (notifList) {
                    notifList.innerHTML = res.data.slice(0, 10).map(n => `
                        <div class="notif-item ${n.is_read ? '' : 'unread'}" onclick="EmsApi.notifications.markRead('${n.id}'); this.classList.remove('unread');">
                            <div class="notif-icon blue">
                                <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/></svg>
                            </div>
                            <div>
                                <div class="notif-text">${n.message || n.title || 'Notification'}</div>
                                <div class="notif-time">${n.created_at ? new Date(n.created_at).toLocaleDateString() : ''}</div>
                            </div>
                        </div>`).join('');
                }
            } else {
                if (notifList) notifList.innerHTML = '<div style="text-align:center;padding:30px;color:var(--muted);font-size:12px;">No new notifications</div>';
                if (notifDot) notifDot.style.display = 'none';
            }
        })();

        // ── Global Search (with API) ──
        document.addEventListener("DOMContentLoaded", function () {
            const topSearch = document.getElementById("globalSearch");
            const searchModalOverlay = document.getElementById("searchModalOverlay");
            const modalSearchInput = document.getElementById("modalSearchInput");
            const employeeResults = document.getElementById("employeeSearchResults");
            const inventoryResults = document.getElementById("inventorySearchResults");
            const quickLinks = document.getElementById("quickLinksSection");
            let searchDebounce = null;

            function escapeHtml(value) {
                return String(value ?? '')
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#039;');
            }

            function responseRows(res) {
                if (!res || !res.success || !res.data) return [];
                if (Array.isArray(res.data)) return res.data;
                if (Array.isArray(res.data.data)) return res.data.data;
                if (Array.isArray(res.data.items)) return res.data.items;
                return [];
            }

            function valuesText(row) {
                return Object.values(row || {}).map(value => String(value ?? '')).join(' ').toLowerCase();
            }

            function filterRows(rows, query) {
                const normalized = query.toLowerCase();
                return rows.filter(row => valuesText(row).includes(normalized));
            }

            async function searchInventory(query) {
                const hrefForTab = (tab) => '/Inventory?tab=' + encodeURIComponent(tab) + '&search=' + encodeURIComponent(query);
                const calls = await Promise.allSettled([
                    EmsApi.inventory.invoiceLedger(),
                    EmsApi.inventory.salesFlow(),
                    EmsApi.inventory.products({ limit: 100 }),
                    EmsApi.inventory.serials({ limit: 100 }),
                    EmsApi.inventory.customers({ limit: 100 }),
                    EmsApi.inventory.vendors({ limit: 100 })
                ]);
                const [ledger, sales, products, serials, customers, vendors] = calls.map(result => result.status === 'fulfilled' ? result.value : null);
                return [
                    ...filterRows(responseRows(ledger), query).map(row => ({ title: row.invoice_no || row.reference_no || 'Invoice', desc: `${row.invoice_direction || 'Invoice'} / ${row.party_name || ''} / ${row.payment_status || ''}`, href: hrefForTab('sales'), icon: 'fa-file-invoice' })),
                    ...filterRows(responseRows(sales), query).map(row => ({ title: row.invoice_id || row.quotation_id || row.do_id || 'Sales workflow', desc: `${row.customer_name || ''} / ${row.delivery_status || ''} / ${row.payment_status || ''}`, href: hrefForTab('sales'), icon: 'fa-receipt' })),
                    ...filterRows(responseRows(products), query).map(row => ({ title: row.product_name || 'Product', desc: `${row.category_name || ''} / ${row.product_type || ''} / ${row.tracking_type || ''}`, href: hrefForTab('stock'), icon: 'fa-boxes-stacked' })),
                    ...filterRows(responseRows(serials), query).map(row => ({ title: row.serial_number || 'Serial', desc: `${row.product_name || ''} / ${row.category_name || ''} / ${row.current_status || ''}`, href: hrefForTab('stock'), icon: 'fa-barcode' })),
                    ...filterRows(responseRows(customers), query).map(row => ({ title: row.customer_name || row.company_name || 'Customer', desc: `${row.company_name || ''} / ${row.phone || ''} / ${row.email || ''}`, href: hrefForTab('parties'), icon: 'fa-building-user' })),
                    ...filterRows(responseRows(vendors), query).map(row => ({ title: row.vendor_name || 'Vendor', desc: `${row.contact_person || ''} / ${row.phone || ''} / ${row.email || ''}`, href: hrefForTab('parties'), icon: 'fa-truck-field' }))
                ].slice(0, 8);
            }

            function syncPageSearch(query) {
                const inventorySearch = document.getElementById('inventorySearch');
                if (inventorySearch && typeof window.applyInventorySearch === 'function') {
                    inventorySearch.value = query;
                    window.applyInventorySearch();
                }
                const employeeSearch = document.getElementById('empSearch');
                if (employeeSearch && typeof window.applyFilters === 'function') {
                    employeeSearch.value = query;
                    window.applyFilters();
                }
            }

            function openSearchModal() {
                searchModalOverlay.classList.add("active");
                setTimeout(() => modalSearchInput.focus(), 100);
                topSearch.blur();
            }

            function closeSearchModal() {
                searchModalOverlay.classList.remove("active");
                modalSearchInput.value = "";
                renderResults("", [], []);
            }

            topSearch.addEventListener("focus", openSearchModal);

            document.addEventListener("keydown", function (e) {
                if ((e.metaKey || e.ctrlKey) && e.key === "k") {
                    e.preventDefault();
                    openSearchModal();
                }
                if (e.key === "Escape" && searchModalOverlay.classList.contains("active")) {
                    closeSearchModal();
                }
            });

            searchModalOverlay.addEventListener("click", function (e) {
                if (e.target === searchModalOverlay) closeSearchModal();
            });

            modalSearchInput.addEventListener("input", function (e) {
                const query = e.target.value.trim();
                syncPageSearch(query);
                if (!query) { renderResults("", [], []); return; }
                clearTimeout(searchDebounce);
                searchDebounce = setTimeout(async () => {
                    const [employeeRes, inventoryRes] = await Promise.allSettled([
                        EmsApi.employees.list(query),
                        searchInventory(query)
                    ]);
                    const employees = employeeRes.status === 'fulfilled' ? responseRows(employeeRes.value) : [];
                    const inventory = inventoryRes.status === 'fulfilled' ? inventoryRes.value : [];
                    renderResults(query, employees, inventory);
                }, 300);
            });

            function renderResults(query, employees, inventory) {
                if (!query) {
                    employeeResults.style.display = "none";
                    inventoryResults.style.display = "none";
                    quickLinks.style.display = "block";
                    return;
                }
                quickLinks.style.display = "none";
                if (employees.length > 0) {
                    employeeResults.style.display = "block";
                    employeeResults.innerHTML = '<div class="search-section-title">Employees</div>';
                    employees.forEach(emp => {
                        const name = emp.name || emp.employee_id || 'Employee';
                        const initials = name.split(' ').map(w => w[0]).join('').substring(0,2).toUpperCase();
                        const html = `
                        <a href="/Employees/Details/${emp.employee_id || emp.id}" class="search-result-item">
                            <div class="search-result-icon" style="display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px;">${initials}</div>
                            <div class="search-result-content">
                                <div class="search-result-title">${name}</div>
                                <div class="search-result-desc">${emp.designation_title || emp.designation_name || ''} • ${emp.department_name || ''}</div>
                            </div>
                            <div class="search-result-arrow"><i class="fa-solid fa-chevron-right"></i></div>
                        </a>`;
                        employeeResults.insertAdjacentHTML('beforeend', html);
                    });
                } else {
                    employeeResults.style.display = "block";
                    employeeResults.innerHTML = '<div class="search-section-title">Employees</div><div style="padding:12px;color:var(--muted);font-size:13px;text-align:center;padding-top:20px;">No results found for "'+query+'"</div>';
                }
                if (inventory.length > 0) {
                    inventoryResults.style.display = "block";
                    inventoryResults.innerHTML = '<div class="search-section-title">Inventory</div>';
                    inventory.forEach(item => {
                        const html = `
                        <a href="${item.href}" class="search-result-item">
                            <div class="search-result-icon blue"><i class="fa-solid ${item.icon}"></i></div>
                            <div class="search-result-content">
                                <div class="search-result-title">${escapeHtml(item.title)}</div>
                                <div class="search-result-desc">${escapeHtml(item.desc)}</div>
                            </div>
                            <div class="search-result-arrow"><i class="fa-solid fa-chevron-right"></i></div>
                        </a>`;
                        inventoryResults.insertAdjacentHTML('beforeend', html);
                    });
                } else {
                    inventoryResults.style.display = "none";
                }
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
