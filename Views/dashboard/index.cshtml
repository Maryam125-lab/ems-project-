@{
    ViewData["Title"] = "Dashboard";
    ViewData["Active"] = "Dashboard";
}

<!-- PAGE HEADER -->
<div class="page-header" id="dashHeader">
    <div>
        <div class="page-title" id="greetingText">
            Good afternoon, Admin <i class="fa-solid fa-fire" aria-hidden="true"></i>
            <span class="live-dot">LIVE</span>
        </div>
        <div class="page-date"><i class="fa-regular fa-calendar" aria-hidden="true"></i> @DateTime.Now.ToString("dddd, dd MMMM yyyy") · EMS Dashboard</div>
    </div>
    <a href="/Employees/Create" class="btn-primary">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        Add Employee
    </a>
</div>

<!-- KPI CARDS -->
<div class="kpi-grid" id="kpiGrid">
    <div class="kpi-card blue" id="kpiTotal">
        <div class="kpi-label">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            Total Payroll
            <span class="kpi-badge up" id="kpiBadgeTotal">↑ --</span>
        </div>
        <div class="kpi-num" id="kpiTotalNum"><span class="shimmer-text">---</span></div>
        <div class="kpi-sub" id="kpiTotalSub">Loading...</div>
    </div>
    <div class="kpi-card green" id="kpiPresent">
        <div class="kpi-label">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
            Present Today
            <span class="kpi-badge up" id="kpiBadgePresent">↑ --</span>
        </div>
        <div class="kpi-num" style="color:var(--accent2)" id="kpiPresentNum"><span class="shimmer-text">---</span></div>
        <div class="kpi-sub" id="kpiPresentSub">Loading...</div>
    </div>
    <div class="kpi-card amber" id="kpiLeave">
        <div class="kpi-label">
            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            On Leave Today
            <span class="kpi-badge down" id="kpiBadgeLeave">–</span>
        </div>
        <div class="kpi-num" style="color:var(--accent3)" id="kpiLeaveNum"><span class="shimmer-text">---</span></div>
        <div class="kpi-sub" id="kpiLeaveSub">Loading...</div>
    </div>
</div>

<!-- PENDING ACTIONS + PERFORMANCE -->
<div class="two-col">
    <div class="card" id="pendingCard">
        <div class="card-title">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--accent)"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Pending Actions
        </div>
        <div class="action-grid" id="pendingActions">
            <a href="/Leave" class="action-btn">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/></svg>
                Approve Leaves
                <span class="badge-red" id="pendingLeaveCount">-</span>
            </a>
            <a href="/Attendance" class="action-btn">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                Mark Attendance
            </a>
            <a href="/Employees/Create" class="action-btn">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Employee
            </a>
            <a href="/Penalties" class="action-btn">
                <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/></svg>
                Review Penalties
                <span class="badge-red" id="pendingPenaltyCount" style="display:none;">-</span>
            </a>
        </div>
    </div>
    <div class="card">
        <div class="card-title">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--accent)"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            Performance Metrics
        </div>
        <div class="metrics-grid" id="metricsGrid">
            <div class="metric"><div class="metric-num blue" id="metricAttendance">--%</div><div class="metric-label">Attendance</div></div>
            <div class="metric"><div class="metric-num green" id="metricLeaveUsed">--%</div><div class="metric-label">Leave Used</div></div>
            <div class="metric"><div class="metric-num amber" id="metricOnTime">--%</div><div class="metric-label">On-time</div></div>
        </div>
    </div>
</div>

<!-- DONUT CHARTS -->
<div class="three-col" style="margin-top:16px;">
    <div class="card">
        <div class="card-title">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--accent)"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            Employees by Department
        </div>
        <div style="display:flex;align-items:center;gap:20px;" id="deptChartArea">
            <svg width="110" height="110" viewBox="0 0 100 100" id="deptDonut">
                <circle cx="50" cy="50" r="38" fill="none" stroke="#1e2436" stroke-width="18"/>
                <text x="50" y="46" text-anchor="middle" font-family="DM Mono" font-size="14" font-weight="800" fill="#e2e8f0" id="deptDonutTotal">--</text>
                <text x="50" y="58" text-anchor="middle" font-family="DM Sans" font-size="7" fill="#64748b">HEADCOUNT</text>
            </svg>
            <div style="display:flex;flex-direction:column;gap:7px;flex:1;" id="deptLegend">
                <div style="font-size:12px;color:var(--muted);">Loading...</div>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-title">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--accent2)"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Workforce Composition
        </div>
        <div id="genderChart" style="padding:10px 0;">
            <div style="font-size:12px;color:var(--muted);text-align:center;">Loading distribution...</div>
        </div>
    </div>
    <div class="card">
        <div class="card-title">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--accent3)"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            Recent Activity
        </div>
        <div id="recentActivity" style="display:flex;flex-direction:column;gap:4px;">
            <div style="font-size:12px;color:var(--muted);text-align:center;padding:16px 0;">Loading activity...</div>
        </div>
    </div>
</div>

<!-- BAR + LINE CHARTS -->
<div class="two-col" style="margin-top:16px;">
    <div class="card">
        <div class="card-title">
            <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:var(--accent)"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            Monthly Attendance
        </div>
        <div style="display:flex;align-items:flex-end;gap:8px;height:100px;" id="monthlyBars">
            <div style="font-size:12px;color:var(--muted);width:100%;text-align:center;padding-top:30px;">Loading...</div>
        </div>
        <div style="display:flex;gap:12px;margin-top:8px;">
            <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:var(--muted);"><div style="width:8px;height:8px;background:var(--accent);border-radius:2px;"></div>Present</div>
            <div style="display:flex;align-items:center;gap:4px;font-size:10px;color:var(--muted);"><div style="width:8px;height:8px;background:var(--accent4);border-radius:2px;"></div>Late/Absent</div>
        </div>
    </div>
    <div class="card">
        <div class="card-title" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
            <div style="display:flex; align-items:center; gap:6px;">
                <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" style="color:var(--accent)"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                Notice Board & Announcements
            </div>
            <a href="/Announcements" style="font-size:11px; color:var(--accent); text-decoration:none; display:flex; align-items:center; gap:4px; font-weight:600;">Manage &rarr;</a>
        </div>
        <div id="adminAnnouncements" style="display:flex;flex-direction:column;gap:8px;">
            <div style="font-size:12px;color:var(--muted);padding:16px 0;text-align:center;">Loading announcements Notice Board...</div>
        </div>
    </div>
</div>

@section Styles {
<style>
    .shimmer-text { background: linear-gradient(90deg,#1e2436 25%,#2a3050 50%,#1e2436 75%); background-size:200% 100%; animation: shimmer 1.5s infinite; -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
    @@keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
    .alert-item { display:flex; align-items:center; gap:10px; padding:10px 12px; border-radius:8px; font-size:12px; border:1px solid rgba(255,255,255,0.04); transition:all 0.2s; }
    .alert-item:hover { background:rgba(255,255,255,0.03); }
    .alert-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
    .alert-dot.red { background:#ef4444; } .alert-dot.amber { background:#f59e0b; } .alert-dot.blue { background:#3b82f6; }
    .alert-label { color:var(--muted); font-size:11px; }
    .alert-value { font-weight:600; margin-left:auto; font-family:'DM Mono',monospace; font-size:12px; }
    .kpi-grid .kpi-card { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .kpi-grid .kpi-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
</style>
}

@section Scripts {
<script src="~/js/api.js" asp-append-version="true"></script>
<script src="~/js/dashboard-loader.js" asp-append-version="true"></script>
}       