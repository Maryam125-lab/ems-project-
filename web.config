<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <defaultDocument enabled="true">
        <files>
          <clear />
          <add value="index.html" />
        </files>
      </defaultDocument>
      <security>
        <requestFiltering>
          <fileExtensions allowUnlisted="true">
            <add fileExtension=".dll" allowed="false" />
            <add fileExtension=".pdb" allowed="false" />
            <add fileExtension=".deps.json" allowed="false" />
            <add fileExtension=".runtimeconfig.json" allowed="false" />
            <add fileExtension=".csproj" allowed="false" />
            <add fileExtension=".sln" allowed="false" />
            <add fileExtension=".config" allowed="false" />
          </fileExtensions>
        </requestFiltering>
      </security>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\EMS.Web.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
